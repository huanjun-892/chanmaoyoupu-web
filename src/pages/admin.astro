      // 复制到剪贴板
      navigator.clipboard.writeText(content).then(() => {
        showToast('内容已复制，正在跳转到' + config.name + '...', 'success');
        // 延迟跳转，给用户看到提示
        setTimeout(() => {
          window.open(config.publishUrl, '_blank');
