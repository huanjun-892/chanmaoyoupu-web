---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import RecipeCard from '../components/RecipeCard.astro';
import KnowledgeCard from '../components/KnowledgeCard.astro';
import { getAllRecipes, getAllKnowledge, getAllSecrets, getAllIngredients, difficultyLabel, getCoverUrl } from '../lib/strapi';

const allRecipes = await getAllRecipes();
const knowledgeItems = await getAllKnowledge();
const secretItems = await getAllSecrets();
const allIngredients = await getAllIngredients();

// 统计数据
const recipeCount = allRecipes.length;
const ingredientCount = allIngredients.length;
const secretCount = secretItems.length;
const knowledgeCount = knowledgeItems.length;

// 最新6道作为"今日上新"
const newRecipes = allRecipes.slice(0, 6).map(r => ({
  title: r.title,
  slug: r.slug,
  difficulty: difficultyLabel(r.difficulty),
  cookTime: r.cookTime,
  calories: r.calories,
  tags: (r.tags || []).map((t: any) => t.name),
  regions: (r.regions || []).map((rg: any) => rg.name),
  cover: getCoverUrl(r.cover),
}));

// 接下来6道作为"热门食谱"
const featuredRecipes = allRecipes.slice(6, 12).map(r => ({
  title: r.title,
  slug: r.slug,
  difficulty: difficultyLabel(r.difficulty),
  cookTime: r.cookTime,
  calories: r.calories,
  tags: (r.tags || []).map((t: any) => t.name),
  regions: (r.regions || []).map((rg: any) => rg.name),
  cover: getCoverUrl(r.cover),
}));

// 热门食材（取前8个）
const popularIngredients = allIngredients.slice(0, 8).map((i: any) => ({
  name: i.name,
  slug: i.slug,
  image: i.imageUrl || '',
  category: i.category || '',
}));

// 最新6条秘方
const secretsFeatured = secretItems
  .slice(0, 6)
  .map((k: any) => ({
    title: k.title,
    slug: k.slug,
    excerpt: k.content ? k.content.replace(/<[^>]*>/g, '').slice(0, 60) + '...' : '',
  }));

// 知识库精选（非秘方，最新2篇）
const knowledgeFeatured = knowledgeItems
  .slice(0, 2)
  .map((k: any) => ({
    title: k.title,
    slug: k.slug,
    category: k.category,
    excerpt: k.content ? k.content.replace(/<[^>]*>/g, '').slice(0, 80) + '...' : '',
    published_at: k.published_at,
  }));
---

<BaseLayout 
  title="首页"
  description="馋猫有谱 - 专业美食食谱网站，提供详细的食谱步骤、食材百科、烹饪秘方和美食知识库。从零基础也能做出好味道，让你馋得明白，做得靠谱。"
  keywords="食谱,菜谱,家常菜,美食,烹饪技巧,食材百科,秘方,美食知识库,馋猫有谱"
>

  <!-- Hero区 -->
  <section class="hero">
    <div class="hero-bg-decor"></div>
    <div class="container hero-inner">
      <div class="hero-text">
        <div class="hero-badge">🍳 每天一道靠谱食谱</div>
        <h1 class="hero-title">
          <span class="char-highlight">馋</span>得明白<br/>
          做得靠<span class="char-highlight">谱</span>
        </h1>
        <p class="hero-desc">{recipeCount}道精选食谱 · {ingredientCount}种食材百科 · {secretCount}条独家秘方<br/>从零开始，手把手教你做出好味道</p>
        <form action="/search" method="get" class="hero-search">
          <svg class="hero-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" name="q" placeholder="搜索菜名、食材、菜系..." class="hero-search-input" />
          <button type="submit" class="btn btn-primary">搜索</button>
        </form>
        <div class="hero-hot">
          <span class="hero-hot-label">热门搜：</span>
          <a href="/recipes?cuisine=川菜">川菜</a>
          <a href="/recipes?cuisine=粤菜">粤菜</a>
          <a href="/ingredients">食材</a>
          <a href="/secrets">秘方</a>
          <a href="/recipes?difficulty=easy">新手菜</a>
        </div>
      </div>
      <div class="hero-illustration">
        <div class="hero-food-showcase">
          <img src="/images/logo.png?v=3" alt="馋猫有谱" class="hero-cat" />
        </div>
      </div>
    </div>
  </section>

  <!-- 数据亮点 -->
  <section class="stats-bar">
    <div class="container stats-inner">
      <div class="stat-item">
        <div class="stat-num">{recipeCount}+</div>
        <div class="stat-label">精选食谱</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-num">{ingredientCount}</div>
        <div class="stat-label">食材词条</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-num">{secretCount}</div>
        <div class="stat-label">独家秘方</div>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <div class="stat-num">{knowledgeCount}</div>
        <div class="stat-label">美食知识</div>
      </div>
    </div>
  </section>

  <!-- 分类入口 -->
  <CategoryGrid />

  <!-- 今日上新 -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">✨ 今日上新</h2>
          <p class="section-subtitle">每天更新，新鲜热乎的菜谱</p>
        </div>
        <a href="/recipes" class="view-all">查看全部 →</a>
      </div>
      <div class="grid-3">
        {newRecipes.map((recipe) => (
          <RecipeCard {...recipe} />
        ))}
      </div>
    </div>
  </section>

  <!-- 热门食谱 -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">🔥 人气食谱</h2>
          <p class="section-subtitle">大家都在做的家常菜</p>
        </div>
        <a href="/recipes" class="view-all">更多食谱 →</a>
      </div>
      <div class="grid-3">
        {featuredRecipes.map((recipe) => (
          <RecipeCard {...recipe} />
        ))}
      </div>
    </div>
  </section>

  <!-- 食材百科 -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">🥬 食材百科</h2>
          <p class="section-subtitle">认识食材，才能做好菜</p>
        </div>
        <a href="/ingredients" class="view-all">全部食材 →</a>
      </div>
      <div class="ingredients-grid">
        {popularIngredients.map((ing) => (
          <a href={`/ingredients/${ing.slug}`} class="ingredient-card">
            <div class="ingredient-img-wrap">
              {ing.image ? (
                <img src={ing.image} alt={ing.name} class="ingredient-img" />
              ) : (
                <div class="ingredient-placeholder">{ing.name.charAt(0)}</div>
              )}
            </div>
            <div class="ingredient-name">{ing.name}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 秘方精选 -->
  {secretsFeatured.length > 0 && (
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">🗝️ 秘方精选</h2>
          <p class="section-subtitle">独家调味秘诀，做饭好吃的关键</p>
        </div>
        <a href="/secrets" class="view-all">全部秘方 →</a>
      </div>
      <div class="secrets-featured-grid secrets-grid-3">
        {secretsFeatured.map((item) => (
          <a href={`/secrets/${item.slug}`} class="secret-featured-card">
            <h3>{item.title}</h3>
            <p>{item.excerpt}</p>
            <span class="secret-link">查看秘方 →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
  )}

  <!-- 知识库精选 -->
  {knowledgeFeatured.length > 0 && (
  <section class="section">
    <div class="container">
      <div class="section-header">
        <div class="section-title-wrap">
          <h2 class="section-title">📚 知识库精选</h2>
          <p class="section-subtitle">系统学习美食知识</p>
        </div>
        <a href="/knowledge" class="view-all">进入知识库 →</a>
      </div>
      <div class="grid-2">
        {knowledgeFeatured.map((item) => (
          <KnowledgeCard {...item} />
        ))}
      </div>
    </div>
  </section>
  )}

  <!-- 公众号CTA -->
  <section class="cta-section">
    <div class="container cta-inner">
      <div class="cta-text">
        <h2 class="cta-title">关注「馋猫有谱」公众号</h2>
        <p class="cta-desc">每天收到一道精选食谱，还有独家美食干货不定期更新</p>
        <div class="cta-features">
          <span class="cta-feature">📨 每日食谱推送</span>
          <span class="cta-feature">🎯 专属内容</span>
          <span class="cta-feature">💬 互动答疑</span>
        </div>
      </div>
      <div class="cta-qr">
        <div class="qr-placeholder">
          <span>微信搜索</span>
          <strong>馋猫有谱</strong>
          <span>关注我们</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 80px 0 72px;
    background: linear-gradient(135deg, #FFF9F5 0%, #FFFFFF 50%, #F8FAFF 100%);
    position: relative;
    overflow: hidden;
  }
  .hero-bg-decor {
    position: absolute;
    top: -30%;
    right: -5%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 140, 66, 0.08) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .hero-bg-decor::before {
    content: '';
    position: absolute;
    bottom: -200px;
    left: -300px;
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(102, 126, 234, 0.06) 0%, transparent 70%);
    border-radius: 50%;
  }
  .hero-inner { display: flex; align-items: center; gap: 60px; position: relative; }
  .hero-text { flex: 1; max-width: 540px; }
  .hero-badge { 
    display: inline-block; 
    padding: 6px 16px; 
    background: #fff; 
    color: var(--color-accent); 
    border-radius: 100px; 
    font-size: 0.82rem; 
    font-weight: 600; 
    margin-bottom: 24px; 
    box-shadow: 0 2px 12px rgba(255, 140, 66, 0.12);
  }
  .hero-title { 
    font-size: 3.4rem; 
    font-weight: 800; 
    color: var(--color-title); 
    line-height: 1.15; 
    margin-bottom: 16px; 
    letter-spacing: -0.02em; 
  }
  .char-highlight { color: var(--color-accent); }
  .hero-desc { 
    font-size: 1.05rem; 
    color: var(--color-muted); 
    margin-bottom: 32px; 
    line-height: 1.8;
  }
  .hero-search { 
    display: flex; 
    gap: 10px; 
    background: #fff; 
    border: 2px solid var(--color-border); 
    border-radius: 100px; 
    padding: 6px 6px 6px 20px; 
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06); 
    transition: all 0.25s; 
  }
  .hero-search:focus-within { 
    border-color: var(--color-accent); 
    box-shadow: 0 4px 24px rgba(255, 140, 66, 0.15); 
  }
  .hero-search-icon { color: var(--color-muted); flex-shrink: 0; margin-top: 10px; }
  .hero-search-input { flex: 1; border: none; background: transparent; outline: none; font-size: 0.95rem; color: var(--color-text); }
  .hero-search-input::placeholder { color: var(--color-muted); }
  .hero-search .btn { flex-shrink: 0; padding: 10px 24px; border-radius: 100px; }
  .hero-hot { display: flex; align-items: center; gap: 16px; margin-top: 20px; font-size: 0.82rem; flex-wrap: wrap; }
  .hero-hot-label { color: var(--color-muted); }
  .hero-hot a { color: var(--color-text); transition: color 0.2s; text-decoration: none; }
  .hero-hot a:hover { color: var(--color-accent); }
  .hero-illustration { flex-shrink: 0; flex: 1; display: flex; align-items: center; justify-content: center; }
  .hero-food-showcase {
    position: relative;
    width: 280px;
    height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-cat { 
    object-fit: contain; 
    width: 220px; 
    height: 220px; 
    filter: drop-shadow(0 8px 30px rgba(255, 140, 66, 0.2));
    z-index: 1;
  }

  /* Stats bar */
  .stats-bar {
    background: #fff;
    border-bottom: 1px solid var(--color-border-light);
    padding: 24px 0;
  }
  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: space-around;
  }
  .stat-item {
    text-align: center;
  }
  .stat-num {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-title);
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-label {
    font-size: 0.82rem;
    color: var(--color-muted);
  }
  .stat-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border-light);
  }

  /* Section */
  .section {
    padding: 64px 0;
  }
  .section-header { 
    display: flex; 
    align-items: flex-end; 
    justify-content: space-between; 
    margin-bottom: 32px; 
  }
  .section-title-wrap {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .section-title { 
    margin-bottom: 0; 
    font-size: 1.5rem;
  }
  .section-subtitle {
    font-size: 0.88rem;
    color: var(--color-muted);
    margin: 0;
  }
  .view-all { 
    font-size: 0.88rem; 
    font-weight: 500; 
    color: var(--color-accent); 
    transition: opacity 0.2s; 
    text-decoration: none;
  }
  .view-all:hover { opacity: 0.7; }
  .section-alt { background: #F8F9FA; }

  /* Ingredients grid */
  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 16px;
  }
  .ingredient-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 20px 12px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    transition: all 0.25s;
  }
  .ingredient-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(255, 107, 53, 0.12);
  }
  .ingredient-img-wrap {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-bg-warm);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ingredient-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ingredient-placeholder {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .ingredient-name {
    font-size: 0.85rem;
    color: var(--color-title);
    font-weight: 500;
    text-align: center;
  }

  /* 秘方精选 */
  .secrets-featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .secrets-grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .secret-featured-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all 0.25s;
    text-decoration: none;
  }
  .secret-featured-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(255, 107, 53, 0.1);
  }
  .secret-featured-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-title);
    margin-bottom: 10px;
  }
  .secret-featured-card p {
    font-size: 0.88rem;
    color: var(--color-muted);
    line-height: 1.6;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .secret-link {
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  /* CTA Section */
  .cta-section {
    padding: 80px 0;
    background: linear-gradient(135deg, #FF8C42 0%, #FF6B35 100%);
    position: relative;
    overflow: hidden;
  }
  .cta-section::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
    border-radius: 50%;
  }
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
    position: relative;
  }
  .cta-text {
    flex: 1;
    color: #fff;
  }
  .cta-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: #fff;
  }
  .cta-desc {
    font-size: 1rem;
    opacity: 0.9;
    margin-bottom: 24px;
    line-height: 1.7;
  }
  .cta-features {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .cta-feature {
    font-size: 0.9rem;
    opacity: 0.95;
  }
  .cta-qr {
    flex-shrink: 0;
  }
  .qr-placeholder {
    width: 160px;
    height: 160px;
    background: #fff;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }
  .qr-placeholder span {
    font-size: 0.78rem;
    color: var(--color-muted);
  }
  .qr-placeholder strong {
    font-size: 1.1rem;
    color: var(--color-accent);
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .ingredients-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .secrets-grid-3 {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .hero { padding: 48px 0 40px; }
    .hero-inner { flex-direction: column-reverse; gap: 24px; text-align: center; }
    .hero-title { font-size: 2.4rem; }
    .hero-desc { font-size: 0.95rem; }
    .hero-search { max-width: 100%; }
    .hero-illustration { width: auto; }
    .hero-food-showcase { width: 180px; height: 180px; }
    .hero-cat { width: 140px; height: 140px; }
    .hero-hot { justify-content: center; }
    
    .stats-inner { flex-wrap: wrap; gap: 16px; }
    .stat-divider { display: none; }
    .stat-item { flex: 1; min-width: 80px; }
    
    .section { padding: 48px 0; }
    .section-title { font-size: 1.25rem; }
    
    .cta-inner { flex-direction: column; text-align: center; gap: 32px; }
    .cta-features { justify-content: center; }
    
    .secrets-featured-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .hero-title { font-size: 2rem; }
    .ingredients-grid { grid-template-columns: repeat(3, 1fr); }
    .cta-title { font-size: 1.5rem; }
  }
</style>
