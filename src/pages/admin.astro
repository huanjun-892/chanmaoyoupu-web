    let editingPlatformId = null;
    
    // 获取平台账号列表
    function getPlatformAccounts() {
      const data = localStorage.getItem('admin_platform_accounts');
      return data ? JSON.parse(data) : [];
    }
    
    // 保存平台账号列表
    function savePlatformAccounts(accounts) {
      localStorage.setItem('admin_platform_accounts', JSON.stringify(accounts));
    }
    
    // 加载平台列表
    function loadPlatformList() {
      const accounts = getPlatformAccounts();
      const listContainer = document.getElementById('platform-list');
      const emptyContainer = document.getElementById('platform-empty');
      
      if (accounts.length === 0) {
        listContainer.innerHTML = '';
        emptyContainer.style.display = 'block';
        return;
      }
      
      emptyContainer.style.display = 'none';
      
      let html = '';
      accounts.forEach(account => {
        const config = platformConfig[account.platform_type];
        if (!config) return;
        
        html += `
          <div class="platform-card">
            <div class="platform-card-header">
              <div class="platform-icon" style="background: ${config.color}20;">${config.icon}</div>
              <div class="platform-info">
                <h4>${config.name}</h4>
                <p>${account.account_name || '未设置账号'}</p>
              </div>
            </div>
            <div class="platform-status ${account.status === 'active' ? 'active' : 'inactive'}">
              <span class="dot"></span>
              ${account.status === 'active' ? '已绑定' : '未激活'}
            </div>
            <div class="platform-actions">
              <button class="btn btn-secondary btn-sm" onclick="editPlatformAccount('${account.id}')">✏️ 编辑</button>
              <button class="btn btn-secondary btn-sm" onclick="deletePlatformAccount('${account.id}')">🗑️ 删除</button>
              <button class="btn btn-primary btn-sm" onclick="goToPublish('${account.platform_type}')">📤 去发布</button>
            </div>
          </div>
        `;
      });
      
      // 添加未绑定的平台提示卡片
      const boundTypes = accounts.map(a => a.platform_type);
      const unboundTypes = Object.keys(platformConfig).filter(t => !boundTypes.includes(t));
      
      if (unboundTypes.length > 0) {
        unboundTypes.forEach(type => {
          const config = platformConfig[type];
          html += `
            <div class="platform-card" style="border-style: dashed; opacity: 0.7;">
              <div class="platform-card-header">
                <div class="platform-icon" style="background: ${config.color}20;">${config.icon}</div>
                <div class="platform-info">
                  <h4>${config.name}</h4>
                  <p>未绑定</p>
                </div>
              </div>
              <div class="platform-status inactive">
                <span class="dot"></span>
                待绑定
              </div>
              <div class="platform-actions">
                <button class="btn btn-primary btn-sm" onclick="openPlatformModal('${type}')" style="flex: 1;">
                  ➕ 立即绑定
                </button>
              </div>
            </div>
          `;
        });
      }
      
      listContainer.innerHTML = html;
    }
    
    // 打开平台账号编辑弹窗
    function openPlatformModal(platformType) {
      // 如果没有传平台类型，先显示平台选择
      if (!platformType) {
        showPlatformSelector();
        return;
      }
      editingPlatformId = null;
      showPlatformModal(platformType, null);
    }
    
    // 显示平台选择弹窗
    function showPlatformSelector() {
      let html = '<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;">';
      
      Object.keys(platformConfig).forEach(type => {
        const config = platformConfig[type];
        html += `
          <div onclick="selectPlatformType('${type}')" style="padding: 20px; border: 1px solid var(--color-border); border-radius: 8px; cursor: pointer; text-align: center; transition: all 0.2s;" onmouseover="this.style.borderColor='var(--color-accent)'" onmouseout="this.style.borderColor='var(--color-border)'">
            <div style="font-size: 2rem; margin-bottom: 8px;">${config.icon}</div>
            <div style="font-weight: 500; color: var(--color-title);">${config.name}</div>
          </div>
        `;
      });
      
      html += '</div>';
      
      document.getElementById('modal-title').textContent = '选择平台';
      document.getElementById('modal-body').innerHTML = html;
      
      const footer = document.getElementById('modal-footer');
      footer.innerHTML = `
        <button class="btn btn-secondary" onclick="closeModal()">取消</button>
      `;
      
      document.getElementById('edit-modal').classList.add('show');
      resetModalPosition();
    }
    
    // 选择平台类型后跳转到表单
    function selectPlatformType(type) {
      showPlatformModal(type, null);
    }
    
    // 编辑平台账号
    function editPlatformAccount(id) {
      const accounts = getPlatformAccounts();
      const account = accounts.find(a => a.id === id);
      if (!account) return;
      
      editingPlatformId = id;
      showPlatformModal(account.platform_type, account);
    }
    
    // 显示平台表单弹窗
    function showPlatformModal(platformType, account) {
      const config = platformConfig[platformType];
      if (!config) return;
      
      let formHtml = `
        <div class="platform-form-group">
          <label>平台类型</label>
          <select id="pf-platform-type" disabled>
            <option value="${platformType}">${config.icon} ${config.name}</option>
          </select>
        </div>
      `;
      
      config.fields.forEach(field => {
        const value = account ? (account[field.key] || '') : '';
        if (field.type === 'textarea') {
          formHtml += `
            <div class="platform-form-group">
              <label>${field.label}</label>
              <textarea id="pf-${field.key}" placeholder="${field.placeholder || ''}">${value}</textarea>
            </div>
          `;
        } else {
          formHtml += `
            <div class="platform-form-group">
              <label>${field.label}</label>
              <input type="${field.type}" id="pf-${field.key}" value="${value}" placeholder="${field.placeholder || ''}">
            </div>
          `;
        }
      });
      
      formHtml += `
        <div class="platform-form-group">
          <label>账号状态</label>
          <select id="pf-status">
            <option value="active" ${account?.status === 'active' ? 'selected' : ''}>已激活</option>
            <option value="inactive" ${account?.status === 'inactive' ? 'selected' : ''}>未激活</option>
          </select>
        </div>
      `;
      
      // 使用通用弹窗显示表单
      document.getElementById('modal-title').textContent = account ? '编辑平台账号' : '添加平台账号';
      document.getElementById('modal-body').innerHTML = formHtml;
      
      // 自定义footer按钮
      const footer = document.getElementById('modal-footer');
      footer.innerHTML = `
        <button class="btn btn-secondary" onclick="closeModal()">取消</button>
        <button class="btn btn-primary" onclick="savePlatformAccount()">保存</button>
      `;
      
      document.getElementById('edit-modal').classList.add('show');
      resetModalPosition();
    }
    
    // 保存平台账号
    function savePlatformAccount() {
      const platformType = document.getElementById('pf-platform-type').value;
      const config = platformConfig[platformType];
      if (!config) return;
      
      const accounts = getPlatformAccounts();
      const accountData = {
        platform_type: platformType,
        status: document.getElementById('pf-status').value,
        updated_at: new Date().toISOString()
      };
      
      // 收集各字段值
      config.fields.forEach(field => {
        const el = document.getElementById('pf-' + field.key);
        if (el) {
          accountData[field.key] = el.value;
        }
      });
      
      if (editingPlatformId) {
        // 编辑模式
        const index = accounts.findIndex(a => a.id === editingPlatformId);
        if (index > -1) {
          accountData.id = editingPlatformId;
          accountData.created_at = accounts[index].created_at;
          accounts[index] = accountData;
        }
      } else {
        // 新增模式
        accountData.id = 'pf_' + Date.now();
        accountData.created_at = new Date().toISOString();
        accounts.push(accountData);
      }
      
      savePlatformAccounts(accounts);
      closeModal();
      loadPlatformList();
      showToast('保存成功', 'success');
    }
    
    // 删除平台账号
    function deletePlatformAccount(id) {
      if (!confirm('确定要删除这个平台账号吗？')) return;
      
      const accounts = getPlatformAccounts();
      const filtered = accounts.filter(a => a.id !== id);
      savePlatformAccounts(filtered);
      loadPlatformList();
      showToast('删除成功', 'success');
    }
    
    // 跳转到发布页面
    function goToPublish(platformType) {
      const config = platformConfig[platformType];
      if (config && config.publishUrl) {
        window.open(config.publishUrl, '_blank');
      }
    }
    
