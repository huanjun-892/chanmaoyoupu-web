---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getAllRecipes, getAllCuisines, getAllTags, getAllRegions, getAllMethods, difficultyLabel, getCoverUrl } from '../../lib/strapi';

const recipes = await getAllRecipes();
const cuisines = await getAllCuisines();
const tags = await getAllTags();
const regions = await getAllRegions();
const methods = await getAllMethods();

const recipeList = recipes.map((r: any) => ({
  title: r.title,
  slug: r.slug,
  difficulty: difficultyLabel(r.difficulty),
  cookTime: r.cookTime,
  calories: r.calories,
  tags: (r.tags || []).map((t: any) => t.name),
  regions: (r.regions || []).map((rg: any) => rg.name),
  cuisine: r.cuisine?.name || '',
  methods: (r.methods || []).map((m: any) => m.name),
  cover: getCoverUrl(r.cover),
  likeCount: r.like_count || 0,
  id: r.id,
}));

const cuisineList = ['全部', ...cuisines.map((c: any) => c.name)];

// 地域排序：国内在前，国外在后
const domesticRegions = ['北京', '上海', '四川', '广东', '山东', '浙江', '湖南', '江苏', '安徽', '福建', '东北', '云南', '贵州', '西北', '湖北', '广西'];
const internationalRegions = ['日本', '韩国', '法国', '意大利', '东南亚', '印度'];
const allRegionNames = regions.map((r: any) => r.name);
const sortedRegionNames = [
  ...domesticRegions.filter(n => allRegionNames.includes(n)),
  ...internationalRegions.filter(n => allRegionNames.includes(n)),
  ...allRegionNames.filter(n => !domesticRegions.includes(n) && !internationalRegions.includes(n))
];
const regionList = ['全部', ...sortedRegionNames];

const sceneList = ['全部', ...tags.map((t: any) => t.name)];
const difficultyList = ['全部', '入门', '简单', '中级', '高级'];
const methodList = ['全部', ...methods.map((m: any) => m.name)];
---

<BaseLayout 
  title="全部食谱 - 馋猫有谱"
  description="馋猫有谱食谱大全，汇聚八大菜系、家常菜、快手菜、宴客菜等各类精选食谱，每道菜都有详细步骤、食材用量和烹饪技巧，新手也能轻松上手。"
  keywords="食谱大全,菜谱,家常菜,快手菜,川菜,粤菜,家常菜做法,烹饪食谱"
>

  <section class="section">
    <div class="container">
      <!-- 页面标题 -->
      <div class="page-header">
        <div>
          <h1 class="page-title">全部食谱</h1>
          <p class="page-desc">共 {recipes.length} 道精选食谱，从入门到进阶</p>
        </div>
        <div class="sort-wrapper">
          <span class="sort-label">排序：</span>
          <select id="sort-select" class="sort-select">
            <option value="newest">最新发布</option>
            <option value="popular">最受欢迎</option>
            <option value="time">烹饪时间</option>
            <option value="difficulty">难度从低到高</option>
          </select>
        </div>
      </div>

      <!-- 筛选器 -->
      <div class="filters" id="filters">
        <div class="filter-row">
          <span class="filter-label">菜系</span>
          <div class="filter-options" data-filter-type="cuisine">
            {cuisineList.map((c: string) => (
              <button class="filter-btn" data-filter="cuisine" data-value={c === '全部' ? '' : c}>{c}</button>
            ))}
          </div>
        </div>

        <div class="filter-row">
          <span class="filter-label">场景</span>
          <div class="filter-options" data-filter-type="tag">
            {sceneList.map((s: string) => (
              <button class="filter-btn" data-filter="tag" data-value={s === '全部' ? '' : s}>{s}</button>
            ))}
          </div>
        </div>

        <div class="filter-row">
          <span class="filter-label">难度</span>
          <div class="filter-options" data-filter-type="difficulty">
            {difficultyList.map((d: string) => (
              <button class="filter-btn" data-filter="difficulty" data-value={d === '全部' ? '' : d}>{d}</button>
            ))}
          </div>
        </div>

        <div class="filter-row">
          <span class="filter-label">做法</span>
          <div class="filter-options" data-filter-type="method">
            {methodList.map((m: string) => (
              <button class="filter-btn" data-filter="method" data-value={m === '全部' ? '' : m}>{m}</button>
            ))}
          </div>
        </div>

        <div class="filter-row">
          <span class="filter-label">地域</span>
          <div class="filter-options" data-filter-type="region">
            {regionList.slice(0, 12).map((r: string) => (
              <button class="filter-btn" data-filter="region" data-value={r === '全部' ? '' : r}>{r}</button>
            ))}
            {regionList.length > 12 && (
              <button class="filter-btn filter-more" onclick="toggleMoreRegions()">更多 ▾</button>
            )}
          </div>
        </div>
        <div class="filter-options hidden" id="more-regions">
          {regionList.slice(12).map((r: string) => (
            <button class="filter-btn" data-filter="region" data-value={r}>{r}</button>
          ))}
        </div>
      </div>

      <!-- 已选筛选标签 -->
      <div class="active-filters" id="active-filters" style="display: none;">
        <span class="active-filters-label">已选：</span>
        <div id="active-filter-tags"></div>
        <button class="clear-filters-btn" onclick="clearAllFilters()">清空全部</button>
      </div>

      <!-- 食谱列表 -->
      <div class="recipe-grid" id="recipe-grid">
        {recipeList.map((recipe: any, index: number) => (
          <div class="recipe-item"
            data-cuisine={recipe.cuisine}
            data-region={recipe.regions.join(',')}
            data-tag={recipe.tags.join(',')}
            data-difficulty={recipe.difficulty}
            data-method={recipe.methods.join(',')}
            data-time={recipe.cookTime}
            data-likes={recipe.likeCount}
            data-id={recipe.id}
            data-index={index}>
            <RecipeCard {...recipe} />
          </div>
        ))}
      </div>

      <!-- 空状态 -->
      <div class="empty-state" id="empty-state" style="display: none;">
        <div class="empty-icon">🍳</div>
        <h3 class="empty-title">没找到符合条件的食谱</h3>
        <p class="empty-desc">试试调整筛选条件，或者看看其他好吃的？</p>
        <button class="btn btn-primary" onclick="clearAllFilters()">清空筛选条件</button>
      </div>

      <!-- 结果统计 -->
      <div class="result-count" id="result-count">
        共 <span id="count-num">{recipes.length}</span> 道食谱
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // 难度排序映射
  const difficultyOrder: Record<string, number> = {
    '入门': 1, '简单': 2, '中级': 3, '高级': 4
  };

  // 当前激活的筛选条件
  const activeFilters: Record<string, string> = {};
  let currentSort = 'newest';

  // 初始化：默认选中"全部"
  document.querySelectorAll('.filter-group, .filter-row').forEach(group => {
    const firstBtn = group.querySelector('.filter-btn');
    if (firstBtn) firstBtn.classList.add('active');
  });

  // URL参数筛选
  const params = new URLSearchParams(window.location.search);
  const paramMap: Record<string, string> = {
    'cuisine': 'cuisine',
    'tag': 'tag',
    'method': 'method',
    'difficulty': 'difficulty',
    'scene': 'tag'
  };

  // 从URL读取筛选条件
  Object.entries(paramMap).forEach(([param, filterType]) => {
    if (params.has(param)) {
      const val = params.get(param);
      if (val) {
        // 处理难度参数映射
        let displayVal = val;
        if (filterType === 'difficulty') {
          const labelMap: Record<string, string> = { easy: '入门', simple: '简单', medium: '中级', hard: '高级' };
          displayVal = labelMap[val] || val;
        }
        const btn = document.querySelector(`.filter-btn[data-filter="${filterType}"][data-value="${displayVal}"]`);
        if (btn) {
          // 取消同组的全部选中
          const group = btn.closest('.filter-options') || btn.closest('.filter-row');
          group?.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          activeFilters[filterType] = displayVal;
        }
      }
    }
  });

  // 筛选按钮点击
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filterType = btn.getAttribute('data-filter');
      const value = btn.getAttribute('data-value') || '';

      if (!filterType) return;

      // 切换按钮高亮
      const group = btn.closest('.filter-options') || btn.closest('.filter-row');
      group?.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // 更新筛选条件
      if (value) {
        activeFilters[filterType] = value;
      } else {
        delete activeFilters[filterType];
      }

      applyFiltersAndSort();
      updateActiveFiltersDisplay();
    });
  });

  // 排序选择
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  if (sortSelect) {
    sortSelect.addEventListener('change', () => {
      currentSort = sortSelect.value;
      applyFiltersAndSort();
    });
  }

  // 应用筛选和排序
  function applyFiltersAndSort() {
    const items = Array.from(document.querySelectorAll<HTMLElement>('.recipe-item'));
    let visibleCount = 0;

    items.forEach(item => {
      let show = true;

      if (activeFilters.cuisine && item.dataset.cuisine !== activeFilters.cuisine) show = false;
      if (activeFilters.region && !item.dataset.region?.split(',').includes(activeFilters.region)) show = false;
      if (activeFilters.tag && !item.dataset.tag?.split(',').includes(activeFilters.tag)) show = false;
      if (activeFilters.difficulty && item.dataset.difficulty !== activeFilters.difficulty) show = false;
      if (activeFilters.method && item.dataset.method && !item.dataset.method.split(',').includes(activeFilters.method)) show = false;

      item.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    // 排序
    const visibleItems = items.filter(i => i.style.display !== 'none');
    const grid = document.getElementById('recipe-grid');

    if (grid) {
      switch (currentSort) {
        case 'newest':
          visibleItems.sort((a, b) => (parseInt(b.dataset.id || '0') - parseInt(a.dataset.id || '0')));
          break;
        case 'popular':
          visibleItems.sort((a, b) => (parseInt(b.dataset.likes || '0') - parseInt(a.dataset.likes || '0')));
          break;
        case 'time':
          visibleItems.sort((a, b) => (parseInt(a.dataset.time || '0') - parseInt(b.dataset.time || '0')));
          break;
        case 'difficulty':
          visibleItems.sort((a, b) => {
            const aDiff = difficultyOrder[a.dataset.difficulty || ''] || 99;
            const bDiff = difficultyOrder[b.dataset.difficulty || ''] || 99;
            return aDiff - bDiff;
          });
          break;
      }

      // 重新排列DOM
      visibleItems.forEach(item => grid.appendChild(item));
    }

    // 更新计数
    const countEl = document.getElementById('count-num');
    if (countEl) countEl.textContent = visibleCount.toString();

    // 空状态
    const emptyEl = document.getElementById('empty-state');
    if (emptyEl) {
      emptyEl.style.display = visibleCount === 0 ? 'flex' : 'none';
    }
  }

  // 更新已选筛选标签显示
  function updateActiveFiltersDisplay() {
    const container = document.getElementById('active-filters');
    const tagsContainer = document.getElementById('active-filter-tags');
    
    if (!container || !tagsContainer) return;

    const filterCount = Object.keys(activeFilters).length;
    
    if (filterCount === 0) {
      container.style.display = 'none';
      return;
    }

    container.style.display = 'flex';
    tagsContainer.innerHTML = '';

    const labelMap: Record<string, string> = {
      cuisine: '菜系',
      region: '地域',
      tag: '场景',
      difficulty: '难度',
      method: '做法'
    };

    Object.entries(activeFilters).forEach(([type, value]) => {
      const tag = document.createElement('span');
      tag.className = 'active-filter-tag';
      tag.innerHTML = `${labelMap[type] || type}: ${value} <span class="remove-filter">×</span>`;
      tag.onclick = () => {
        // 找到对应的"全部"按钮并点击
        const allBtn = document.querySelector(`.filter-btn[data-filter="${type}"][data-value=""]`);
        if (allBtn) (allBtn as HTMLElement).click();
      };
      tagsContainer.appendChild(tag);
    });
  }

  // 清空所有筛选
  function clearAllFilters() {
    document.querySelectorAll('.filter-btn[data-value=""]').forEach(btn => {
      btn.click();
    });
  }

  // 展开更多地区
  function toggleMoreRegions() {
    const moreEl = document.getElementById('more-regions');
    const btn = document.querySelector('.filter-more');
    if (moreEl && btn) {
      moreEl.classList.toggle('hidden');
      btn.textContent = moreEl.classList.contains('hidden') ? '更多 ▾' : '收起 ▴';
    }
  }

  // 初始化
  updateActiveFiltersDisplay();
  applyFiltersAndSort();
</script>

<style>
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 16px;
  }

  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-title);
    margin-bottom: 6px;
  }

  .page-desc {
    font-size: 0.95rem;
    color: var(--color-muted);
    margin: 0;
  }

  .sort-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sort-label {
    font-size: 0.88rem;
    color: var(--color-muted);
  }

  .sort-select {
    padding: 8px 14px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: #fff;
    font-size: 0.88rem;
    color: var(--color-text);
    cursor: pointer;
    outline: none;
    transition: border-color 0.2s;
  }

  .sort-select:focus {
    border-color: var(--color-accent);
  }

  /* 筛选器 */
  .filters {
    margin-bottom: 24px;
    padding: 24px;
    background: #fff;
    border-radius: 12px;
    border: 1px solid var(--color-border-light);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
  }

  .filter-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px dashed var(--color-border-light);
  }

  .filter-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .filter-label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-title);
    flex-shrink: 0;
    width: 50px;
    line-height: 30px;
  }

  .filter-options {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    flex: 1;
  }

  .filter-btn {
    padding: 5px 14px;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    background: #fff;
    color: var(--color-text);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .filter-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-btn.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .filter-more {
    color: var(--color-muted);
    font-size: 0.82rem;
  }

  .hidden {
    display: none;
  }

  #more-regions {
    padding: 8px 0 0 62px;
  }

  /* 已选筛选标签 */
  .active-filters {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: var(--color-accent-light);
    border-radius: 8px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .active-filters-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    flex-shrink: 0;
  }

  #active-filter-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    flex: 1;
  }

  .active-filter-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    background: #fff;
    border: 1px solid var(--color-accent);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--color-accent);
    cursor: pointer;
    transition: all 0.2s;
  }

  .active-filter-tag:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .remove-filter {
    font-size: 1rem;
    line-height: 1;
    font-weight: bold;
  }

  .clear-filters-btn {
    padding: 4px 12px;
    background: transparent;
    border: none;
    color: var(--color-muted);
    font-size: 0.82rem;
    cursor: pointer;
    flex-shrink: 0;
  }

  .clear-filters-btn:hover {
    color: var(--color-accent);
  }

  /* 食谱网格 */
  .recipe-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* 空状态 */
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 20px;
    text-align: center;
  }

  .empty-icon {
    font-size: 4rem;
    margin-bottom: 16px;
  }

  .empty-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--color-title);
    margin-bottom: 8px;
  }

  .empty-desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    margin-bottom: 20px;
  }

  /* 结果统计 */
  .result-count {
    text-align: center;
    margin-top: 32px;
    font-size: 0.88rem;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .recipe-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 1.5rem;
    }
    
    .filters {
      padding: 16px;
    }
    
    .filter-row {
      flex-direction: column;
      gap: 8px;
    }
    
    .filter-label {
      width: auto;
      line-height: 1.4;
    }
    
    #more-regions {
      padding-left: 0;
    }
    
    .recipe-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
  }

  @media (max-width: 480px) {
    .recipe-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
