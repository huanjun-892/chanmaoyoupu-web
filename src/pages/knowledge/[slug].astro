---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllKnowledge, processContent } from '../../lib/strapi';

export async function getStaticPaths() {
  const knowledgeItems = await getAllKnowledge();
  if (knowledgeItems.length === 0) {
    return [];
  }
  // 只生成非秘方条目的路径（秘方走 /secrets/ 路径）
  const nonSecretItems = knowledgeItems.filter((k: any) => k.category !== 'secret');
  return nonSecretItems.map((k: any) => ({
    params: { slug: k.slug },
  }));
}

const { slug } = Astro.params;
const knowledgeItems = await getAllKnowledge();
const entry = knowledgeItems.find((k: any) => k.slug === slug);

if (!entry) {
  return Astro.redirect('/knowledge');
}

const categoryMap: Record<string, string> = {
  technique: '技法',
  ingredient: '食材',
  flavor: '味型',
  culture: '文化',
  history: '历史',
  secret: '秘方',
};
---

<BaseLayout title={entry.title}>
  
  <article class="knowledge-detail">
    <div class="container">
      <div class="knowledge-header">
        <span class="tag">{categoryMap[entry.category] || entry.category}</span>
        <h1 class="knowledge-title">{entry.title}</h1>
      </div>

      <div class="knowledge-body" set:html={processContent(entry.content || '')} />

      <div class="related">
        {entry.relatedRecipes && entry.relatedRecipes.length > 0 && (
        <div class="related-section">
          <h3 class="related-title">相关食谱</h3>
          <div class="related-links">
            {entry.relatedRecipes.map((r: any) => (
              <a href={`/recipes/${r.slug}`} class="related-link">{r.title} →</a>
            ))}
          </div>
        </div>
        )}
        {entry.relatedKnowledge && entry.relatedKnowledge.length > 0 && (
        <div class="related-section">
          <h3 class="related-title">相关知识</h3>
          <div class="related-links">
            {entry.relatedKnowledge.map((k: any) => (
              <a href={`/knowledge/${k.slug}`} class="related-link">{k.title} →</a>
            ))}
          </div>
        </div>
        )}
      </div>
    </div>
  </article>

</BaseLayout>

<style>
  .knowledge-detail { padding-top: 40px; }
  .knowledge-header { margin-bottom: 40px; }
  .knowledge-title { font-size: 2rem; font-weight: 700; color: var(--color-title); margin-top: 12px; }
  .knowledge-body { max-width: 720px; font-size: 0.95rem; line-height: 1.9; color: var(--color-text); }
  .knowledge-body :global(h2) { font-size: 1.3rem; font-weight: 600; color: var(--color-title); margin: 36px 0 16px; padding-left: 12px; border-left: 3px solid var(--color-accent); }
  .knowledge-body :global(h3) { font-size: 1.15rem; font-weight: 600; color: var(--color-title); margin: 28px 0 12px; }
  .knowledge-body :global(h4) { font-size: 1rem; font-weight: 600; color: var(--color-title); margin: 20px 0 8px; }
  .knowledge-body :global(p) { margin-bottom: 12px; }
  .knowledge-body :global(strong) { color: var(--color-title); }
  .knowledge-body :global(table) { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 0.9rem; }
  .knowledge-body :global(th) { background: var(--color-bg-warm); padding: 8px 12px; text-align: left; font-weight: 600; }
  .knowledge-body :global(td) { padding: 8px 12px; border-bottom: 1px solid var(--color-border); }
  .knowledge-body :global(ul) { margin-bottom: 16px; padding-left: 24px; }
  .knowledge-body :global(li) { margin-bottom: 6px; }
  .related { margin-top: 60px; padding-top: 32px; border-top: 1px solid var(--color-border); display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .related-title { font-size: 1rem; font-weight: 600; color: var(--color-title); margin-bottom: 12px; }
  .related-links { display: flex; flex-direction: column; gap: 8px; }
  .related-link { font-size: 0.9rem; color: var(--color-accent); transition: opacity 0.2s; }
  .related-link:hover { opacity: 0.7; }
  @media (max-width: 768px) { .related { grid-template-columns: 1fr; } }
</style>