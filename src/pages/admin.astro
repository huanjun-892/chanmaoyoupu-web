    // AI增强内容
    function aiEnhance(type) {
      const textarea = document.getElementById('push-content-result');
      let content = textarea.value;
      if (!content) {
        showToast('请先生成内容', 'error');
        return;
      }
      
      showToast('AI优化中...', 'info');
      
      // 模拟AI处理（后续接入真实AI API）
      setTimeout(() => {
        let result = content;
        
        switch(type) {
          case 'polish': // 润色
            result = content
              .replace(/根据个人口味/g, '可根据自家口味')
              .replace(/适量$/gm, '按需调整')
              .replace(/小贴士：/g, '💡 小小Tips：');
            // 添加一些连接词让文章更流畅
            if (!result.includes('首先')) {
              result = result.replace(/做法步骤：\n1\./, '做法步骤：\n首先，1.');
            }
            break;
            
          case 'expand': // 扩写
            result = content.replace(/小贴士：\n(.*?)\n/, '小贴士：\n$1\n另外，烹饪时注意火候的掌握也很重要哦～\n');
            // 给每步添加一点细节
            result = result.replace(/(\d+)\. (.*?)(\n)/g, (match, num, text, newline) => {
              if (text.length < 20) {
                return match;
              }
              return num + '. ' + text + '（这一步很关键哦）' + newline;
            });
            break;
            
          case 'shorten': // 缩短
            // 简化表述
            result = content
              .replace(/食材清单：/g, '🥬 食材：')
              .replace(/做法步骤：/g, '👨‍🍳 步骤：')
              .replace(/小贴士：/g, '💡 提示：');
            // 去掉一些重复的话
            result = result.replace(/\n\n\n/g, '\n\n');
            break;
            
          case 'casual': // 更口语
            result = content
              .replace(/食材清单：/g, '准备好这些东西哈：')
              .replace(/做法步骤：/g, '接下来咱们开做：')
              .replace(/小贴士：/g, '说句实在话哈：')
              .replace(/适量/g, '看着放就行')
              .replace(/少许/g, '来一丢丢');
            break;
            
          case 'title': // 改标题
            const titlePrefixes = ['🔥超好吃的', '😋巨下饭的', '🥘家常版', '👩‍🍳手把手教你做', '💯零失败的'];
            const randomPrefix = titlePrefixes[Math.floor(Math.random() * titlePrefixes.length)];
            const firstLineEnd = content.indexOf('\n');
            if (firstLineEnd > 0) {
              let oldTitle = content.substring(0, firstLineEnd).replace(/^[^\u4e00-\u9fa5a-zA-Z]+/, '');
              result = randomPrefix + oldTitle + '\n' + content.substring(firstLineEnd + 1);
            }
            break;
        }
        
        textarea.value = result;
        updateCharCount();
        showToast('AI优化完成', 'success');
      }, 800);
    }
    
