---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getAllKnowledge } from '../../lib/strapi';

const knowledgeItems = await getAllKnowledge();

const categoryMap: Record<string, { icon: string; label: string }> = {
  technique: { icon: '🔥', label: '技法' },
  ingredient: { icon: '🥬', label: '食材' },
  flavor: { icon: '👅', label: '味型' },
  culture: { icon: '📜', label: '文化' },
  history: { icon: '📖', label: '历史' },
};

// 统计各分类数量
const categoryCounts: Record<string, number> = {};
knowledgeItems.forEach((k: any) => {
  const cat = k.category || 'other';
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
});

const categories = Object.entries(categoryMap).map(([slug, { icon, label }]) => ({
  name: label,
  slug,
  icon,
  count: categoryCounts[slug] || 0,
  desc: `${label}相关美食知识`,
}));
---

<BaseLayout title="知识库">
  <Header />

  <section class="section">
    <div class="container">
      <h1 class="page-title">美食知识库</h1>
      <p class="page-desc">不仅要会做，还要懂。从技法到食材，从味型到文化，吃个明白。</p>

      {categories.length > 0 && (
      <div class="grid-5 category-cards">
        {categories.map((cat) => (
          <a href={`/knowledge?category=${cat.slug}`} class="category-card">
            <span class="category-icon">{cat.icon}</span>
            <h3 class="category-name">{cat.name}</h3>
            <p class="category-desc">{cat.desc}</p>
            <span class="category-count">{cat.count}篇</span>
          </a>
        ))}
      </div>
      )}

      {knowledgeItems.length > 0 ? (
      <div class="knowledge-list">
        <h2 class="section-subtitle">全部条目</h2>
        {knowledgeItems.map((item: any) => {
          const catInfo = categoryMap[item.category] || { icon: '📚', label: '知识' };
          const excerpt = item.content ? item.content.replace(/<[^>]*>/g, '').slice(0, 80) + '...' : '';
          return (
            <a href={`/knowledge/${item.slug}`} class="knowledge-item">
              <div class="knowledge-item-left">
                <span class="tag">{catInfo.icon} {catInfo.label}</span>
                <h3 class="knowledge-item-title">{item.title}</h3>
                <p class="knowledge-item-excerpt">{excerpt}</p>
              </div>
              <span class="knowledge-item-arrow">→</span>
            </a>
          );
        })}
      </div>
      ) : (
      <div class="coming-soon">
        <span class="coming-soon-icon">📝</span>
        <p class="coming-soon-text">知识库正在筹备中，敬请期待！</p>
        <p class="coming-soon-sub">先去看看<a href="/recipes">食谱</a>吧～</p>
      </div>
      )}
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-title);
    margin-bottom: 8px;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-muted);
    margin-bottom: 40px;
  }

  .grid-5 {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    margin-bottom: 48px;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 24px 16px;
    background: var(--color-bg-warm);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    transition: all 0.2s;
  }

  .category-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .category-icon {
    font-size: 2rem;
    margin-bottom: 10px;
  }

  .category-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-title);
    margin-bottom: 6px;
  }

  .category-desc {
    font-size: 0.75rem;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 10px;
  }

  .category-count {
    font-size: 0.7rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  .section-subtitle {
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-title);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-accent);
    display: inline-block;
  }

  .knowledge-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .knowledge-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all 0.2s;
  }

  .knowledge-item:hover {
    border-color: var(--color-accent);
  }

  .knowledge-item-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-title);
    margin: 6px 0;
  }

  .knowledge-item-excerpt {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .knowledge-item-arrow {
    font-size: 1.2rem;
    color: var(--color-muted);
    transition: color 0.2s;
  }

  .knowledge-item:hover .knowledge-item-arrow {
    color: var(--color-accent);
  }

  .coming-soon {
    text-align: center;
    padding: 80px 20px;
  }

  .coming-soon-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 16px;
  }

  .coming-soon-text {
    font-size: 1.2rem;
    color: var(--color-title);
    font-weight: 600;
    margin-bottom: 8px;
  }

  .coming-soon-sub {
    font-size: 0.95rem;
    color: var(--color-muted);
  }

  .coming-soon-sub a {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .grid-5 {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 480px) {
    .grid-5 {
      grid-template-columns: repeat(2, 1fr);
    }
    .knowledge-item {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
  }
</style>
