---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

// SSG模式下，排行榜数据需要客户端获取
const pageTitle = '排行榜 - 馋猫有谱';
---

<BaseLayout title={pageTitle}>
  <main class="rankings-page">
    <div class="container">
      <h1 class="page-title">🏆 排行榜</h1>
      
      <div class="tabs">
        <button class="tab-btn active" data-tab="likes" onclick="switchRankingTab('likes')">
          <svg viewBox="0 0 24 24" width="18" height="18"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="currentColor"/></svg>
          点赞榜
        </button>
        <button class="tab-btn" data-tab="favorites" onclick="switchRankingTab('favorites')">
          <svg viewBox="0 0 24 24" width="18" height="18"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="currentColor"/></svg>
          收藏榜
        </button>
      </div>

      <!-- 点赞榜 -->
      <div id="likes-ranking" class="ranking-list">
        <div class="loading">
          <div class="spinner"></div>
          <span>加载中...</span>
        </div>
      </div>

      <!-- 收藏榜 -->
      <div id="favorites-ranking" class="ranking-list" style="display: none;">
        <div class="loading">
          <div class="spinner"></div>
          <span>加载中...</span>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
.rankings-page {
  min-height: 100vh;
  padding: 40px 0;
}

.page-title {
  font-size: 2rem;
  font-weight: 700;
  color: var(--color-title);
  text-align: center;
  margin-bottom: 32px;
}

.tabs {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-bottom: 32px;
}

.tab-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  border: none;
  background: var(--color-bg-subtle);
  border-radius: 30px;
  font-size: 1rem;
  font-weight: 500;
  color: var(--color-muted);
  cursor: pointer;
  transition: all 0.25s;
}

.tab-btn.active {
  background: linear-gradient(135deg, #ff6b35, #ff8f65);
  color: #fff;
}

.tab-btn:not(.active):hover {
  background: var(--color-bg);
  color: var(--color-title);
}

.ranking-list {
  max-width: 800px;
  margin: 0 auto;
}

.ranking-item {
  display: flex;
  align-items: center;
  padding: 16px 24px;
  background: var(--color-bg);
  border-radius: 16px;
  margin-bottom: 12px;
  transition: all 0.25s;
  cursor: pointer;
}

.ranking-item:hover {
  transform: translateX(8px);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
}

.ranking-item a {
  display: flex;
  align-items: center;
  width: 100%;
  text-decoration: none;
  color: inherit;
}

.ranking-rank {
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  font-weight: 700;
  margin-right: 20px;
}

.ranking-rank.top-1 {
  background: linear-gradient(135deg, #ffd700, #ffb800);
  color: #fff;
  border-radius: 50%;
}

.ranking-rank.top-2 {
  background: linear-gradient(135deg, #c0c0c0, #a8a8a8);
  color: #fff;
  border-radius: 50%;
}

.ranking-rank.top-3 {
  background: linear-gradient(135deg, #cd7f32, #b5651d);
  color: #fff;
  border-radius: 50%;
}

.ranking-rank.normal {
  background: var(--color-bg-subtle);
  color: var(--color-muted);
  border-radius: 50%;
}

.ranking-info {
  flex: 1;
}

.ranking-title {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--color-title);
  margin-bottom: 4px;
}

.ranking-meta {
  font-size: 0.875rem;
  color: var(--color-muted);
}

.ranking-count {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-accent);
  margin-left: 20px;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px;
  color: var(--color-muted);
  gap: 16px;
}

.spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--color-border-light);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-state {
  text-align: center;
  padding: 60px;
  color: var(--color-muted);
}

@media (max-width: 768px) {
  .page-title { font-size: 1.5rem; }
  .tabs { gap: 8px; }
  .tab-btn { padding: 10px 16px; font-size: 0.9rem; }
  .ranking-item { padding: 12px 16px; }
  .ranking-rank { width: 40px; height: 40px; font-size: 1rem; margin-right: 12px; }
  .ranking-count { font-size: 1.2rem; }
}
</style>

<script>
import { getLikesRanking, getFavoritesRanking, type RankingItem } from '../lib/auth';

declare global {
  interface Window {
    switchRankingTab: (tab: 'likes' | 'favorites') => void;
    loadLikesRanking: () => Promise<void>;
    loadFavoritesRanking: () => Promise<void>;
  }
}

const likesData: RankingItem[] = [];
const favoritesData: RankingItem[] = [];

window.switchRankingTab = function(tab: 'likes' | 'favorites') {
  const tabBtns = document.querySelectorAll('.tab-btn');
  const likesList = document.getElementById('likes-ranking');
  const favoritesList = document.getElementById('favorites-ranking');
  
  tabBtns.forEach(btn => {
    if (btn.getAttribute('data-tab') === tab) {
      btn.classList.add('active');
    } else {
      btn.classList.remove('active');
    }
  });
  
  if (tab === 'likes') {
    if (likesList) likesList.style.display = 'block';
    if (favoritesList) favoritesList.style.display = 'none';
  } else {
    if (likesList) likesList.style.display = 'none';
    if (favoritesList) favoritesList.style.display = 'block';
  }
};

function renderRankingList(containerId: string, items: RankingItem[], type: 'likes' | 'favorites') {
  const container = document.getElementById(containerId);
  if (!container) return;
  
  if (items.length === 0) {
    container.innerHTML = '<div class="empty-state">暂无数据</div>';
    return;
  }
  
  const countLabel = type === 'likes' ? '个点赞' : '次收藏';
  
  container.innerHTML = items.map((item, index) => {
    const rank = index + 1;
    const rankClass = rank <= 3 ? `top-${rank}` : 'normal';
    const title = item.recipe_slug.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
    
    return `
      <div class="ranking-item">
        <a href="/recipes/${item.recipe_slug}">
          <div class="ranking-rank ${rankClass}">${rank}</div>
          <div class="ranking-info">
            <div class="ranking-title">${title}</div>
            <div class="ranking-meta">查看食谱详情</div>
          </div>
          <div class="ranking-count">${item[`${type}_count` as keyof RankingItem] || 0}${countLabel}</div>
        </a>
      </div>
    `;
  }).join('');
}

window.loadLikesRanking = async function() {
  const container = document.getElementById('likes-ranking');
  if (!container) return;
  
  try {
    const result = await getLikesRanking(50);
    if (result.success && result.data) {
      likesData.length = 0;
      likesData.push(...result.data);
      renderRankingList('likes-ranking', likesData, 'likes');
    } else {
      container.innerHTML = '<div class="empty-state">加载失败，请刷新重试</div>';
    }
  } catch (err) {
    console.error('加载点赞榜失败:', err);
    container.innerHTML = '<div class="empty-state">加载失败，请刷新重试</div>';
  }
};

window.loadFavoritesRanking = async function() {
  const container = document.getElementById('favorites-ranking');
  if (!container) return;
  
  try {
    const result = await getFavoritesRanking(50);
    if (result.success && result.data) {
      favoritesData.length = 0;
      favoritesData.push(...result.data);
      renderRankingList('favorites-ranking', favoritesData, 'favorites');
    } else {
      container.innerHTML = '<div class="empty-state">加载失败，请刷新重试</div>';
    }
  } catch (err) {
    console.error('加载收藏榜失败:', err);
    container.innerHTML = '<div class="empty-state">加载失败，请刷新重试</div>';
  }
};

// 页面加载时获取数据
document.addEventListener('DOMContentLoaded', () => {
  window.loadLikesRanking();
  window.loadFavoritesRanking();
});
</script>
