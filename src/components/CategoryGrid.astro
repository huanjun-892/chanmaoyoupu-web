---
import { getAllCuisines, getCoverUrl } from '../lib/strapi';

const allCuisines = await getAllCuisines();

// 首页展示10个菜系分类
const priorityNames = [
  '川菜', '粤菜', '湘菜', '浙菜', '鲁菜', '苏菜',
  '闽菜', '徽菜', '东北菜', '家常菜',
];

const cookingMethods = [
  { name: '炒', emoji: '🍳' },
  { name: '炖', emoji: '🫕' },
  { name: '煮', emoji: '🍲' },
  { name: '蒸', emoji: '♨️' },
  { name: '煎', emoji: '🥘' },
  { name: '炸', emoji: '🔥' },
  { name: '烤', emoji: '🧑‍🍳' },
  { name: '焖', emoji: '🥩' },
  { name: '卤', emoji: '🍖' },
  { name: '拌', emoji: '🥗' },
  { name: '烩', emoji: '🍜' },
  { name: '腌', emoji: '🫙' },
];

const priorityCuisines = priorityNames
  .map(name => allCuisines.find((c: any) => c.name === name))
  .filter(Boolean) as any[];
---

<section class="section categories-section">
  <div class="container">
    <h2 class="section-title">想做什么菜？</h2>
    <div class="category-grid">
      {priorityCuisines.map((cuisine) => {
        const coverUrl = getCoverUrl(cuisine.cover);
        return (
          <a href={`/recipes?cuisine=${cuisine.name}`} class="category-item">
            {coverUrl ? (
              <img src={coverUrl} alt={cuisine.name} class="category-img" loading="lazy" />
            ) : (
              <span class="category-emoji-fallback">🍽️</span>
            )}
            <span class="category-label">{cuisine.name}</span>
          </a>
        );
      })}
    </div>

    <h2 class="section-title" style="margin-top: 28px;">按做法找</h2>
    <div class="method-grid">
      {cookingMethods.map((m) => (
        <a href={`/recipes?method=${m.name}`} class="method-item">
          <span class="method-emoji">{m.emoji}</span>
          <span class="method-label">{m.name}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .category-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 14px;
  }

  .category-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-radius: var(--radius);
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border: 1px solid var(--color-border-light);
    background: #fff;
    text-decoration: none;
  }

  .category-img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    display: block;
  }

  .category-emoji-fallback {
    width: 100%;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    background: #fafafa;
  }

  .category-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
  }

  .category-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-title);
    letter-spacing: 0.02em;
    padding: 10px 4px;
    background: #fff;
    width: 100%;
    text-align: center;
  }

  @media (max-width: 768px) {
    .category-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 480px) {
    .category-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .category-label {
      font-size: 0.75rem;
      padding: 8px 2px;
    }
  }

  .method-grid { display: flex; gap: 12px; flex-wrap: wrap; }
  .method-item { display: flex; align-items: center; gap: 6px; padding: 10px 20px; background: #fff; border: 1px solid var(--color-border-light); border-radius: 100px; text-decoration: none; color: var(--color-text); font-size: 0.9rem; font-weight: 500; transition: all 0.25s; }
  .method-item:hover { border-color: var(--color-accent); color: var(--color-accent); transform: translateY(-1px); box-shadow: 0 2px 8px rgba(255, 140, 66, 0.12); }
  .method-emoji { font-size: 1.1rem; }
</style>
