        '卡路里': 'calories',
        '热量': 'calories',
        '封面图': 'cover_url',
        '图片': 'cover_url',
        '状态': 'published',
        '营养价值': 'nutrition',
        '常见误区': 'common_mistakes',
        '制作技巧': 'success_tips',
        '食材替代': 'ingredient_substitutes',
        '适用人群': 'suitable_for',
        '所需工具': 'required_tools',
        '食材清单': 'ingredients',
        '烹饪步骤': 'steps',
        '菜系': 'cuisine_name',
        '菜系ID': 'cuisine_id'
      },
      ingredients: {
        '名称': 'name',
        '食材名': 'name',
        '拼音': 'slug',
        'slug': 'slug',
        '分类': 'category',
        '图片': 'image_url',
        '封面': 'image_url',
        '别名': 'aliases',
        '产地': 'origin',
        '季节': 'season',
        '状态': 'published',
        '简介': 'description',
        '描述': 'description',
        '营养价值': 'nutrition',
        '营养': 'nutrition',
        '选购技巧': 'tips',
        '使用技巧': 'tips',
        '搭配建议': 'pairing_suggestions',
        '食用禁忌': 'avoid_with',
        '储存方法': 'storage_method'
      },
      knowledge: {
        '标题': 'title',
        '拼音': 'slug',
        'slug': 'slug',
        '分类': 'category',
        '摘要': 'summary',
        '简介': 'summary',
        '内容': 'content',
        '正文': 'content'
      }
    };
    
    // 从 Excel 导入
    function importFromExcel(type, fileInput) {
      const file = fileInput.files[0];
      if (!file) return;
      
      if (!window.XLSX) {
        showToast('Excel 解析库加载中，请稍候再试', 'error');
        return;
      }
      
      const reader = new FileReader();
      reader.onload = function(e) {
        try {
          const data = new Uint8Array(e.target.result);
          const workbook = XLSX.read(data, { type: 'array' });
          const firstSheet = workbook.Sheets[workbook.SheetNames[0]];
          const jsonData = XLSX.utils.sheet_to_json(firstSheet);
          
          if (jsonData.length === 0) {
            showToast('Excel 文件中没有数据', 'error');
            return;
          }
          
          // 确认导入
          if (!confirm('检测到 ' + jsonData.length + ' 条数据，确定要开始导入吗？')) {
            fileInput.value = '';
            return;
          }
          
          // 开始批量导入
          doBatchImport(type, jsonData);
          
        } catch (err) {
          console.error('Excel 解析失败:', err);
          showToast('Excel 解析失败：' + err.message, 'error');
        }
        
        fileInput.value = '';
      };
      reader.readAsArrayBuffer(file);
    }
    
    // 执行批量导入
    function doBatchImport(type, items) {
      const fieldMap = importFieldMaps[type];
      const apiEndpoint = type === 'recipes' ? '/recipes' : type === 'ingredients' ? '/ingredients' : '/knowledge';
      
      let successCount = 0;
      let failCount = 0;
      let currentIndex = 0;
      const total = items.length;
      
      // 创建进度弹窗
      showImportProgress(type, total);
      
      function importNext() {
        if (currentIndex >= total) {
          // 导入完成
          updateImportProgress(total, total, successCount, failCount);
          setTimeout(() => {
            closeImportProgress();
            showToast('导入完成：成功 ' + successCount + ' 条，失败 ' + failCount + ' 条', successCount > 0 ? 'success' : 'error');
            // 刷新列表
            if (type === 'recipes') { currentPage.recipes = 1; loadRecipes(); }
            else if (type === 'ingredients') { currentPage.ingredients = 1; loadIngredients(); }
            else { currentPage.knowledge = 1; loadKnowledge(); }
          }, 500);
          return;
        }
        
        const rawItem = items[currentIndex];
        const mappedItem = mapFields(rawItem, fieldMap);
        
        // 特殊处理：食谱的食材和步骤
        if (type === 'recipes') {
          if (mappedItem.ingredients && typeof mappedItem.ingredients === 'string') {
            const ingList = mappedItem.ingredients.split(/[,，、\n]/).filter(s => s.trim());
            mappedItem.ingredients = ingList.map((name, idx) => ({
              name: name.trim(),
              amount: '',
              sort_order: idx + 1
            }));
          }
          if (mappedItem.steps && typeof mappedItem.steps === 'string') {
            const stepList = mappedItem.steps.split(/\n/).filter(s => s.trim());
            mappedItem.steps = stepList.map((text, idx) => ({
              step_number: idx + 1,
              text: text.trim()
            }));
          }
          // 数字类型转换
          if (mappedItem.cook_time) mappedItem.cook_time = parseInt(mappedItem.cook_time) || 0;
          if (mappedItem.servings) mappedItem.servings = parseInt(mappedItem.servings) || 1;
          if (mappedItem.calories) mappedItem.calories = parseInt(mappedItem.calories) || 0;
          if (mappedItem.published !== undefined) mappedItem.published = mappedItem.published === 1 || mappedItem.published === '1' || mappedItem.published === true ? 1 : 0;
        }
        
        if (type === 'ingredients') {
          if (mappedItem.published !== undefined) mappedItem.published = mappedItem.published === 1 || mappedItem.published === '1' || mappedItem.published === true ? 1 : 0;
        }
        
        // 调用 API 导入
        fetch(API_BASE + apiEndpoint, {
          method: 'POST',
          headers: {
            ...getAuthHeaders(),
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(mappedItem)
        })
        .then(res => res.json())
        .then(result => {
          if (result.success) {
            successCount++;
          } else {
            failCount++;
            console.warn('导入失败:', rawItem, result.error);
          }
        })
        .catch(err => {
          failCount++;
          console.error('导入错误:', err);
        })
        .finally(() => {
          currentIndex++;
          updateImportProgress(currentIndex, total, successCount, failCount);
          // 延迟一下再导入下一条，避免请求过快
          setTimeout(importNext, 200);
        });
      }
      
      importNext();
    }
    
    // 字段映射
    function mapFields(rawItem, fieldMap) {
      const result = {};
      for (const [key, value] of Object.entries(rawItem)) {
        const mappedKey = fieldMap[key.trim()] || key.trim();
        if (value !== undefined && value !== null && value !== '') {
          result[mappedKey] = value;
        }
      }
      return result;
    }
    
    // 显示导入进度弹窗
    function showImportProgress(type, total) {
      const typeNames = { recipes: '食谱', ingredients: '食材', knowledge: '知识库' };
      const modalHtml = `
        <div class="modal-overlay show" id="import-progress-modal" style="z-index: 2000;">
          <div class="modal-content" style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 400px; min-height: auto;">
            <div class="modal-header" style="cursor: default;">
              <h3>批量导入${typeNames[type]}</h3>
            </div>
            <div class="modal-body">
              <p style="margin-bottom: 16px;">正在导入，请稍候...</p>
              <div style="background: var(--color-bg-secondary); border-radius: 4px; height: 24px; overflow: hidden; margin-bottom: 12px;">
                <div id="import-progress-bar" style="background: var(--color-primary); height: 100%; width: 0%; transition: width 0.3s;"></div>
              </div>
              <p id="import-progress-text" style="font-size: 0.9rem; color: var(--color-text-secondary);">0 / ${total} 条</p>
              <p id="import-result-text" style="font-size: 0.85rem; margin-top: 8px;">
                <span style="color: #16a34a;">成功: 0</span>
                <span style="color: #dc2626; margin-left: 16px;">失败: 0</span>
              </p>
            </div>
          </div>
        </div>
      `;
      document.body.insertAdjacentHTML('beforeend', modalHtml);
    }
    
    // 更新导入进度
    function updateImportProgress(current, total, success, fail) {
      const bar = document.getElementById('import-progress-bar');
      const text = document.getElementById('import-progress-text');
      const result = document.getElementById('import-result-text');
      
      if (bar) bar.style.width = (current / total * 100) + '%';
      if (text) text.textContent = current + ' / ' + total + ' 条';
      if (result) result.innerHTML = `
        <span style="color: #16a34a;">成功: ${success}</span>
        <span style="color: #dc2626; margin-left: 16px;">失败: ${fail}</span>
      `;
    }
    
    // 关闭导入进度弹窗
    function closeImportProgress() {
      const modal = document.getElementById('import-progress-modal');
      if (modal) modal.remove();
    }
    
