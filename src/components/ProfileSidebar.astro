---
const { active = 'favorites' } = Astro.props;
---

<aside class="profile-sidebar">
  <div class="sidebar-header">
    <div class="user-avatar-wrapper">
      <img id="sidebar-avatar" src="/images/default-avatar.jpg" alt="头像" class="user-avatar" />
    </div>
    <div class="user-info">
      <h3 id="sidebar-nickname" class="user-nickname">加载中...</h3>
      <p class="user-email" id="sidebar-email">—</p>
    </div>
  </div>
  
  <nav class="sidebar-nav">
    <a href="/profile" class:list={['sidebar-item', { active: active === 'profile' }]}>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      <span>个人资料</span>
    </a>
    <a href="/profile/favorites" class:list={['sidebar-item', { active: active === 'favorites' }]}>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
      </svg>
      <span>我的收藏</span>
    </a>
    <a href="/profile/settings" class:list={['sidebar-item', { active: active === 'settings' }]}>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"/>
        <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 01-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
      </svg>
      <span>账号设置</span>
    </a>
  </nav>
</aside>

<style>
.profile-sidebar {
  width: 260px;
  flex-shrink: 0;
  background: var(--color-bg);
  border-radius: var(--radius-lg);
  padding: 24px 0;
  height: fit-content;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.04);
}

.sidebar-header {
  padding: 0 20px 20px;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 12px;
  text-align: center;
}

.user-avatar-wrapper {
  margin-bottom: 12px;
}

.user-avatar {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid var(--color-accent-light);
}

.user-nickname {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--color-title);
  margin: 0 0 4px 0;
}

.user-email {
  font-size: 0.85rem;
  color: var(--color-muted);
  margin: 0;
  word-break: break-all;
}

.sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sidebar-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 20px;
  color: var(--color-text-secondary);
  text-decoration: none;
  font-size: 0.95rem;
  transition: all 0.2s;
  border-left: 3px solid transparent;
}

.sidebar-item:hover {
  background: var(--color-bg-secondary);
  color: var(--color-text);
}

.sidebar-item.active {
  background: var(--color-accent-light);
  color: var(--color-accent);
  border-left-color: var(--color-accent);
  font-weight: 500;
}

@media (max-width: 768px) {
  .profile-sidebar {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 10;
    padding: 12px 0;
  }
  
  .sidebar-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 16px 12px;
    text-align: left;
  }
  
  .user-avatar {
    width: 48px;
    height: 48px;
  }
  
  .user-nickname {
    font-size: 1rem;
  }
  
  .sidebar-nav {
    flex-direction: row;
    overflow-x: auto;
    gap: 0;
    padding: 0 8px;
  }
  
  .sidebar-item {
    flex-shrink: 0;
    padding: 8px 16px;
    border-left: none;
    border-bottom: 2px solid transparent;
    border-radius: 0;
  }
  
  .sidebar-item.active {
    border-left: none;
    border-bottom-color: var(--color-accent);
  }
  
  .sidebar-item span {
    display: none;
  }
}
</style>

<script>
import { getStoredUser, isLoggedIn } from '../lib/auth';

function updateSidebarUserInfo() {
  const nicknameEl = document.getElementById('sidebar-nickname');
  const emailEl = document.getElementById('sidebar-email');
  const avatarEl = document.getElementById('sidebar-avatar');
  
  if (!isLoggedIn()) {
    if (nicknameEl) nicknameEl.textContent = '未登录';
    if (emailEl) emailEl.textContent = '点击登录';
    return;
  }
  
  const user = getStoredUser();
  if (user) {
    if (nicknameEl) nicknameEl.textContent = user.nickname || '用户';
    if (emailEl) emailEl.textContent = user.email || '—';
    if (avatarEl && user.avatar_url) {
      avatarEl.src = user.avatar_url;
    }
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', updateSidebarUserInfo);
} else {
  updateSidebarUserInfo();
}

window.addEventListener('storage', updateSidebarUserInfo);
window.addEventListener('auth_change', updateSidebarUserInfo);
</script>
