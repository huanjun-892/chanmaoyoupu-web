          <p style="color: var(--color-text-secondary); margin-bottom: 24px;">
            即将上线，敬请期待
          </p>
          <button class="btn btn-secondary" disabled style="opacity: 0.6; cursor: not-allowed;">
            敬请期待
          </button>
        </div>
      </section>
      
      <!-- 定时发布（占位） -->
      <section id="page-schedule" class="page-section">
        <div style="margin-bottom: 20px;">
          <h2 style="margin: 0; color: var(--color-title);">定时发布</h2>
          <p style="color: var(--color-text-secondary); font-size: 0.9rem; margin: 5px 0 0 0;">
            设置定时任务，自动发布内容
          </p>
        </div>
        <div class="form-card" style="text-align: center; padding: 60px;">
          <div style="font-size: 4rem; margin-bottom: 16px;">⏰</div>
          <h3 style="margin: 0 0 8px 0; color: var(--color-title);">定时发布</h3>
          <p style="color: var(--color-text-secondary); margin-bottom: 24px;">
            即将上线，敬请期待
          </p>
          <button class="btn btn-secondary" disabled style="opacity: 0.6; cursor: not-allowed;">
            敬请期待
          </button>
        </div>
      </section>
    </main>
  </div>
  
  <!-- 编辑弹窗 -->
  <div class="modal-overlay" id="edit-modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modal-title">编辑</h3>
        <button class="modal-close" onclick="closeModal()">&times;</button>
      </div>
      <div class="modal-body" id="modal-body"></div>
      <div class="modal-footer" id="modal-footer">
        <button class="btn btn-secondary" onclick="closeModal()">取消</button>
        <button class="btn btn-primary" onclick="saveItem()">保存</button>
      </div>
      <div class="modal-resize-handle" id="modal-resize-handle"></div>
    </div>
  </div>

  <script is:inline>
    const API_BASE = 'https://api.chanmaoyoupu.com/api/admin';
    let currentPage = { recipes: 1, ingredients: 1, knowledge: 1 };
    let perPage = { recipes: 10, ingredients: 10, knowledge: 10 };
    let currentItem = null;
    let currentItemType = null;
    let currentCategoryTab = 'cuisines';
    let currentPlatform = 'wechat';
    let quillEditors = {}; // 存储所有 Quill 编辑器实例
    
    // ============ Quill 富文本编辑器工具函数 ============
    function initQuillEditor(containerId, options = {}) {
      // 如果已存在，先销毁
      if (quillEditors[containerId]) {
        quillEditors[containerId].destroy();
        delete quillEditors[containerId];
      }
      
      const container = document.getElementById(containerId);
      if (!container) return null;
      
      // 添加包装器类
      container.classList.add('editor-wrapper');
      
      // 创建 Quill 容器结构
      const editorId = containerId + '-editor';
      container.innerHTML = `<div id="${editorId}"></div>`;
      
      const defaultOptions = {
        theme: 'snow',
        placeholder: options.placeholder || '请输入内容...',
        modules: {
          toolbar: options.toolbar || [
            [{ 'header': [3, 4, false] }],
            ['bold', 'italic', 'underline'],
            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
            ['clean']
          ]
        }
      };
      
      const quill = new Quill('#' + editorId, defaultOptions);
      
      // 设置初始内容（支持HTML）
      if (options.content && options.content.trim()) {
        quill.clipboard.dangerouslyPasteHTML(0, options.content);
      }
      
      // 设置编辑器初始高度
      const qlContainer = container.querySelector('.ql-container');
      if (qlContainer) {
        qlContainer.style.height = options.height || '120px';
        qlContainer.style.resize = 'vertical';
        qlContainer.style.overflow = 'hidden';
      }
      
      quillEditors[containerId] = quill;
      return quill;
    }
    
    function getQuillContent(containerId) {
      if (quillEditors[containerId]) {
        return quillEditors[containerId].root.innerHTML;
      }
      const container = document.getElementById(containerId);
      if (container) {
        const editor = container.querySelector('.ql-editor');
        if (editor) return editor.innerHTML;
      }
      return '';
    }
    
    function destroyQuillEditors() {
      Object.keys(quillEditors).forEach(key => {
        try {
          quillEditors[key].destroy();
        } catch (e) {}
        delete quillEditors[key];
      });
      quillEditors = {};
    }
    
    // 带富文本的字段配置
    const richTextFields = {
      recipe: ['description', 'nutrition', 'common_mistakes', 'success_tips', 'ingredient_substitutes', 'suitable_for', 'required_tools'],
      ingredient: ['description', 'nutrition', 'tips', 'pairing_suggestions', 'avoid_with', 'storage_method'],
      knowledge: ['summary', 'content'],
      cuisine: ['description'],
      tag: []
    };
    
    // 初始化（脚本在DOM之后，直接执行即可）
    function initAdmin() {
      try {
        initNavigation();
        initModalDrag();
        checkAuth();
      } catch (e) {
        console.error('Admin init error:', e);
      }
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAdmin);
    } else {
      initAdmin();
    }
    
    // 检查登录状态
    function checkAuth() {
      const token = localStorage.getItem('admin_token');
      if (!token) {
        showLoginPage();
      } else {
        fetch(API_BASE + '/stats', {
          headers: { 'Authorization': 'Bearer ' + token }
        }).then(res => {
          if (res.status === 401 || res.status === 403) {
            localStorage.removeItem('admin_token');
            localStorage.removeItem('admin_user');
            showLoginPage();
          } else {
            showAdminPanel();
          }
        }).catch(() => {
          // 网络错误也显示登录页
          showLoginPage();
        });
      }
    }
    
    // 显示登录页面
    function showLoginPage() {
      document.getElementById('login-page').style.display = 'flex';
      document.getElementById('admin-container').style.display = 'none';
    }
    
    // 显示管理后台
    function showAdminPanel() {
      document.getElementById('login-page').style.display = 'none';
      document.getElementById('admin-container').style.display = 'flex';
      updateUserInfo();
      loadStats();
    }
    
    // 登录
    function doLogin() {
      const email = document.getElementById('login-email').value;
      const password = document.getElementById('login-password').value;
      
      if (!email || !password) {
        showToast('请输入邮箱和密码', 'error');
        return;
      }
      
      fetch('https://api.chanmaoyoupu.com/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      }).then(res => res.json()).then(data => {
        if (data.success) {
          if (data.data.user.role !== 'admin') {
            showToast('该账号没有管理员权限', 'error');
            return;
          }
          localStorage.setItem('admin_token', data.data.token);
          localStorage.setItem('admin_user', JSON.stringify(data.data.user));
          showAdminPanel();
          loadStats();
          showToast('登录成功', 'success');
        } else {
          showToast(data.error || '登录失败', 'error');
        }
      }).catch(() => {
        showToast('网络错误，请稍后重试', 'error');
      });
    }
    
    // 退出登录
    function logout() {
      if (!confirm('确定要退出登录吗？')) return;
      localStorage.removeItem('admin_token');
      localStorage.removeItem('admin_user');
      // 清空登录表单
      document.getElementById('login-email').value = '';
      document.getElementById('login-password').value = '';
      showLoginPage();
      showToast('已退出登录', 'success');
    }
    
    // 更新用户信息显示
    function updateUserInfo() {
      const user = JSON.parse(localStorage.getItem('admin_user') || '{}');
      document.getElementById('user-email').textContent = user.email || '未登录';
    }
    
    // 导航切换
    function initNavigation() {
      const links = document.querySelectorAll('.admin-nav a');
      if (!links || links.length === 0) {
        console.warn('Admin nav links not found');
        return;
      }
      
      links.forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          try {
            const page = this.dataset.page;
            if (!page) return;
            
            // 切换激活状态
            links.forEach(a => a.classList.remove('active'));
            this.classList.add('active');
            
            // 切换内容区域
            document.querySelectorAll('.page-section').forEach(s => s.classList.remove('active'));
            const targetSection = document.getElementById('page-' + page);
            if (targetSection) {
              targetSection.classList.add('active');
            }
            
            // 更新标题
            const titleEl = document.getElementById('page-title');
            const spanEl = this.querySelector('span');
            if (titleEl && spanEl) {
              titleEl.textContent = spanEl.textContent;
            }
            
            // 加载对应数据
            if (page === 'recipes') loadRecipes();
            else if (page === 'ingredients') loadIngredients();
            else if (page === 'knowledge') loadKnowledge();
            else if (page === 'categories') loadCuisines();
            else if (page === 'users') loadUsers();
            else if (page === 'push') loadPushContentOptions();
            else if (page === 'platforms') loadPlatformList();
            else if (page === 'friend-links') loadFriendLinks();
            else if (page === 'nav-menus') loadNavMenus();
            else if (page === 'banners') loadBanners();
            else if (page === 'settings') loadSiteSettings();
          } catch (err) {
            console.error('Navigation error:', err);
          }
        });
      });
    }
    
    // 获取认证头
    function getAuthHeaders() {
      const token = localStorage.getItem('admin_token');
      return {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + (token || '')
      };
    }
    
    // ============ 统计数据 ============
    function loadStats() {
      fetch(API_BASE + '/stats', { headers: getAuthHeaders() })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            document.getElementById('stat-recipes').textContent = data.data.recipes || 0;
            document.getElementById('stat-ingredients').textContent = data.data.ingredients || 0;
            document.getElementById('stat-knowledge').textContent = data.data.knowledge || 0;
            document.getElementById('stat-cuisines').textContent = data.data.cuisines || 0;
            document.getElementById('stat-tags').textContent = data.data.tags || 0;
            document.getElementById('stat-users').textContent = data.data.users || 0;
          }
        });
    }
    
    // ============ 食谱管理 ============
    function loadRecipes() {
      const page = currentPage.recipes;
      const limit = perPage.recipes;
      const keyword = document.getElementById('recipe-search').value;
      const status = document.getElementById('recipe-status').value;
      
      let url = API_BASE + '/recipes?page=' + page + '&limit=' + limit;
      if (keyword) url += '&keyword=' + encodeURIComponent(keyword);
      if (status !== '') url += '&published=' + status;
      
      fetch(url, { headers: getAuthHeaders() })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            renderRecipesTable(data.data.items);
            renderPagination('recipes', data.data);
          }
        });
    }
    
    function searchRecipes() {
      currentPage.recipes = 1;
      loadRecipes();
    }
    
    function renderRecipesTable(items) {
      const container = document.getElementById('recipes-table-container');
      if (!items || items.length === 0) {
        container.innerHTML = '<div class="loading"><p>暂无数据</p></div>';
        return;
      }
      
      let html = '<table class="data-table"><thead><tr>';
      html += '<th>ID</th><th>标题</th><th>Slug</th><th>难度</th><th>菜系</th><th>状态</th><th>操作</th>';
      html += '</tr></thead><tbody>';
      
      items.forEach(item => {
        const statusText = item.published ? '已发布' : '草稿';
        const statusClass = item.published ? 'status-published' : 'status-draft';
        html += `<tr>
          <td>${item.id}</td>
          <td>${item.title}</td>
          <td><code style="font-size: 0.8rem;">${item.slug}</code></td>
          <td>${item.difficulty || '-'}</td>
          <td>${item.cuisine_name || '-'}</td>
          <td><span class="status-badge ${statusClass}">${statusText}</span></td>
          <td>
            <button class="btn btn-secondary btn-sm" onclick="editRecipe(${item.id})">编辑</button>
            <button class="btn btn-secondary btn-sm" onclick="toggleRecipePublish(${item.id}, ${item.published ? 0 : 1})">
              ${item.published ? '下架' : '上架'}
            </button>
            <button class="btn btn-danger btn-sm" onclick="deleteRecipe(${item.id})">删除</button>
          </td>
        </tr>`;
      });
      
      html += '</tbody></table>';
      container.innerHTML = html;
    }
    
    function openRecipeModal(id) {
      currentItemType = 'recipe';
      currentItem = null;
      
      const title = document.getElementById('modal-title');
      
      if (id) {
        title.textContent = '编辑食谱';
        fetch(API_BASE + '/recipes/' + id, { headers: getAuthHeaders() })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              currentItem = data.data;
              renderRecipeForm(data.data);
            }
          });
      } else {
        title.textContent = '新增食谱';
        renderRecipeForm({});
      }
      
      document.getElementById('edit-modal').classList.add('show');
      resetModalPosition();
    }
    
    function editRecipe(id) {
      openRecipeModal(id);
    }
    
    function renderRecipeForm(data) {
      const body = document.getElementById('modal-body');

      // 构建食材HTML
      let ingredientsHtml = '';
      const ingredients = data.ingredients || [];
      if (ingredients.length === 0) {
        ingredientsHtml = '<p style="color: var(--color-text-secondary); font-size: 0.85rem; margin: 0;">暂无食材，点击下方按钮添加</p>';
      } else {
        ingredients.forEach((ing, idx) => {
          ingredientsHtml += `
            <div class="ingredient-row" style="display: flex; gap: 8px; margin-bottom: 8px;">
              <input type="text" placeholder="食材名称" value="${ing.name || ''}" style="flex: 1; padding: 6px 10px; border: 1px solid var(--color-border); border-radius: 4px; font-size: 0.85rem; background: var(--color-bg); color: var(--color-text);">
              <input type="text" placeholder="用量" value="${ing.amount || ''}" style="width: 120px; padding: 6px 10px; border: 1px solid var(--color-border); border-radius: 4px; font-size: 0.85rem; background: var(--color-bg); color: var(--color-text);">
              <button type="button" onclick="removeIngredientRow(this)" style="padding: 6px 12px; background: #fee2e2; color: #dc2626; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">删除</button>
            </div>
          `;
        });
      }

      // 构建步骤HTML
      let stepsHtml = '';
      const steps = data.steps || [];
      if (steps.length === 0) {
        stepsHtml = '<p style="color: var(--color-text-secondary); font-size: 0.85rem; margin: 0;">暂无步骤，点击下方按钮添加</p>';
      } else {
        steps.forEach((step, idx) => {
          stepsHtml += `
            <div class="step-row" style="margin-bottom: 8px;">
              <div style="display: flex; gap: 8px; align-items: flex-start;">
                <span style="font-weight: 600; color: var(--color-accent); min-width: 24px; padding-top: 6px;">${idx + 1}.</span>
                <textarea placeholder="步骤描述" rows="2" style="flex: 1; padding: 6px 10px; border: 1px solid var(--color-border); border-radius: 4px; font-size: 0.85rem; resize: vertical; background: var(--color-bg); color: var(--color-text);">${step.text || ''}</textarea>
                <button type="button" onclick="removeStepRow(this)" style="padding: 6px 12px; background: #fee2e2; color: #dc2626; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem; white-space: nowrap;">删除</button>
              </div>
            </div>
          `;
        });
      }

      body.innerHTML = `
        <div style="border-bottom: 1px solid var(--color-border); padding-bottom: 12px; margin-bottom: 12px;">
          <h4 style="margin: 0 0 12px 0; color: var(--color-title); font-size: 0.95rem;">基本信息</h4>
          <div class="form-group">
            <label>标题 *</label>
            <input type="text" id="recipe-title" value="${data.title || ''}" placeholder="食谱标题">
          </div>
          <div class="form-group">
            <label>Slug *</label>
            <input type="text" id="recipe-slug" value="${data.slug || ''}" placeholder="url-friendly slug">
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>难度</label>
              <select id="recipe-difficulty">
                <option value="简单" ${data.difficulty === '简单' ? 'selected' : ''}>简单</option>
                <option value="中等" ${data.difficulty === '中等' ? 'selected' : ''}>中等</option>
                <option value="较难" ${data.difficulty === '较难' ? 'selected' : ''}>较难</option>
              </select>
            </div>
            <div class="form-group">
              <label>烹饪时间(分钟)</label>
              <input type="number" id="recipe-cooktime" value="${data.cook_time || ''}">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>份量(人份)</label>
              <input type="number" id="recipe-servings" value="${data.servings || ''}">
            </div>
            <div class="form-group">
              <label>卡路里</label>
              <input type="number" id="recipe-calories" value="${data.calories || ''}">
            </div>
          </div>
          <div class="form-group">
            <label>菜系</label>
            <select id="recipe-cuisine">
              <option value="">无</option>
            </select>
          </div>
          <div class="form-group">
            <label>封面图URL</label>
            <input type="text" id="recipe-cover" value="${data.cover_url || ''}" placeholder="https://...">
          </div>
          <div class="form-group">
            <label>简介</label>
            <div id="recipe-description" class="quill-small"></div>
          </div>
          <div class="form-group">
            <label>发布状态</label>
            <select id="recipe-published">
              <option value="1" ${data.published === 1 ? 'selected' : ''}>发布</option>
              <option value="0" ${data.published === 0 ? 'selected' : ''}>草稿</option>
            </select>
          </div>
        </div>

        <div style="border-bottom: 1px solid var(--color-border); padding-bottom: 12px; margin-bottom: 12px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <h4 style="margin: 0; color: var(--color-title); font-size: 0.95rem;">食材清单</h4>
            <button type="button" onclick="addIngredientRow()" style="padding: 4px 12px; background: var(--color-accent); color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">+ 添加食材</button>
          </div>
          <div id="ingredients-list">${ingredientsHtml}</div>
        </div>

        <div style="border-bottom: 1px solid var(--color-border); padding-bottom: 12px; margin-bottom: 12px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <h4 style="margin: 0; color: var(--color-title); font-size: 0.95rem;">烹饪步骤</h4>
            <button type="button" onclick="addStepRow()" style="padding: 4px 12px; background: var(--color-accent); color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">+ 添加步骤</button>
          </div>
          <div id="steps-list">${stepsHtml}</div>
        </div>

        <div>
          <h4 style="margin: 0 0 12px 0; color: var(--color-title); font-size: 0.95rem;">详细信息</h4>
          <div class="form-group">
            <label>营养价值</label>
            <div id="recipe-nutrition"></div>
          </div>
          <div class="form-group">
            <label>常见误区</label>
            <div id="recipe-common-mistakes"></div>
          </div>
          <div class="form-group">
            <label>成功技巧</label>
            <div id="recipe-success-tips"></div>
          </div>
          <div class="form-group">
            <label>食材替代</label>
            <div id="recipe-substitutes"></div>
          </div>
          <div class="form-group">
            <label>适宜人群</label>
            <div id="recipe-suitable-for"></div>
          </div>
          <div class="form-group">
            <label>所需厨具</label>
            <div id="recipe-required-tools"></div>
          </div>
        </div>
      `;

      // 加载菜系选项
      loadCuisineOptions(data.cuisine_id);
      
      // 初始化富文本编辑器
      setTimeout(() => {
        initQuillEditor('recipe-description', {
          content: data.description || '',
          placeholder: '简要介绍这道菜的特点...',
          toolbar: ['bold', 'italic', { 'list': 'bullet' }, 'clean']
        });
        
        const fieldConfig = {
          'recipe-nutrition': { placeholder: '如：富含蛋白质、维生素...', content: data.nutrition || '' },
          'recipe-common-mistakes': { placeholder: '如：不要过度翻炒以免变老...', content: data.common_mistakes || '' },
          'recipe-success-tips': { placeholder: '如：冷水下锅焯水去腥味...', content: data.success_tips || '' },
          'recipe-substitutes': { placeholder: '如：没有料酒可用黄酒代替...', content: data.ingredient_substitutes || '' },
          'recipe-suitable-for': { placeholder: '如：一般人群均可食用...', content: data.suitable_for || '' },
          'recipe-required-tools': { placeholder: '如：炒锅、铲子、盘子...', content: data.required_tools || '' }
        };
        
        Object.keys(fieldConfig).forEach(fieldId => {
          initQuillEditor(fieldId, {
            content: fieldConfig[fieldId].content,
            placeholder: fieldConfig[fieldId].placeholder,
            toolbar: [
              [{ 'header': [3, 4, false] }],
              ['bold', 'italic', 'underline'],
              [{ 'list': 'ordered'}, { 'list': 'bullet' }],
              ['clean']
            ]
          });
        });
      }, 10);
    }

    // 加载菜系下拉选项
    function loadCuisineOptions(selectedId) {
      fetch(API_BASE + '/cuisines?all=1', { headers: getAuthHeaders() })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            const select = document.getElementById('recipe-cuisine');
            if (!select) return;
            data.data.forEach(c => {
              if (c.id === 0) return;
              const option = document.createElement('option');
              option.value = c.id;
              option.textContent = c.name;
              if (selectedId && c.id === selectedId) option.selected = true;
              select.appendChild(option);
            });
          }
        });
    }

    // 添加食材行
    function addIngredientRow() {
      const list = document.getElementById('ingredients-list');
      if (!list) return;
      const row = document.createElement('div');
      row.className = 'ingredient-row';
      row.style.cssText = 'display: flex; gap: 8px; margin-bottom: 8px;';
      row.innerHTML = `
