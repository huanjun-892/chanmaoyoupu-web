---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="搜索">
  
  <section class="section">
    <div class="container">
      <h1 class="page-title">搜索</h1>

      <form class="search-form" id="search-form">
        <div class="search-row">
          <input type="text" id="search-q" name="q" placeholder="搜索食谱、食材、秘方、知识库..." class="search-input" />
          <button type="submit" class="search-btn">搜索</button>
        </div>
        <div class="filter-row">
          <label class="filter-label">搜索范围：</label>
          <select id="search-type" name="type" class="filter-select">
            <option value="all">全部</option>
            <option value="recipes">食谱</option>
            <option value="ingredients">食材</option>
            <option value="secrets">秘方</option>
            <option value="knowledge">知识库</option>
          </select>
        </div>
      </form>

      <div id="search-results">
        <div class="no-results">
          <p>输入关键词开始搜索</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ API_BASE: 'https://api.chanmaoyoupu.com' }}>
  const params = new URLSearchParams(window.location.search);
  const initQ = params.get('q') || '';
  const initType = params.get('type') || 'all';

  const inputQ = document.getElementById('search-q');
  const selectType = document.getElementById('search-type');
  const resultsDiv = document.getElementById('search-results');

  if (initQ) {
    inputQ.value = initQ;
    selectType.value = initType;
    doSearch(initQ, initType);
  }

  document.getElementById('search-form').addEventListener('submit', (e) => {
    e.preventDefault();
    const q = inputQ.value.trim();
    const type = selectType.value;
    if (q) {
      const url = new URL(window.location.href);
      url.searchParams.set('q', q);
      url.searchParams.set('type', type);
      history.replaceState(null, '', url);
      doSearch(q, type);
    }
  });

  async function doSearch(q, type) {
    resultsDiv.innerHTML = '<div class="loading">搜索中...</div>';
    try {
      const res = await fetch(`${API_BASE}/api/content/search?q=${encodeURIComponent(q)}&type=${type}`);
      const json = await res.json();
      const data = json.data || json;
      renderResults(data, q, type);
    } catch (err) {
      resultsDiv.innerHTML = '<div class="no-results"><p>搜索出错了，请稍后重试</p></div>';
    }
  }

  function renderResults(data, q, type) {
    const recipes = data.recipes || [];
    const knowledge = data.knowledge || [];
    const secrets = data.secrets || [];
    const ingredients = data.ingredients || [];
    const total = data.total || 0;

    if (total === 0) {
      resultsDiv.innerHTML = '<div class="no-results"><p>没有找到与「' + q + '」相关的内容</p><p class="hint">试试换个关键词，或搜索食材名、菜名等</p></div>';
      return;
    }

    let html = '<p class="result-summary">找到 <strong>' + total + '</strong> 条与「' + q + '」相关的结果</p>';

    // Tabs
    html += '<div class="result-tabs">';
    html += '<button class="result-tab active" data-type="all">全部 (' + total + ')</button>';
    html += '<button class="result-tab" data-type="recipes">食谱 (' + recipes.length + ')</button>';
    html += '<button class="result-tab" data-type="ingredients">食材 (' + ingredients.length + ')</button>';
    html += '<button class="result-tab" data-type="secrets">秘方 (' + secrets.length + ')</button>';
    html += '<button class="result-tab" data-type="knowledge">知识库 (' + knowledge.length + ')</button>';
    html += '</div>';

    // Recipes
    if (recipes.length > 0) {
      html += '<div class="result-section" data-section="recipes">';
      html += '<h2 class="section-label">🍽 食谱</h2>';
      html += '<div class="grid-3">';
      recipes.forEach(r => {
        const coverUrl = (r.cover && (r.cover.url || r.cover.formats?.small?.url)) || '/images/default-recipe.jpg';
        const diff = r.difficulty === 'easy' ? '简单' : r.difficulty === 'medium' ? '中级' : '高级';
        html += '<a href="/recipes/' + r.slug + '" class="card recipe-card"><div class="card-img-wrap"><img src="' + coverUrl + '" alt="' + r.title + '" class="card-img" loading="lazy"/></div><div class="card-body"><h3 class="card-title">' + r.title + '</h3><div class="card-meta"><span>' + diff + '</span><span>⏱ ' + (r.cookTime || 0) + '分钟</span></div></div></a>';
      });
      html += '</div></div>';
    }

    // Ingredients
    if (ingredients.length > 0) {
      html += '<div class="result-section" data-section="ingredients">';
      html += '<h2 class="section-label">🥬 食材调料</h2>';
      html += '<div class="ingredient-results">';
      ingredients.forEach(ing => {
        const icon = ing.category === 'seasoning' ? '🧂' : '🥬';
        const desc = ing.description ? ing.description.substring(0, 80) : '';
        html += '<a href="/ingredients/' + ing.slug + '" class="ingredient-result-item"><span class="ing-icon">' + icon + '</span><div class="ing-info"><span class="ing-name">' + ing.name + '</span><span class="ing-desc">' + desc + '</span></div></a>';
      });
      html += '</div></div>';
    }

    // Secrets
    if (secrets.length > 0) {
      html += '<div class="result-section" data-section="secrets">';
      html += '<h2 class="section-label">🗝 秘方</h2>';
      html += '<div class="knowledge-list">';
      secrets.forEach(s => {
        html += '<a href="/secrets/' + s.slug + '" class="knowledge-item"><span class="knowledge-category" style="background:#FFF3E0;color:#E65100;">秘方</span><span class="knowledge-title">' + s.title + '</span></a>';
      });
      html += '</div></div>';
    }

    // Knowledge
    if (knowledge.length > 0) {
      html += '<div class="result-section" data-section="knowledge">';
      html += '<h2 class="section-label">📚 知识库</h2>';
      html += '<div class="knowledge-list">';
      knowledge.forEach(k => {
        html += '<a href="/knowledge/' + k.slug + '" class="knowledge-item"><span class="knowledge-category">' + k.category + '</span><span class="knowledge-title">' + k.title + '</span></a>';
      });
      html += '</div></div>';
    }

    resultsDiv.innerHTML = html;

    // Tab switching
    const tabs = resultsDiv.querySelectorAll('.result-tab');
    const sections = resultsDiv.querySelectorAll('.result-section');
    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        tabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        const tabType = tab.getAttribute('data-type');
        sections.forEach(section => {
          section.style.display = (tabType === 'all' || section.getAttribute('data-section') === tabType) ? '' : 'none';
        });
      });
    });
  }
</script>

<style>
  .page-title { font-size: 2rem; font-weight: 700; color: var(--color-title); margin-bottom: 24px; }

  .search-form { margin-bottom: 28px; }
  .search-row { display: flex; gap: 10px; margin-bottom: 12px; }
  .search-input {
    flex: 1; padding: 12px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 1rem; outline: none;
  }
  .search-input:focus { border-color: var(--color-accent); }
  .search-btn {
    padding: 12px 28px; background: var(--color-accent); color: #fff;
    border: none; border-radius: var(--radius); font-size: 1rem;
    cursor: pointer; font-weight: 600;
  }
  .search-btn:hover { opacity: 0.9; }
  .filter-row { display: flex; align-items: center; gap: 10px; }
  .filter-label { font-size: 0.85rem; color: var(--color-muted); }
  .filter-select {
    padding: 6px 12px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.85rem; outline: none;
  }

  .loading { text-align: center; padding: 40px; color: var(--color-muted); }
  .result-summary { font-size: 0.9rem; color: var(--color-muted); margin-bottom: 20px; }
  .result-summary strong { color: var(--color-accent); }

  .result-tabs { display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap; }
  .result-tab {
    padding: 6px 16px; border: 1px solid var(--color-border); border-radius: 100px;
    background: var(--color-bg); color: var(--color-text); font-size: 0.85rem;
    cursor: pointer; transition: all 0.2s;
  }
  .result-tab:hover { border-color: var(--color-accent); }
  .result-tab.active { background: var(--color-accent); color: #fff; border-color: var(--color-accent); }

  .section-label { font-size: 1.1rem; font-weight: 700; color: var(--color-title); margin-bottom: 16px; }

  .knowledge-list { display: flex; flex-direction: column; gap: 10px; }
  .knowledge-item {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 18px; background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius); text-decoration: none; color: inherit; transition: all 0.2s;
  }
  .knowledge-item:hover { border-color: var(--color-accent); }
  .knowledge-category {
    padding: 2px 10px; border-radius: 100px; font-size: 0.72rem;
    background: #E8F5E9; color: #2E7D32; flex-shrink: 0;
  }
  .knowledge-title { font-size: 0.95rem; font-weight: 500; }

  .ingredient-results { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 12px; }
  .ingredient-result-item {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 18px; background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius); text-decoration: none; color: inherit; transition: all 0.2s;
  }
  .ingredient-result-item:hover { border-color: var(--color-accent); }
  .ing-icon { font-size: 1.5rem; flex-shrink: 0; }
  .ing-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .ing-name { font-size: 0.95rem; font-weight: 600; }
  .ing-desc { font-size: 0.8rem; color: var(--color-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .no-results { text-align: center; padding: 60px 20px; color: var(--color-muted); }
  .no-results .hint { font-size: 0.85rem; margin-top: 8px; }
</style>
