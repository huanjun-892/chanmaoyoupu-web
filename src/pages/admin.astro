    function saveFriendLink() {
      const data = {
        name: document.getElementById('fl-name').value.trim(),
        url: document.getElementById('fl-url').value.trim(),
        logo: document.getElementById('fl-logo').value.trim(),
        description: document.getElementById('fl-description').value.trim(),
        sort_order: parseInt(document.getElementById('fl-sort').value) || 0,
        status: parseInt(document.getElementById('fl-status').value)
      };
      
      if (!data.name || !data.url) {
        showToast('名称和链接不能为空', 'error');
        return;
      }
      
      let url = API_BASE + '/friend-links';
      let method = 'POST';
      
      if (currentItem && currentItem.id) {
        url += '/' + currentItem.id;
        method = 'PUT';
      }
      
      fetch(url, {
        method: method,
        headers: { ...getAuthHeaders(), 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      }).then(res => res.json()).then(result => {
        if (result.success) {
          showToast(currentItem ? '更新成功' : '添加成功', 'success');
          closeModal();
          loadFriendLinks();
