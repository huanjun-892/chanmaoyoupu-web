    function showToast(message, type) {
      const toast = document.createElement('div');
      toast.className = 'toast toast-' + type;
      toast.textContent = message;
      document.body.appendChild(toast);
      
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transition = 'opacity 0.3s';
        setTimeout(() => toast.remove(), 300);
      }, 2000);
    }
    
    // 注意：移除点击遮罩关闭，避免resize或拖拽时误关闭
    // 改为只有点击关闭按钮或取消按钮才关闭
    
    // ============ 弹窗拖拽与大小调整 ============
    let isDragging = false;
    let dragOffsetX = 0;
    let dragOffsetY = 0;
    let modalContent = null;
    
    function initModalDrag() {
      const modal = document.getElementById('edit-modal');
      modalContent = modal.querySelector('.modal-content');
      const header = modal.querySelector('.modal-header');
      
      if (!header || !modalContent) return;
      
      // 拖拽开始
      header.addEventListener('mousedown', function(e) {
        // 点击关闭按钮不触发拖拽
        if (e.target.classList.contains('modal-close')) return;
        
        isDragging = true;
        modalContent.classList.add('dragging');
        
        // 获取当前渲染位置
        const rect = modalContent.getBoundingClientRect();
        
        // 从transform居中切换到绝对定位
        modalContent.style.transform = 'none';
        modalContent.style.left = rect.left + 'px';
        modalContent.style.top = rect.top + 'px';
        modalContent.style.right = 'auto';
        modalContent.style.bottom = 'auto';
        
        dragOffsetX = e.clientX - rect.left;
        dragOffsetY = e.clientY - rect.top;
        
        // 清除用户选择，避免拖拽时选中文字
        e.preventDefault();
      });
      
      // 拖拽移动
      document.addEventListener('mousemove', function(e) {
        if (!isDragging || !modalContent) return;
        e.preventDefault();
        
        let newX = e.clientX - dragOffsetX;
        let newY = e.clientY - dragOffsetY;
        
        // 限制在视口范围内（至少保留200px可见）
        const minX = -modalContent.offsetWidth + 200;
        const minY = 0;
        const maxX = window.innerWidth - 100;
        const maxY = window.innerHeight - 50;
        
        newX = Math.max(minX, Math.min(newX, maxX));
        newY = Math.max(minY, Math.min(newY, maxY));
        
        modalContent.style.left = newX + 'px';
        modalContent.style.top = newY + 'px';
      });
      
      // 拖拽结束
      document.addEventListener('mouseup', function() {
        if (isDragging) {
          isDragging = false;
          modalContent?.classList.remove('dragging');
        }
      });
      
      // 防止双击选中文字
      header.addEventListener('dblclick', function(e) {
        e.preventDefault();
      });
      
      // ========== 弹窗大小调整 ==========
      let isResizing = false;
      let resizeStartX = 0;
      let resizeStartY = 0;
      let resizeStartWidth = 0;
      let resizeStartHeight = 0;
      
      const resizeHandle = document.getElementById('modal-resize-handle');
      if (resizeHandle) {
        resizeHandle.addEventListener('mousedown', function(e) {
          e.stopPropagation();
          e.preventDefault();
          
          isResizing = true;
          resizeStartX = e.clientX;
          resizeStartY = e.clientY;
          
          // 确保使用绝对定位
          const rect = modalContent.getBoundingClientRect();
          modalContent.style.transform = 'none';
          modalContent.style.left = rect.left + 'px';
          modalContent.style.top = rect.top + 'px';
          modalContent.style.right = 'auto';
          modalContent.style.bottom = 'auto';
          
          resizeStartWidth = rect.width;
          resizeStartHeight = rect.height;
          
          document.body.style.cursor = 'se-resize';
          document.body.style.userSelect = 'none';
        });
        
        document.addEventListener('mousemove', function(e) {
          if (!isResizing || !modalContent) return;
          e.preventDefault();
          
          let deltaX = e.clientX - resizeStartX;
          let deltaY = e.clientY - resizeStartY;
          
          let newWidth = resizeStartWidth + deltaX;
          let newHeight = resizeStartHeight + deltaY;
          
          // 最小尺寸限制
          newWidth = Math.max(400, newWidth);
          newHeight = Math.max(300, newHeight);
          
          // 最大尺寸限制（不超过视口的95%）
          const maxWidth = window.innerWidth * 0.95;
          const maxHeight = window.innerHeight * 0.9;
          newWidth = Math.min(newWidth, maxWidth);
          newHeight = Math.min(newHeight, maxHeight);
          
          // 确保窗口不会被拖出视口右侧和底部
          const rect = modalContent.getBoundingClientRect();
          if (rect.left + newWidth > window.innerWidth - 10) {
            newWidth = window.innerWidth - rect.left - 10;
          }
          if (rect.top + newHeight > window.innerHeight - 10) {
            newHeight = window.innerHeight - rect.top - 10;
          }
          
          modalContent.style.width = newWidth + 'px';
          modalContent.style.height = newHeight + 'px';
        });
        
        document.addEventListener('mouseup', function() {
          if (isResizing) {
            isResizing = false;
            document.body.style.cursor = '';
            document.body.style.userSelect = '';
          }
        });
      }
      
      // 监听窗口大小变化，确保弹窗不超出边界
      window.addEventListener('resize', function() {
        if (!modalContent || !document.getElementById('edit-modal').classList.contains('show')) return;
        
        // 如果使用绝对定位的弹窗，确保在视口范围内
        const rect = modalContent.getBoundingClientRect();
        let newLeft = rect.left;
        let newTop = rect.top;
        
        if (rect.right < 100) {
          newLeft = 100 - rect.width;
        } else if (rect.left > window.innerWidth - 100) {
          newLeft = window.innerWidth - 100;
        }
        
        if (rect.bottom < 50) {
          newTop = 50 - rect.height;
        } else if (rect.top > window.innerHeight - 50) {
          newTop = window.innerHeight - 50;
        }
        
        if (newLeft !== rect.left || newTop !== rect.top) {
          modalContent.style.left = newLeft + 'px';
          modalContent.style.top = newTop + 'px';
        }
      });
    }
    
    // 重置弹窗位置（打开新弹窗时调用）
    function resetModalPosition() {
      const modal = document.getElementById('edit-modal');
      const content = modal.querySelector('.modal-content');
