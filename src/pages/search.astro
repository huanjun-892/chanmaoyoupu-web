---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getAllRecipes, difficultyLabel, getCoverUrl } from '../lib/strapi';

const recipes = await getAllRecipes();
const recipeData = recipes.map((r: any) => ({
  title: r.title,
  slug: r.slug,
  difficulty: difficultyLabel(r.difficulty),
  cookTime: r.cookTime,
  calories: r.calories,
  tags: (r.tags || []).map((t: any) => t.name),
  cuisine: r.cuisine?.name || '',
  cover: getCoverUrl(r.cover),
  description: r.description || '',
  ingredientNames: (r.ingredients || []).map((i: any) => i.name).join(','),
}));
---

<BaseLayout title="搜索">

  <section class="section">
    <div class="container">
      <h1 class="page-title">搜索食谱</h1>

      <div class="search-box">
        <input type="text" id="search-input" placeholder="输入菜名、食材、菜系..." class="search-input" />
      </div>

      <div id="results" class="grid-3">
        {recipeData.map((recipe: any) => (
          <div class="search-item"
            data-title={recipe.title}
            data-cuisine={recipe.cuisine}
            data-ingredients={recipe.ingredientNames}
            data-tags={recipe.tags.join(',')}
            data-desc={recipe.description}>
            <RecipeCard {...recipe} />
          </div>
        ))}
      </div>

      <div class="empty-state" id="empty-state" style="display:none;">
        <p>没有找到相关食谱，换个关键词试试？</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('search-input') as HTMLInputElement;
  const items = document.querySelectorAll('.search-item');
  const emptyEl = document.getElementById('empty-state');

  // URL参数
  const params = new URLSearchParams(window.location.search);
  if (params.has('q')) {
    input.value = params.get('q') || '';
    doSearch(input.value);
  }

  input.addEventListener('input', () => {
    doSearch(input.value);
  });

  function doSearch(query: string) {
    const q = query.trim().toLowerCase();
    let count = 0;
    items.forEach((item) => {
      const el = item as HTMLElement;
      if (!q) {
        el.style.display = '';
        count++;
        return;
      }
      const title = el.dataset.title?.toLowerCase() || '';
      const cuisine = el.dataset.cuisine?.toLowerCase() || '';
      const ingredients = el.dataset.ingredients?.toLowerCase() || '';
      const tags = el.dataset.tags?.toLowerCase() || '';
      const desc = el.dataset.desc?.toLowerCase() || '';

      const match = title.includes(q) || cuisine.includes(q) || ingredients.includes(q) || tags.includes(q) || desc.includes(q);
      el.style.display = match ? '' : 'none';
      if (match) count++;
    });
    if (emptyEl) emptyEl.style.display = count === 0 ? 'block' : 'none';
  }
</script>

<style>
  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-title);
    margin-bottom: 24px;
  }

  .search-box {
    margin-bottom: 32px;
  }

  .search-input {
    width: 100%;
    max-width: 600px;
    padding: 14px 20px;
    border: 1.5px solid var(--color-border);
    border-radius: 100px;
    font-size: 1rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .search-input:focus {
    border-color: var(--color-accent);
  }

  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--color-muted);
  }
</style>
