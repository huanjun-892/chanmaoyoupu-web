    // ============ 推送助手 ============
    function selectPlatform(platform) {
      currentPlatform = platform;
      document.querySelectorAll('#page-push .stat-card').forEach(card => {
        card.style.borderColor = 'var(--color-border)';
      });
      event.currentTarget.style.borderColor = 'var(--color-accent)';
      generatePushContent();
    }
    
    function loadPushContentOptions() {
      const type = document.getElementById('push-content-type').value;
      const select = document.getElementById('push-content-select');
      
      const url = type === 'recipe' 
        ? API_BASE + '/recipes?limit=50' 
        : API_BASE + '/knowledge?limit=50';
      
      fetch(url, { headers: getAuthHeaders() })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            select.innerHTML = '<option value="">请选择内容</option>';
            data.data.items.forEach(item => {
              select.innerHTML += `<option value="${item.id}">${item.title}</option>`;
            });
          }
        });
    }
    
    function loadPushContent() {
      loadPushContentOptions();
      document.getElementById('push-content-result').value = '';
    }
    
    function generatePushContent() {
      const type = document.getElementById('push-content-type').value;
      const id = document.getElementById('push-content-select').value;
      if (!id) return;
      
      const detailUrl = type === 'recipe' 
        ? API_BASE + '/recipes/' + id 
        : API_BASE + '/knowledge/' + id;
      
      fetch(detailUrl, { headers: getAuthHeaders() })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            const content = generatePlatformContent(data.data, type, currentPlatform);
            document.getElementById('push-content-result').value = content;
          }
        });
    }
    
    function generatePlatformContent(item, type, platform) {
      const title = item.title;
      const desc = item.description || item.summary || '';
      
      const platformStyles = {
        wechat: {
          prefix: '🍜 ',
          suffix: '\n\n— END —\n喜欢的话记得点赞+在看哦～\n关注「馋猫有谱」，每天学一道家常菜',
          style: '公众号风格，段落分明，语气亲切'
        },
        xiaohongshu: {
          prefix: '🔥 ',
          suffix: '\n\n#美食教程 #家常菜 #食谱分享 #做饭教程 #美食日常 #吃货薯',
          style: '小红书风格，emoji丰富，口语化，有吸引力'
        },
        douyin: {
          prefix: '',
          suffix: '\n\n喜欢的话记得点赞关注哦 👆',
          style: '短视频口播文案，口语化，有节奏感'
        },
        toutiao: {
          prefix: '',
          suffix: '\n\n—— 馋猫有谱 · 专注家常美食 ——',
          style: '头条风格，信息密度高，结构清晰'
        },
        bilibili: {
          prefix: '',
          suffix: '\n\n觉得有用的话记得一键三连哦～ 支持一下up主！',
          style: 'B站风格，轻松活泼，有网感'
        }
      };
      
      const style = platformStyles[platform] || platformStyles.wechat;
      
      if (type === 'recipe') {
        const ingredients = item.ingredients || [];
        const steps = item.steps || [];
        
        let content = style.prefix + title + '\n\n';
        content += '📝 食材清单：\n';
        ingredients.forEach(ing => {
          content += '• ' + ing.name + '：' + (ing.amount || '适量') + '\n';
        });
        
        content += '\n👨‍🍳 做法步骤：\n';
        steps.forEach((step, idx) => {
          content += (idx + 1) + '. ' + (step.text || step.description || '') + '\n';
        });
        
        content += '\n💡 小贴士：\n';
        content += (item.success_tips || item.tips || '根据个人口味调整盐和调料的用量～') + '\n';
        content += style.suffix;
        
        return content;
      } else {
        let content = style.prefix + title + '\n\n';
        content += (item.content || desc) + '\n\n';
        content += style.suffix;
        return content;
      }
    }
    
    function copyPushContent() {
      const text = document.getElementById('push-content-result').value;
      if (!text) {
        showToast('请先生成内容', 'error');
        return;
      }
      
      navigator.clipboard.writeText(text).then(() => {
        showToast('已复制到剪贴板', 'success');
      }).catch(() => {
        const textarea = document.getElementById('push-content-result');
        textarea.select();
        document.execCommand('copy');
        showToast('已复制到剪贴板', 'success');
      });
    }
    
    // ============ 通用功能 ============
    function saveItem() {
      let data = {};
      let url = API_BASE + '/' + currentItemType + 's';
      let method = 'POST';
      
      if (currentItemType === 'recipe') {
        // 收集食材
        const ingredients = [];
        const ingredientRows = document.querySelectorAll('#ingredients-list .ingredient-row');
        ingredientRows.forEach((row, idx) => {
          const inputs = row.querySelectorAll('input');
          const name = inputs[0]?.value.trim();
          const amount = inputs[1]?.value.trim();
          if (name) {
            ingredients.push({ name, amount, sort_order: idx + 1 });
          }
        });
        
        // 收集步骤
        const steps = [];
        const stepRows = document.querySelectorAll('#steps-list .step-row');
        stepRows.forEach((row, idx) => {
          const textarea = row.querySelector('textarea');
          const text = textarea?.value.trim();
          if (text) {
            steps.push({ step_number: idx + 1, text });
          }
        });
        
        const cuisineVal = document.getElementById('recipe-cuisine').value;
        data = {
          title: document.getElementById('recipe-title').value,
          slug: document.getElementById('recipe-slug').value,
          description: getQuillContent('recipe-description'),
          difficulty: document.getElementById('recipe-difficulty').value,
          cook_time: parseInt(document.getElementById('recipe-cooktime').value) || 0,
          servings: parseInt(document.getElementById('recipe-servings').value) || 1,
          calories: parseInt(document.getElementById('recipe-calories').value) || 0,
          cuisine_id: cuisineVal ? parseInt(cuisineVal) : null,
          cover_url: document.getElementById('recipe-cover').value,
          published: parseInt(document.getElementById('recipe-published').value),
          nutrition: getQuillContent('recipe-nutrition'),
          common_mistakes: getQuillContent('recipe-common-mistakes'),
          success_tips: getQuillContent('recipe-success-tips'),
          ingredient_substitutes: getQuillContent('recipe-substitutes'),
          suitable_for: getQuillContent('recipe-suitable-for'),
          required_tools: getQuillContent('recipe-required-tools'),
          ingredients: ingredients,
          steps: steps
        };
      } else if (currentItemType === 'ingredient') {
        data = {
          name: document.getElementById('ingredient-name').value,
          slug: document.getElementById('ingredient-slug').value,
          category: document.getElementById('ingredient-category').value,
          image_url: document.getElementById('ingredient-image').value,
          description: getQuillContent('ingredient-description')
        };
      } else if (currentItemType === 'knowledge') {
        data = {
          title: document.getElementById('knowledge-title').value,
          slug: document.getElementById('knowledge-slug').value,
          category: document.getElementById('knowledge-category-form').value,
          summary: getQuillContent('knowledge-summary'),
          content: getQuillContent('knowledge-content')
        };
      } else if (currentItemType === 'cuisine') {
        data = {
          name: document.getElementById('cuisine-name').value,
          slug: document.getElementById('cuisine-slug').value,
          description: getQuillContent('cuisine-description'),
          sort_order: parseInt(document.getElementById('cuisine-sort').value) || 0
        };
      } else if (currentItemType === 'tag') {
        data = {
          name: document.getElementById('tag-name').value,
          slug: document.getElementById('tag-slug').value,
          icon: document.getElementById('tag-icon').value
        };
      } else if (currentItemType === 'region') {
        data = {
          name: document.getElementById('region-name').value
        };
      } else if (currentItemType === 'method') {
        data = {
          name: document.getElementById('method-name').value
        };
      }
      
      if (currentItem && currentItem.id) {
        url += '/' + currentItem.id;
        method = 'PUT';
      }
      
      fetch(url, {
        method: method,
        headers: getAuthHeaders(),
        body: JSON.stringify(data)
      }).then(res => res.json()).then(result => {
        if (result.success) {
          showToast('保存成功', 'success');
          closeModal();
          if (currentItemType === 'recipe') loadRecipes();
          else if (currentItemType === 'ingredient') loadIngredients();
          else if (currentItemType === 'knowledge') loadKnowledge();
          else if (currentItemType === 'cuisine') loadCuisines();
          else if (currentItemType === 'tag') loadTags();
          else if (currentItemType === 'region') loadRegions();
          else if (currentItemType === 'method') loadMethods();
          loadStats();
        } else {
          showToast(result.error || '保存失败', 'error');
        }
      });
    }
    
    function renderPagination(type, data) {
      const container = document.getElementById(type + '-pagination');
      const totalPages = data.pages || 1;
      const current = data.page || 1;
      
      let html = '<span class="page-info">共 ' + data.total + ' 条，第 ' + current + '/' + totalPages + ' 页</span>';
      html += '<button onclick="goToPage(\'' + type + '\', 1)" ' + (current === 1 ? 'disabled' : '') + '>首页</button>';
      html += '<button onclick="goToPage(\'' + type + '\', ' + (current - 1) + ')" ' + (current === 1 ? 'disabled' : '') + '>上一页</button>';
      html += '<button onclick="goToPage(\'' + type + '\', ' + (current + 1) + ')" ' + (current >= totalPages ? 'disabled' : '') + '>下一页</button>';
      html += '<button onclick="goToPage(\'' + type + '\', ' + totalPages + ')" ' + (current >= totalPages ? 'disabled' : '') + '>末页</button>';
      
      container.innerHTML = html;
    }
    
    function goToPage(type, page) {
      currentPage[type] = page;
      if (type === 'recipes') loadRecipes();
      else if (type === 'ingredients') loadIngredients();
      else if (type === 'knowledge') loadKnowledge();
    }
    
    function closeModal() {
      // 先销毁所有富文本编辑器实例
      destroyQuillEditors();
      document.getElementById('edit-modal').classList.remove('show');
      // 重置弹窗底部按钮为默认状态（取消+保存）
      const footer = document.getElementById('modal-footer');
      footer.innerHTML = `
        <button class="btn btn-secondary" onclick="closeModal()">取消</button>
        <button class="btn btn-primary" onclick="saveItem()">保存</button>
      `;
      currentItem = null;
      currentItemType = null;
    }
    
    function showToast(message, type) {
      const toast = document.createElement('div');
      toast.className = 'toast toast-' + type;
      toast.textContent = message;
      document.body.appendChild(toast);
      
      setTimeout(() => {
        toast.style.opacity = '0';
        toast.style.transition = 'opacity 0.3s';
        setTimeout(() => toast.remove(), 300);
      }, 2000);
    }
    
    // 点击遮罩关闭弹窗
    const editModal = document.getElementById('edit-modal');
    if (editModal) {
      editModal.addEventListener('click', function(e) {
        if (e.target === this) closeModal();
      });
    }
  </script>
</BaseLayout>
