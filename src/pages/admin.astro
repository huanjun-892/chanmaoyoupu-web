      let url = API_BASE + '/banners';
      let method = 'POST';
      
      if (currentItem && currentItem.id) {
        url += '/' + currentItem.id;
        method = 'PUT';
      }
      
      fetch(url, {
        method: method,
        headers: { ...getAuthHeaders(), 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      }).then(res => res.json()).then(result => {
        if (result.success) {
          showToast(currentItem ? '更新成功' : '添加成功', 'success');
