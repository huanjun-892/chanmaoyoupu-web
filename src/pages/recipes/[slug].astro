---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getAllRecipes, getRecipeBySlug, difficultyLabel, difficultyColor } from '../../lib/strapi';

export async function getStaticPaths() {
  const recipes = await getAllRecipes();
  return recipes.map((r: any) => ({
    params: { slug: r.slug },
  }));
}

const { slug } = Astro.params;
const recipe = await getRecipeBySlug(slug as string);

if (!recipe) {
  return Astro.redirect('/recipes');
}

const ingredients = recipe.ingredients || [];
const steps = (recipe.steps || []).sort((a: any, b: any) => a.stepNumber - b.stepNumber);
const relatedRecipes = recipe.relatedRecipes || [];
---

<BaseLayout title={recipe.title}>
  <Header />

  <article class="recipe-detail">
    <div class="container">
      <!-- 面包屑 -->
      <nav class="breadcrumb">
        <a href="/">首页</a>
        <span class="sep">/</span>
        <a href="/recipes">食谱</a>
        <span class="sep">/</span>
        <span>{recipe.title}</span>
      </nav>

      <!-- 头部信息 -->
      <div class="recipe-header">
        <div class="recipe-header-left">
          <div class="recipe-tags">
            {recipe.cuisine && <a href={`/recipes?cuisine=${recipe.cuisine.name}`} class="tag-cuisine">{recipe.cuisine.name}</a>}
            {(recipe.methods || []).map((m: any) => (
              <span class="tag-method">{m.name}</span>
            ))}
            {(recipe.tags || []).map((t: any) => (
              <span class="tag-scene">{t.icon} {t.name}</span>
            ))}
          </div>
          <h1 class="recipe-title">{recipe.title}</h1>
          <p class="recipe-desc">{recipe.description}</p>
          <div class="recipe-meta">
            <span class="meta-item">
              <span class="meta-label">难度</span>
              <span class="meta-value" style={`color: ${difficultyColor(recipe.difficulty)}`}>{difficultyLabel(recipe.difficulty)}</span>
            </span>
            <span class="meta-item">
              <span class="meta-label">烹饪</span>
              <span class="meta-value">{recipe.cookTime}分钟</span>
            </span>
            <span class="meta-item">
              <span class="meta-label">份量</span>
              <span class="meta-value">{recipe.servings}人份</span>
            </span>
            {recipe.calories && (
            <span class="meta-item">
              <span class="meta-label">热量</span>
              <span class="meta-value">{recipe.calories}千卡</span>
            </span>
            )}
          </div>
        </div>
      </div>

      <!-- 主体两栏 -->
      <div class="recipe-body">
        <!-- 左栏：步骤 -->
        <div class="recipe-main">
          <section class="recipe-section">
            <h2 class="section-heading">制作步骤</h2>
            <div class="steps">
              {steps.map((step: any, i: number) => (
                <div class="step">
                  <div class="step-num">{step.stepNumber}</div>
                  <div class="step-content">
                    <p class="step-desc">{step.description}</p>
                    {step.tip && <p class="step-tip">💡 {step.tip}</p>}
                  </div>
                </div>
              ))}
            </div>
          </section>
        </div>

        <!-- 右栏：用料 -->
        <aside class="recipe-sidebar">
          <section class="recipe-section sidebar-section">
            <h2 class="section-heading">用料清单</h2>
            <ul class="ingredient-list">
              {ingredients.map((ing: any) => (
                <li class={`ingredient-item ${ing.isMain ? '' : 'ingredient-minor'}`}>
                  <span class="ingredient-name">{ing.name}</span>
                  <span class="ingredient-amount">{ing.amount}</span>
                </li>
              ))}
            </ul>
          </section>

          {(recipe.regions && recipe.regions.length > 0) && (
          <section class="recipe-section sidebar-section">
            <h2 class="section-heading">地域</h2>
            <div class="region-list">
              {recipe.regions.map((r: any) => (
                <span class="region-tag">{r.name}</span>
              ))}
            </div>
          </section>
          )}
        </aside>
      </div>

      <!-- 相关食谱 -->
      {relatedRecipes.length > 0 && (
      <section class="recipe-related">
        <h2 class="section-heading">相关食谱</h2>
        <div class="grid-3">
          {relatedRecipes.slice(0, 3).map((r: any) => (
            <RecipeCard
              title={r.title}
              slug={r.slug}
              difficulty={difficultyLabel(r.difficulty)}
              cookTime={r.cookTime}
              calories={r.calories}
              tags={[]}
              cover={r.cover?.url || null}
            />
          ))}
        </div>
      </section>
      )}
    </div>
  </article>

  <Footer />
</BaseLayout>

<style>
  .recipe-detail { padding-top: 24px; }

  .breadcrumb {
    font-size: 0.82rem;
    color: var(--color-muted);
    margin-bottom: 24px;
  }
  .breadcrumb a { color: var(--color-muted); transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .breadcrumb .sep { margin: 0 6px; }

  .recipe-header {
    margin-bottom: 40px;
  }

  .recipe-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 12px;
  }

  .tag-cuisine, .tag-method, .tag-scene {
    padding: 3px 12px;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 500;
  }
  .tag-cuisine {
    background: #FFF3E0;
    color: #E65100;
  }
  .tag-method {
    background: #E8F5E9;
    color: #2E7D32;
  }
  .tag-scene {
    background: #F3E5F5;
    color: #6A1B9A;
  }
  .tag-cuisine:hover { background: #FFE0B2; }

  .recipe-title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-title);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .recipe-desc {
    font-size: 1rem;
    color: var(--color-muted);
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .recipe-meta {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .meta-label {
    font-size: 0.75rem;
    color: var(--color-muted);
  }

  .meta-value {
    font-size: 1rem;
    font-weight: 600;
  }

  /* Two column layout */
  .recipe-body {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 40px;
    margin-bottom: 48px;
  }

  .section-heading {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-title);
    margin-bottom: 20px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--color-accent);
    display: inline-block;
  }

  /* Steps */
  .steps {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .step {
    display: flex;
    gap: 16px;
  }

  .step-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .step-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-top: 5px;
  }

  .step-tip {
    margin-top: 6px;
    font-size: 0.85rem;
    color: var(--color-accent);
    background: var(--color-accent-light);
    padding: 6px 12px;
    border-radius: 6px;
  }

  /* Sidebar - Ingredients */
  .sidebar-section {
    background: var(--color-bg-warm);
    padding: 20px;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    margin-bottom: 20px;
  }

  .ingredient-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ingredient-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0;
    border-bottom: 1px dashed var(--color-border);
    font-size: 0.9rem;
  }

  .ingredient-item:last-child {
    border-bottom: none;
  }

  .ingredient-minor {
    color: var(--color-muted);
  }

  .ingredient-name {
    color: var(--color-text);
  }

  .ingredient-amount {
    color: var(--color-accent);
    font-weight: 500;
  }

  .region-list {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .region-tag {
    padding: 4px 12px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.82rem;
    color: var(--color-text);
  }

  .recipe-related {
    margin-top: 40px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .recipe-body {
      grid-template-columns: 1fr;
    }
    .recipe-title {
      font-size: 1.5rem;
    }
    .recipe-meta {
      gap: 16px;
    }
  }
</style>
