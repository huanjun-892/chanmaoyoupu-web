---
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/images/logo-small.png" alt="馋猫有谱" class="logo-icon" width="36" height="36" />
      <span class="logo-text">馋猫有谱</span>
    </a>
    <nav class="nav">
      <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>首页</a>
      <a href="/recipes" class:list={['nav-link', { active: currentPath.startsWith('/recipes') }]}>食谱</a>
      <a href="/secrets" class:list={['nav-link', { active: currentPath.startsWith('/secrets') }]}>秘方</a>
      <a href="/knowledge" class:list={['nav-link', { active: currentPath.startsWith('/knowledge') }]}>知识库</a>
      <a href="/rankings" class:list={['nav-link', { active: currentPath === '/rankings' }]}>排行榜</a>
    </nav>
    <div class="header-right">
      <form action="/search" method="get" class="search-box">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" placeholder="搜食谱、食材..." class="search-input" />
      </form>
      <button id="auth-btn" class="auth-btn" onclick="openLoginModal()">登录</button>
    
      <!-- 已登录用户菜单 -->
      <div id="user-menu" class="user-menu" style="display: none;">
        <button class="user-menu-trigger" onclick="toggleUserDropdown()">
          <img id="header-user-avatar" src="/images/default-avatar.jpg" alt="头像" class="header-avatar" />
          <svg class="dropdown-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5l3 3 3-3"/></svg>
        </button>
        
        <div id="user-dropdown" class="user-dropdown">
          <div class="dropdown-header" onclick="openProfileModal()">
            <img id="user-dropdown-avatar" src="/images/default-avatar.jpg" alt="头像" class="dropdown-avatar" />
            <div class="dropdown-user-info">
              <span id="user-dropdown-nickname" class="dropdown-nickname">用户</span>
              <span class="dropdown-edit-profile">查看/修改资料 ›</span>
            </div>
          </div>
          <div class="dropdown-divider"></div>
          <a href="/profile/favorites" class="dropdown-item">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            我的收藏
          </a>
          <a href="/rankings" class="dropdown-item">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M8 21h12M12 17v4M6 13l2-8h8l2 8M2 21h4"/><circle cx="12" cy="7" r="3"/></svg>
            排行榜
          </a>
          <div class="dropdown-divider"></div>
          <button class="dropdown-item logout-item" onclick="handleLogout()">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            退出登录
          </button>
        </div>
      </div>
    </div>
  </div>
</header>