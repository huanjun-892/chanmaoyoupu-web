---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllKnowledge, processContent } from '../../lib/strapi';

export async function getStaticPaths() {
  const knowledgeItems = await getAllKnowledge();
  if (knowledgeItems.length === 0) {
    return [];
  }
  // 只生成秘方条目的路径
  const secretItems = knowledgeItems.filter((k: any) => k.category === 'secret');
  return secretItems.map((k: any) => ({
    params: { slug: k.slug },
  }));
}

const { slug } = Astro.params;
const knowledgeItems = await getAllKnowledge();
const entry = knowledgeItems.find((k: any) => k.slug === slug);

if (!entry) {
  return Astro.redirect('/secrets');
}

// 获取其他秘方作为推荐
const otherSecrets = knowledgeItems
  .filter((k: any) => k.category === 'secret' && k.slug !== slug)
  .slice(0, 4);
---

<BaseLayout title={entry.title}>
  
  <article class="secret-detail">
    <div class="container">
      <div class="secret-breadcrumb">
        <a href="/secrets">秘方</a> <span class="sep">›</span> <span>{entry.title}</span>
      </div>

      <div class="secret-header">
        <span class="tag">🗝️ 秘方</span>
        <h1 class="secret-title">{entry.title}</h1>
      </div>

      <div class="secret-body" set:html={processContent(entry.content || '')} />

      {otherSecrets.length > 0 && (
      <div class="related-secrets">
        <h3 class="related-title">更多秘方</h3>
        <div class="related-grid">
          {otherSecrets.map((k: any) => (
            <a href={`/secrets/${k.slug}`} class="related-card">
              <h4>{k.title}</h4>
              <span>查看 →</span>
            </a>
          ))}
        </div>
      </div>
      )}
    </div>
  </article>

</BaseLayout>

<style>
  .secret-detail { padding-top: 40px; }
  
  .secret-breadcrumb {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 24px;
  }
  .secret-breadcrumb a { color: var(--color-accent); text-decoration: none; }
  .secret-breadcrumb a:hover { text-decoration: underline; }
  .secret-breadcrumb .sep { margin: 0 8px; }

  .secret-header { margin-bottom: 40px; }
  .secret-title { font-size: 2rem; font-weight: 700; color: var(--color-title); margin-top: 12px; }

  .secret-body { max-width: 720px; font-size: 0.95rem; line-height: 1.9; color: var(--color-text); }
  .secret-body :global(h2) { font-size: 1.3rem; font-weight: 600; color: var(--color-title); margin: 36px 0 16px; padding-left: 12px; border-left: 3px solid var(--color-accent); }
  .secret-body :global(h3) { font-size: 1.15rem; font-weight: 600; color: var(--color-title); margin: 28px 0 12px; }
  .secret-body :global(h4) { font-size: 1rem; font-weight: 600; color: var(--color-title); margin: 20px 0 8px; }
  .secret-body :global(p) { margin-bottom: 12px; }
  .secret-body :global(strong) { color: var(--color-title); }
  .secret-body :global(table) { width: 100%; border-collapse: collapse; margin: 16px 0; font-size: 0.9rem; }
  .secret-body :global(th) { background: var(--color-bg-warm); padding: 8px 12px; text-align: left; font-weight: 600; }
  .secret-body :global(td) { padding: 8px 12px; border-bottom: 1px solid var(--color-border); }
  .secret-body :global(ul) { margin-bottom: 16px; padding-left: 24px; }
  .secret-body :global(li) { margin-bottom: 6px; }

  .related-secrets {
    margin-top: 60px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }
  .related-title { font-size: 1.1rem; font-weight: 600; color: var(--color-title); margin-bottom: 16px; }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .related-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all 0.2s;
    text-decoration: none;
  }
  .related-card:hover {
    border-color: var(--color-accent);
  }
  .related-card h4 {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-title);
    margin: 0;
  }
  .related-card span {
    font-size: 0.85rem;
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>