---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import RecipeCard from '../components/RecipeCard.astro';
import KnowledgeCard from '../components/KnowledgeCard.astro';
import { getAllRecipes, getAllKnowledge, difficultyLabel, getCoverUrl } from '../lib/strapi';

const allRecipes = await getAllRecipes();
const knowledgeItems = await getAllKnowledge();

// 最新2道作为"今日上新"
const newRecipes = allRecipes.slice(0, 2).map(r => ({
  title: r.title,
  slug: r.slug,
  difficulty: difficultyLabel(r.difficulty),
  cookTime: r.cookTime,
  calories: r.calories,
  tags: (r.tags || []).map((t: any) => t.name),
  regions: (r.regions || []).map((rg: any) => rg.name),
  cover: getCoverUrl(r.cover),
}));

// 接下来3道作为"热门食谱"
const featuredRecipes = allRecipes.slice(2, 5).map(r => ({
  title: r.title,
  slug: r.slug,
  difficulty: difficultyLabel(r.difficulty),
  cookTime: r.cookTime,
  calories: r.calories,
  tags: (r.tags || []).map((t: any) => t.name),
  regions: (r.regions || []).map((rg: any) => rg.name),
  cover: getCoverUrl(r.cover),
}));

// 知识库精选（非秘方）
const knowledgeFeatured = knowledgeItems
  .filter((k: any) => k.category !== 'secret')
  .slice(0, 2)
  .map((k: any) => ({
    title: k.title,
    slug: k.slug,
    category: k.category,
    excerpt: k.content ? k.content.replace(/<[^>]*>/g, '').slice(0, 80) + '...' : '',
  }));

// 秘方精选
const secretsFeatured = knowledgeItems
  .filter((k: any) => k.category === 'secret')
  .slice(0, 4)
  .map((k: any) => ({
    title: k.title,
    slug: k.slug,
    excerpt: k.content ? k.content.replace(/<[^>]*>/g, '').slice(0, 60) + '...' : '',
  }));
---

<BaseLayout title="首页">

  <!-- Hero区 -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <div class="hero-badge">食谱 + 食材 + 秘方 + 知识库</div>
        <h1 class="hero-title">
          <span class="char-highlight">馋</span>得明白<br/>
          做得靠<span class="char-highlight">谱</span>
        </h1>
        <p class="hero-manifesto">
          他做的好，无非<span class="manifesto-highlight">靠谱</span><br/>
          只要<span class="char-highlight">有谱</span>，你也可以
        </p>
        <p class="hero-desc">详细步骤、食材百科、专业美食知识库<br/>小白也能做出好味道</p>
        <form action="/search" method="get" class="hero-search">
          <svg class="hero-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" name="q" placeholder="搜索菜名、食材、菜系..." class="hero-search-input" />
          <button type="submit" class="btn btn-primary">搜索</button>
        </form>
        <div class="hero-hot">
          <span class="hero-hot-label">热门：</span>
          <a href="/recipes?cuisine=川菜">川菜</a>
          <a href="/ingredients">食材</a>
          <a href="/secrets">秘方</a>
          <a href="/recipes?difficulty=easy">新手菜</a>
        </div>
      </div>
      <div class="hero-illustration">
        <img src="/images/logo.png?v=3" alt="馋猫有谱" class="hero-cat" />
      </div>
    </div>
  </section>

  <!-- 分类入口 -->
  <CategoryGrid />

  <!-- 今日上新 -->
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">今日上新</h2>
        <a href="/recipes" class="view-all">查看全部 →</a>
      </div>
      <div class="grid-2">
        {newRecipes.map((recipe) => (
          <RecipeCard {...recipe} />
        ))}
      </div>
    </div>
  </section>

  <!-- 热门食谱 -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">热门食谱</h2>
        <a href="/recipes" class="view-all">更多食谱 →</a>
      </div>
      <div class="grid-3">
        {featuredRecipes.map((recipe) => (
          <RecipeCard {...recipe} />
        ))}
      </div>
    </div>
  </section>

  <!-- 秘方精选 -->
  {secretsFeatured.length > 0 && (
  <section class="section">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">🗝️ 秘方精选</h2>
        <a href="/secrets" class="view-all">全部秘方 →</a>
      </div>
      <div class="secrets-featured-grid">
        {secretsFeatured.map((item) => (
          <a href={`/secrets/${item.slug}`} class="secret-featured-card">
            <h3>{item.title}</h3>
            <p>{item.excerpt}</p>
            <span class="secret-link">查看秘方 →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
  )}

  <!-- 知识库精选 -->
  {knowledgeFeatured.length > 0 && (
  <section class="section section-alt">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">知识库精选</h2>
        <a href="/knowledge" class="view-all">进入知识库 →</a>
      </div>
      <div class="grid-2">
        {knowledgeFeatured.map((item) => (
          <KnowledgeCard {...item} />
        ))}
      </div>
    </div>
  </section>
  )}
</BaseLayout>

<style>
  /* Hero */
  .hero {
    padding: 88px 0 72px;
    background: #FFFFFF;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    top: -40%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(255, 140, 66, 0.03) 0%, transparent 70%);
    border-radius: 50%;
  }
  .hero-inner { display: flex; align-items: center; gap: 60px; position: relative; }
  .hero-text { flex: 1; max-width: 520px; }
  .hero-badge { display: inline-block; padding: 5px 14px; background: var(--color-accent-light); color: var(--color-accent); border-radius: 100px; font-size: 0.76rem; font-weight: 600; letter-spacing: 0.04em; margin-bottom: 20px; }
  .hero-title { font-size: 3.2rem; font-weight: 800; color: var(--color-title); line-height: 1.18; margin-bottom: 18px; letter-spacing: -0.02em; }
  .char-highlight { color: var(--color-accent); }
  .hero-manifesto { font-size: 1.15rem; color: var(--color-text); margin-bottom: 10px; margin-top: 6px; line-height: 1.7; font-weight: 400; letter-spacing: 0.03em; }
  .manifesto-highlight { color: var(--color-accent); font-weight: 700; }
  .hero-desc { font-size: 1.05rem; color: var(--color-muted); margin-bottom: 32px; line-height: 1.7; }
  .hero-search { display: flex; gap: 10px; background: var(--color-bg); border: 1.5px solid var(--color-border); border-radius: 100px; padding: 5px 5px 5px 18px; box-shadow: var(--shadow-sm); transition: all 0.25s; }
  .hero-search:focus-within { border-color: var(--color-accent); box-shadow: 0 0 0 3px var(--color-accent-light); }
  .hero-search-icon { color: var(--color-muted); flex-shrink: 0; margin-top: 10px; }
  .hero-search-input { flex: 1; border: none; background: transparent; outline: none; font-size: 0.95rem; color: var(--color-text); }
  .hero-search-input::placeholder { color: var(--color-muted); }
  .hero-search .btn { flex-shrink: 0; padding: 10px 24px; }
  .hero-hot { display: flex; align-items: center; gap: 16px; margin-top: 18px; font-size: 0.82rem; }
  .hero-hot-label { color: var(--color-muted); }
  .hero-hot a { color: var(--color-text); transition: color 0.2s; }
  .hero-hot a:hover { color: var(--color-accent); }
  .hero-illustration { flex-shrink: 0; width: 220px; display: flex; align-items: center; justify-content: center; }
  .hero-cat { object-fit: contain; width: 200px; height: 200px; filter: drop-shadow(0 4px 20px rgba(255, 140, 66, 0.15)); }

  /* Section header */
  .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }
  .section-header .section-title { margin-bottom: 0; }
  .view-all { font-size: 0.82rem; font-weight: 500; color: var(--color-accent); transition: opacity 0.2s; }
  .view-all:hover { opacity: 0.7; }
  .section-alt { background: #F8F9FA; }

  /* 秘方精选 */
  .secrets-featured-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .secret-featured-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all 0.25s;
    text-decoration: none;
  }
  .secret-featured-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(255, 107, 53, 0.1);
  }
  .secret-featured-card h3 {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-title);
    margin-bottom: 8px;
  }
  .secret-featured-card p {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.5;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .secret-link {
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .hero { padding: 52px 0 48px; }
    .hero-inner { flex-direction: column-reverse; gap: 24px; text-align: center; }
    .hero-title { font-size: 2.2rem; }
    .hero-manifesto { font-size: 1rem; }
    .hero-search { max-width: 100%; }
    .hero-illustration { width: auto; }
    .hero-cat { object-fit: contain; width: 140px; height: 140px; }
    .hero-hot { justify-content: center; }
    .secrets-featured-grid { grid-template-columns: 1fr; }
  }
</style>