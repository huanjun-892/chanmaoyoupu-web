---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';

const pageTitle = '我的评论 - 馋猫有谱';
---

<BaseLayout title={pageTitle}>
  <main class="comments-page">
    <div class="container">
      <div class="page-header">
        <h1 class="page-title">💬 我的评论</h1>
        <button class="back-btn" onclick="window.location.href='/'">
          返回首页
        </button>
      </div>
      
      <div id="login-prompt" class="login-prompt" style="display: none;">
        <div class="prompt-content">
          <svg viewBox="0 0 24 24" width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
          </svg>
          <h2>登录后查看评论</h2>
          <p>登录后可查看和管理您发表的评论</p>
          <button class="login-btn" onclick="openLoginModal()">立即登录</button>
        </div>
      </div>

      <div id="comments-content" class="comments-content">
        <div id="comments-list" class="comments-list">
          <div class="loading">
            <div class="spinner"></div>
            <span>加载中...</span>
          </div>
        </div>
        
        <div id="pagination" class="pagination" style="display: none;">
          <button id="prev-btn" class="page-btn" onclick="prevPage()">上一页</button>
          <span id="page-info" class="page-info"></span>
          <button id="next-btn" class="page-btn" onclick="nextPage()">下一页</button>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
.comments-page {
  min-height: 100vh;
  padding: 40px 0;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32px;
}

.page-title {
  font-size: 2rem;
  font-weight: 700;
  color: var(--color-title);
}

.back-btn {
  padding: 10px 20px;
  background: var(--color-bg-subtle);
  border: none;
  border-radius: 20px;
  font-size: 0.9rem;
  color: var(--color-muted);
  cursor: pointer;
  transition: all 0.25s;
}

.back-btn:hover {
  background: var(--color-bg);
  color: var(--color-title);
}

.login-prompt {
  max-width: 400px;
  margin: 60px auto;
}

.prompt-content {
  text-align: center;
  padding: 48px;
  background: var(--color-bg);
  border-radius: 24px;
  color: var(--color-muted);
}

.prompt-content svg {
  margin-bottom: 24px;
  opacity: 0.5;
}

.prompt-content h2 {
  font-size: 1.5rem;
  color: var(--color-title);
  margin-bottom: 12px;
}

.prompt-content p {
  margin-bottom: 24px;
}

.login-btn {
  padding: 12px 32px;
  background: linear-gradient(135deg, #ff6b35, #ff8f65);
  color: #fff;
  border: none;
  border-radius: 24px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.25s;
}

.login-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(255, 107, 53, 0.35);
}

.comments-content {
  display: none;
}

.comments-list {
  max-width: 800px;
  margin: 0 auto;
}

.comment-item {
  padding: 20px 24px;
  background: var(--color-bg);
  border-radius: 16px;
  margin-bottom: 12px;
  transition: all 0.25s;
}

.comment-item:hover {
  transform: translateX(8px);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
}

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.comment-recipe {
  display: flex;
  align-items: center;
  gap: 10px;
  flex: 1;
  text-decoration: none;
  color: inherit;
}

.comment-recipe-cover {
  width: 48px;
  height: 48px;
  border-radius: 8px;
  object-fit: cover;
  flex-shrink: 0;
  background: var(--color-bg-subtle);
}

.comment-recipe-info {
  flex: 1;
  min-width: 0;
}

.comment-recipe-title {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--color-title);
  margin-bottom: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.comment-date {
  font-size: 0.8rem;
  color: var(--color-muted);
}

.comment-content {
  font-size: 0.95rem;
  color: var(--color-text);
  line-height: 1.6;
  margin-bottom: 12px;
  word-break: break-word;
}

.comment-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.comment-reply-indicator {
  font-size: 0.8rem;
  color: var(--color-accent);
  display: flex;
  align-items: center;
  gap: 4px;
}

.delete-btn {
  padding: 6px 14px;
  background: var(--color-bg-subtle);
  border: none;
  border-radius: 8px;
  color: var(--color-muted);
  cursor: pointer;
  font-size: 0.8rem;
  transition: all 0.2s;
}

.delete-btn:hover {
  background: #ffebee;
  color: #e53935;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px;
  color: var(--color-muted);
  gap: 16px;
}

.spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--color-border-light);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-state {
  text-align: center;
  padding: 60px;
  color: var(--color-muted);
}

.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16px;
  margin-top: 32px;
}

.page-btn {
  padding: 10px 24px;
  background: var(--color-bg-subtle);
  border: none;
  border-radius: 20px;
  font-size: 0.9rem;
  color: var(--color-text);
  cursor: pointer;
  transition: all 0.25s;
}

.page-btn:hover:not(:disabled) {
  background: var(--color-accent);
  color: #fff;
}

.page-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.page-info {
  font-size: 0.9rem;
  color: var(--color-muted);
}

@media (max-width: 768px) {
  .page-header {
    flex-direction: column;
    gap: 16px;
    text-align: center;
  }
  .page-title { font-size: 1.5rem; }
  .comment-item { padding: 16px; }
  .comment-recipe-title { font-size: 0.9rem; }
  .comment-content { font-size: 0.9rem; }
}
</style>

<script>
import { isLoggedIn, getMyComments, deleteComment, type MyCommentsResponse } from '../../lib/auth';

declare global {
  interface Window {
    loadComments: () => Promise<void>;
    renderComments: (data: MyCommentsResponse) => void;
    deleteMyComment: (id: number) => Promise<void>;
    prevPage: () => void;
    nextPage: () => void;
  }
}

let currentPage = 1;
let totalPages = 1;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
  });
}

function formatSlug(slug: string): string {
  return slug.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
}

window.renderComments = function(data: MyCommentsResponse) {
  currentPage = data.page;
  totalPages = data.pages;
  
  const container = document.getElementById('comments-list');
  const pagination = document.getElementById('pagination');
  const pageInfo = document.getElementById('page-info');
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  
  if (!container) return;
  
  if (data.items.length === 0) {
    container.innerHTML = '<div class="empty-state">还没有发表过评论，快去食谱页留言吧~</div>';
    if (pagination) pagination.style.display = 'none';
    return;
  }
  
  container.innerHTML = data.items.map(item => {
    const recipeTitle = item.recipe_title || formatSlug(item.recipe_slug);
    const isReply = item.parent_id && item.parent_id > 0;
    
    return `
    <div class="comment-item" data-id="${item.id}">
      <div class="comment-header">
        <a href="/recipes/${item.recipe_slug}" class="comment-recipe">
          ${item.recipe_cover ? `<img src="${item.recipe_cover}" alt="${recipeTitle}" class="comment-recipe-cover" />` : ''}
          <div class="comment-recipe-info">
            <div class="comment-recipe-title">${recipeTitle}</div>
            <div class="comment-date">${formatDate(item.created_at)}</div>
          </div>
        </a>
      </div>
      <div class="comment-content">${item.content}</div>
      <div class="comment-footer">
        ${isReply ? '<span class="comment-reply-indicator">↩ 回复评论</span>' : '<span></span>'}
        <button class="delete-btn" onclick="deleteMyComment(${item.id})">删除</button>
      </div>
    </div>
  `}).join('');
  
  if (pagination) pagination.style.display = 'flex';
  if (pageInfo) pageInfo.textContent = `第 ${currentPage} / ${totalPages} 页`;
  if (prevBtn) prevBtn.disabled = currentPage <= 1;
  if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
};

window.deleteMyComment = async function(commentId: number) {
  if (!confirm('确定要删除这条评论吗？')) return;
  
  try {
    const result = await deleteComment(commentId);
    if (result.success) {
      const item = document.querySelector(`.comment-item[data-id="${commentId}"]`);
      if (item) {
        item.style.opacity = '0';
        item.style.transform = 'translateX(-100%)';
        setTimeout(() => {
          item.remove();
          if (document.querySelectorAll('.comment-item').length === 0) {
            window.loadComments();
          }
        }, 300);
      }
    } else {
      alert(result.error || '删除失败');
    }
  } catch (err) {
    console.error('删除评论失败:', err);
    alert('删除失败，请重试');
  }
};

window.loadComments = async function() {
  const loginPrompt = document.getElementById('login-prompt');
  const commentsContent = document.getElementById('comments-content');
  
  if (!isLoggedIn()) {
    if (loginPrompt) loginPrompt.style.display = 'block';
    if (commentsContent) commentsContent.style.display = 'none';
    return;
  }
  
  if (loginPrompt) loginPrompt.style.display = 'none';
  if (commentsContent) commentsContent.style.display = 'block';
  
  const container = document.getElementById('comments-list');
  if (!container) return;
  
  try {
    const result = await getMyComments(currentPage, 10);
    if (result.success && result.data) {
      window.renderComments(result.data);
    } else if (result.error === '请先登录') {
      if (loginPrompt) loginPrompt.style.display = 'block';
      if (commentsContent) commentsContent.style.display = 'none';
    } else {
      container.innerHTML = '<div class="empty-state">加载失败，请刷新重试</div>';
    }
  } catch (err) {
    console.error('加载评论失败:', err);
    container.innerHTML = '<div class="empty-state">加载失败，请刷新重试</div>';
  }
};

window.prevPage = function() {
  if (currentPage > 1) {
    currentPage--;
    window.loadComments();
  }
};

window.nextPage = function() {
  if (currentPage < totalPages) {
    currentPage++;
    window.loadComments();
  }
};

document.addEventListener('DOMContentLoaded', () => {
  window.loadComments();
});

window.addEventListener('auth_change', () => {
  currentPage = 1;
  window.loadComments();
});
</script>
