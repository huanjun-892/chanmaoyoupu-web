    function loadUsers(page = 1, search = '', role = '') {
      usersCurrentPage = page;
      const container = document.getElementById('users-table-container');
      if (!container) return;
      
      container.innerHTML = '<div class="loading"><div class="spinner"></div><p>加载中...</p></div>';
      
      let url = API_BASE + '/users?page=' + page + '&limit=' + usersPageSize;
      if (search) url += '&search=' + encodeURIComponent(search);
      if (role) url += '&role=' + role;
      
      fetch(url, { headers: getAuthHeaders() })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            renderUsersTable(data.data.users, data.data.total, page);
          } else {
            container.innerHTML = '<p style="text-align: center; color: var(--color-error);">加载失败：' + (data.error || '未知错误') + '</p>';
          }
        })
        .catch(err => {
          container.innerHTML = '<p style="text-align: center; color: var(--color-error);">加载失败：' + err.message + '</p>';
        });
    }
    
    function searchUsers() {
      const search = document.getElementById('user-search').value;
      const role = document.getElementById('user-role-filter').value;
      loadUsers(1, search, role);
    }
    
    function renderUsersTable(users, total, page) {
      const container = document.getElementById('users-table-container');
      if (!container) return;
      
      if (!users || users.length === 0) {
        container.innerHTML = '<p style="text-align: center; color: var(--color-text-secondary); padding: 40px;">暂无用户数据</p>';
        document.getElementById('users-pagination').innerHTML = '';
        return;
      }
      
      let html = '<table class="data-table">';
      html += '<thead><tr>';
      html += '<th>ID</th><th>邮箱</th><th>昵称</th><th>角色</th><th>注册时间</th><th>操作</th>';
      html += '</tr></thead><tbody>';
      
      users.forEach(user => {
        const roleBadge = user.role === 'admin' 
          ? '<span class="badge badge-admin">管理员</span>' 
          : '<span class="badge badge-user">普通用户</span>';
        
        const roleAction = user.role === 'admin'
          ? `<button class="btn btn-secondary btn-sm" onclick="updateUserRole(${user.id}, 'user')">设为普通用户</button>`
          : `<button class="btn btn-primary btn-sm" onclick="updateUserRole(${user.id}, 'admin')">设为管理员</button>`;
        
        html += `
          <tr>
            <td>${user.id}</td>
            <td>${escapeHtml(user.email || '')}</td>
            <td>${escapeHtml(user.nickname || '-')}</td>
            <td>${roleBadge}</td>
            <td>${formatDate(user.created_at)}</td>
            <td>${roleAction}</td>
          </tr>
        `;
      });
      
      html += '</tbody></table>';
      container.innerHTML = html;
      
      // 渲染分页
      renderPagination('users', total, usersPageSize, page, function(p) {
        const search = document.getElementById('user-search').value;
        const role = document.getElementById('user-role-filter').value;
        loadUsers(p, search, role);
      });
    }
    
