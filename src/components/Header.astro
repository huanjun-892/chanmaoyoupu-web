---
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/images/logo-small.png" alt="馋猫有谱" class="logo-icon" width="36" height="36" />
      <span class="logo-text">馋猫有谱</span>
    </a>
    <nav class="nav">
      <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>首页</a>
      <a href="/recipes" class:list={['nav-link', { active: currentPath.startsWith('/recipes') }]}>食谱</a>
      <a href="/knowledge" class:list={['nav-link', { active: currentPath.startsWith('/knowledge') }]}>知识库</a>
      <a href="/rankings" class:list={['nav-link', { active: currentPath === '/rankings' }]}>排行榜</a>
    </nav>
    <div class="header-right">
      <form action="/search" method="get" class="search-box">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" placeholder="搜食谱、食材..." class="search-input" />
      </form>
      <button id="auth-btn" class="auth-btn" onclick="openLoginModal()">登录</button>
      
      <!-- 已登录用户菜单 -->
      <div id="user-menu" class="user-menu" style="display: none;">
        <button class="user-menu-trigger" onclick="toggleUserDropdown()">
          <img id="header-user-avatar" src="/images/default-avatar.jpg" alt="头像" class="header-avatar" />
          <svg class="dropdown-arrow" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 5l3 3 3-3"/></svg>
        </button>
        
        <div id="user-dropdown" class="user-dropdown">
          <div class="dropdown-header">
            <img id="user-dropdown-avatar" src="/images/default-avatar.jpg" alt="头像" class="dropdown-avatar" />
            <div class="dropdown-user-info">
              <span id="user-dropdown-nickname" class="dropdown-nickname">用户</span>
              <span class="dropdown-edit-profile" onclick="openProfileModal()">修改资料</span>
            </div>
          </div>
          <div class="dropdown-divider"></div>
          <a href="/profile/favorites" class="dropdown-item">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            我的收藏
          </a>
          <a href="/rankings" class="dropdown-item">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 15l-2-2h4l-2 2zm0-6l2 2h-4l2-2z"/><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
            排行榜
          </a>
          <div class="dropdown-divider"></div>
          <button class="dropdown-item logout-item" onclick="handleLogout()">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            退出登录
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<!-- 修改资料弹窗 -->
<div id="profile-modal" class="modal-overlay" style="display: none;">
  <div class="profile-modal-content">
    <button class="modal-close" onclick="closeProfileModal()">&times;</button>
    <h3 class="profile-modal-title">修改资料</h3>
    
    <div class="avatar-section">
      <div class="avatar-preview-wrap">
        <img id="profile-avatar-preview" src="/images/default-avatar.jpg" alt="头像预览" class="avatar-preview" />
        <label for="profile-avatar-url" class="avatar-change-btn">更换头像</label>
      </div>
      <input type="url" id="profile-avatar-url" placeholder="粘贴图片链接地址" class="avatar-url-input" />
      <p class="avatar-hint">支持粘贴图片URL地址，推荐正方形图片</p>
    </div>
    
    <div class="profile-field">
      <label for="profile-nickname">昵称</label>
      <input type="text" id="profile-nickname" maxlength="20" placeholder="输入新昵称" />
      <span id="profile-nickname-status" class="nickname-status"></span>
    </div>
    
    <div class="profile-field">
      <label for="profile-phone">手机号（选填）</label>
      <input type="tel" id="profile-phone" maxlength="11" placeholder="选填" />
    </div>
    
    <div class="profile-field">
      <label for="profile-birthday">出生日期（选填）</label>
      <input type="date" id="profile-birthday" />
    </div>
    
    <div id="profile-error" class="error-msg" style="display: none;"></div>
    <div id="profile-success" class="success-msg" style="display: none;"></div>
    
    <button id="profile-save-btn" class="submit-btn" onclick="saveProfile()">保存修改</button>
  </div>
</div>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 252, 248, 0.88);
    backdrop-filter: blur(16px) saturate(180%);
    border-bottom: 1px solid var(--color-border-light);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 68px;
    gap: 36px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .logo-text {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-title);
    letter-spacing: -0.01em;
  }

  .nav {
    display: flex;
    gap: 28px;
  }

  .nav-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-muted);
    padding: 4px 0;
    position: relative;
    transition: color 0.25s;
  }

  .nav-link:hover {
    color: var(--color-title);
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 2.5px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .header-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .search-box {
    display: flex;
    align-items: center;
    background: var(--color-bg-subtle);
    border: 1.5px solid transparent;
    border-radius: 100px;
    padding: 8px 16px;
    transition: all 0.25s;
    gap: 8px;
  }

  .search-box:focus-within {
    border-color: var(--color-accent);
    background: var(--color-bg);
    box-shadow: 0 0 0 3px var(--color-accent-light);
  }

  .search-icon {
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .search-input {
    border: none;
    background: transparent;
    outline: none;
    font-size: 0.84rem;
    color: var(--color-text);
    width: 160px;
  }

  .search-input::placeholder {
    color: var(--color-muted);
  }

  .auth-btn {
    padding: 8px 20px;
    background: linear-gradient(135deg, #ff6b35, #ff8f65);
    color: #fff;
    border: none;
    border-radius: 20px;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.25s;
    white-space: nowrap;
  }

  .auth-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 107, 53, 0.35);
  }

  /* 用户菜单 */
  .user-menu {
    position: relative;
    display: flex;
    align-items: center;
  }

  .user-menu-trigger {
    display: flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    border-radius: 20px;
    transition: background 0.2s;
  }

  .user-menu-trigger:hover {
    background: rgba(0, 0, 0, 0.04);
  }

  .header-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .dropdown-arrow {
    color: #999;
    transition: transform 0.2s;
  }

  .user-menu-trigger:hover .dropdown-arrow {
    color: #666;
  }

  .user-dropdown.show .dropdown-arrow {
    transform: rotate(180deg);
  }

  /* 下拉菜单 */
  .user-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 240px;
    background: #fff;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12), 0 2px 8px rgba(0, 0, 0, 0.06);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: all 0.2s ease;
    overflow: hidden;
    z-index: 200;
  }

  .user-dropdown.show {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .dropdown-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
  }

  .dropdown-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #f0f0f0;
  }

  .dropdown-user-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .dropdown-nickname {
    font-size: 15px;
    font-weight: 600;
    color: #333;
  }

  .dropdown-edit-profile {
    font-size: 12px;
    color: #ff6b35;
    cursor: pointer;
  }

  .dropdown-edit-profile:hover {
    text-decoration: underline;
  }

  .dropdown-divider {
    height: 1px;
    background: #f0f0f0;
    margin: 0 12px;
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    font-size: 14px;
    color: #555;
    text-decoration: none;
    transition: background 0.15s;
    cursor: pointer;
    border: none;
    background: none;
    width: 100%;
    text-align: left;
  }

  .dropdown-item:hover {
    background: #f8f8f8;
    color: #333;
  }

  .logout-item {
    color: #999;
  }

  .logout-item:hover {
    background: #fff5f5;
    color: #e53935;
  }

  /* 修改资料弹窗 */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    backdrop-filter: blur(4px);
  }

  .profile-modal-content {
    background: #fff;
    border-radius: 16px;
    padding: 32px;
    width: 90%;
    max-width: 420px;
    min-width: 320px;
    position: relative;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    max-height: 90vh;
    overflow-y: auto;
  }

  .profile-modal-title {
    font-size: 18px;
    font-weight: 600;
    color: #333;
    margin-bottom: 24px;
  }

  .avatar-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  .avatar-preview-wrap {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .avatar-preview {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #f0f0f0;
  }

  .avatar-change-btn {
    font-size: 13px;
    color: #ff6b35;
    cursor: pointer;
    font-weight: 500;
  }

  .avatar-change-btn:hover {
    text-decoration: underline;
  }

  .avatar-url-input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 14px;
    transition: border-color 0.2s;
  }

  .avatar-url-input:focus {
    outline: none;
    border-color: #ff6b35;
  }

  .avatar-hint {
    font-size: 12px;
    color: #bbb;
    text-align: center;
  }

  .profile-field {
    margin-bottom: 16px;
    position: relative;
  }

  .profile-field label {
    display: block;
    font-size: 14px;
    font-weight: 500;
    color: #333;
    margin-bottom: 6px;
  }

  .profile-field input {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 14px;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  .profile-field input:focus {
    outline: none;
    border-color: #ff6b35;
  }

  .nickname-status {
    position: absolute;
    right: 10px;
    top: 38px;
    font-size: 16px;
    font-weight: bold;
  }

  .nickname-status.available { color: #4caf50; }
  .nickname-status.taken { color: #e53935; }
  .nickname-status.checking { color: #ff9800; }

  .error-msg {
    color: #e53935;
    font-size: 13px;
    padding: 8px 12px;
    background: #ffebee;
    border-radius: 6px;
    margin-bottom: 12px;
  }

  .success-msg {
    color: #2e7d32;
    font-size: 13px;
    padding: 8px 12px;
    background: #e8f5e9;
    border-radius: 6px;
    margin-bottom: 12px;
  }

  .submit-btn {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, #ff6b35, #ff8f65);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 107, 53, 0.4);
  }

  .submit-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  .modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: #999;
    padding: 4px;
    line-height: 1;
  }

  .modal-close:hover { color: #333; }

  @media (max-width: 768px) {
    .nav { gap: 20px; }
    .search-input { width: 110px; }
    .header-inner { gap: 20px; }
  }

  @media (max-width: 480px) {
    .search-input { width: 80px; }
    .header-inner { gap: 14px; }
    .auth-btn { padding: 6px 14px; font-size: 0.8rem; }
    .user-dropdown { width: 220px; }
  }
</style>

<script>
import { getStoredUser, checkNickname, updateProfile } from '../lib/auth';

declare global {
  interface Window {
    toggleUserDropdown: () => void;
    openProfileModal: () => void;
    closeProfileModal: () => void;
    saveProfile: () => Promise<void>;
  }
}

// 切换用户下拉菜单
window.toggleUserDropdown = function() {
  const dropdown = document.getElementById('user-dropdown');
  if (dropdown) {
    dropdown.classList.toggle('show');
  }
};

// 点击其他区域关闭下拉菜单
document.addEventListener('click', (e) => {
  const userMenu = document.getElementById('user-menu');
  const dropdown = document.getElementById('user-dropdown');
  if (userMenu && dropdown && !userMenu.contains(e.target as Node)) {
    dropdown.classList.remove('show');
  }
});

// 打开修改资料弹窗
window.openProfileModal = function() {
  const modal = document.getElementById('profile-modal');
  const dropdown = document.getElementById('user-dropdown');
  if (dropdown) dropdown.classList.remove('show');
  
  const user = getStoredUser();
  if (user) {
    const avatarPreview = document.getElementById('profile-avatar-preview') as HTMLImageElement;
    const avatarUrl = document.getElementById('profile-avatar-url') as HTMLInputElement;
    const nickname = document.getElementById('profile-nickname') as HTMLInputElement;
    const phone = document.getElementById('profile-phone') as HTMLInputElement;
    const birthday = document.getElementById('profile-birthday') as HTMLInputElement;
    
    if (avatarPreview) avatarPreview.src = user.avatar_url || '/images/default-avatar.jpg';
    if (avatarUrl) avatarUrl.value = user.avatar_url || '';
    if (nickname) nickname.value = user.nickname || '';
    if (phone) phone.value = user.phone || '';
    if (birthday) birthday.value = user.birthday || '';
  }
  
  if (modal) {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
};

// 关闭修改资料弹窗
window.closeProfileModal = function() {
  const modal = document.getElementById('profile-modal');
  if (modal) {
    modal.style.display = 'none';
    document.body.style.overflow = '';
  }
  const errorEl = document.getElementById('profile-error');
  const successEl = document.getElementById('profile-success');
  if (errorEl) errorEl.style.display = 'none';
  if (successEl) successEl.style.display = 'none';
};

// 头像URL输入预览
const avatarUrlInput = document.getElementById('profile-avatar-url') as HTMLInputElement;
if (avatarUrlInput) {
  avatarUrlInput.addEventListener('input', () => {
    const preview = document.getElementById('profile-avatar-preview') as HTMLImageElement;
    if (preview && avatarUrlInput.value) {
      preview.src = avatarUrlInput.value;
      preview.onerror = () => { preview.src = '/images/default-avatar.jpg'; };
    }
  });
}

// 昵称查重
let profileNicknameTimer: any = null;
const profileNicknameInput = document.getElementById('profile-nickname') as HTMLInputElement;
if (profileNicknameInput) {
  profileNicknameInput.addEventListener('input', () => {
    const nickname = profileNicknameInput.value.trim();
    const statusEl = document.getElementById('profile-nickname-status');
    if (!statusEl) return;
    
    const currentUser = getStoredUser();
    // 如果没改昵称，不查重
    if (!nickname || nickname === currentUser?.nickname) {
      statusEl.textContent = '';
      statusEl.className = 'nickname-status';
      return;
    }
    
    clearTimeout(profileNicknameTimer);
    statusEl.textContent = '⏳';
    statusEl.className = 'nickname-status checking';
    
    profileNicknameTimer = setTimeout(async () => {
      try {
        const result = await checkNickname(nickname);
        if (result.success && result.data) {
          if (result.data.available) {
            statusEl.textContent = '✓';
            statusEl.className = 'nickname-status available';
          } else {
            statusEl.textContent = '✗';
            statusEl.className = 'nickname-status taken';
          }
        }
      } catch {
        statusEl.textContent = '';
        statusEl.className = 'nickname-status';
      }
    }, 500);
  });
}

// 保存资料
window.saveProfile = async function() {
  const saveBtn = document.getElementById('profile-save-btn') as HTMLButtonElement;
  const errorEl = document.getElementById('profile-error');
  const successEl = document.getElementById('profile-success');
  
  if (!saveBtn) return;
  saveBtn.disabled = true;
  saveBtn.textContent = '保存中...';
  
  if (errorEl) { errorEl.style.display = 'none'; }
  if (successEl) { successEl.style.display = 'none'; }
  
  const avatarUrl = (document.getElementById('profile-avatar-url') as HTMLInputElement).value.trim();
  const nickname = (document.getElementById('profile-nickname') as HTMLInputElement).value.trim();
  const phone = (document.getElementById('profile-phone') as HTMLInputElement).value.trim();
  const birthday = (document.getElementById('profile-birthday') as HTMLInputElement).value;
  
  // 校验
  if (phone && !/^1\d{10}$/.test(phone)) {
    if (errorEl) { errorEl.textContent = '手机号格式不正确'; errorEl.style.display = 'block'; }
    saveBtn.disabled = false;
    saveBtn.textContent = '保存修改';
    return;
  }
  
  const data: any = {};
  if (avatarUrl) data.avatar_url = avatarUrl;
  if (nickname) data.nickname = nickname;
  if (phone !== undefined) data.phone = phone;
  if (birthday !== undefined) data.birthday = birthday;
  
  try {
    const result = await updateProfile(data);
    if (result.success && result.data) {
      if (successEl) { successEl.textContent = '修改成功！'; successEl.style.display = 'block'; }
      window.updateAuthUI();
      setTimeout(() => { window.closeProfileModal(); }, 800);
    } else {
      if (errorEl) { errorEl.textContent = result.error || '修改失败'; errorEl.style.display = 'block'; }
    }
  } catch (err: any) {
    if (errorEl) { errorEl.textContent = err.message || '网络错误'; errorEl.style.display = 'block'; }
  } finally {
    saveBtn.disabled = false;
    saveBtn.textContent = '保存修改';
  }
};

// 点击弹窗遮罩关闭
document.getElementById('profile-modal')?.addEventListener('click', (e) => {
  if (e.target === e.currentTarget) {
    window.closeProfileModal();
  }
});
</script>
