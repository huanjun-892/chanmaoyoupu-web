---
export interface Props {
  title: string;
  slug: string;
  cover?: string | null;
  difficulty?: string;
  cookTime?: number;
  calories?: number;
  tags?: string[];
  likeCount?: number;
  favoriteCount?: number;
}

const { title, slug, cover, difficulty, cookTime, calories, tags = [], likeCount = 0, favoriteCount = 0 } = Astro.props;
---

<a href={`/recipes/${slug}`} class="card recipe-card">
  <div class="card-img-wrap">
    {cover
      ? <img src={cover} alt={title} class="card-img" loading="lazy" />
      : <div class="card-img placeholder">🍳</div>
    }
    {calories && (
      <span class:list={['calorie-badge', calories < 300 ? 'tag-green' : calories > 600 ? 'tag-red' : 'tag']}>
        {calories} kcal
      </span>
    )}
    <div class="card-stats">
      <span class="stat-item">
        <svg viewBox="0 0 24 24" width="14" height="14"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="currentColor"/></svg>
        <span class="stat-count" data-slug={slug} data-type="likes">{likeCount}</span>
      </span>
      <span class="stat-item">
        <svg viewBox="0 0 24 24" width="14" height="14"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="currentColor"/></svg>
        <span class="stat-count" data-slug={slug} data-type="favorites">{favoriteCount}</span>
      </span>
    </div>
  </div>
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    <div class="card-meta">
      {difficulty && <span>{difficulty}</span>}
      {cookTime && <span>⏱ {cookTime}分钟</span>}
    </div>
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.slice(0, 3).map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</a>

<style>
  .card-img-wrap {
    position: relative;
  }

  .placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg-warm);
    font-size: 3rem;
  }

  .calorie-badge {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .card-stats {
    position: absolute;
    bottom: 8px;
    left: 8px;
    display: flex;
    gap: 12px;
  }

  .stat-item {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 4px 8px;
    background: rgba(0, 0, 0, 0.5);
    border-radius: 12px;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .stat-item svg {
    opacity: 0.9;
  }

  .card-tags {
    display: flex;
    gap: 6px;
    margin-top: 10px;
    flex-wrap: wrap;
  }
</style>

<script>
import { getLikeStatus, getFavoriteStatus } from '../lib/auth';

// 页面加载后获取点赞和收藏数
document.addEventListener('DOMContentLoaded', async () => {
  const statCounts = document.querySelectorAll('.stat-count[data-slug]');
  
  for (const el of statCounts) {
    const span = el as HTMLElement;
    const slug = span.dataset.slug;
    const type = span.dataset.type;
    
    if (!slug || !type) continue;
    
    try {
      if (type === 'likes') {
        const result = await getLikeStatus(slug);
        if (result.success && result.data) {
          span.textContent = result.data.count.toString();
        }
      } else if (type === 'favorites') {
        const result = await getFavoriteStatus(slug);
        if (result.success && result.data) {
          span.textContent = result.data.count.toString();
        }
      }
    } catch (err) {
      // 静默失败，使用默认0
    }
  }
});
</script>
