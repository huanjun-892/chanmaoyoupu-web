---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/global.css';

const pageTitle = '我的收藏 - 馋猫有谱';
---

<BaseLayout title={pageTitle}>
  <main class="favorites-page">
    <div class="container">
      <div class="page-header">
        <h1 class="page-title">⭐ 我的收藏</h1>
        <button class="back-btn" onclick="window.location.href='/'">
          返回首页
        </button>
      </div>
      
      <div id="login-prompt" class="login-prompt" style="display: none;">
        <div class="prompt-content">
          <svg viewBox="0 0 24 24" width="64" height="64" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
          </svg>
          <h2>登录后查看收藏</h2>
          <p>登录后可查看和管理您收藏的食谱</p>
          <button class="login-btn" onclick="openLoginModal()">立即登录</button>
        </div>
      </div>

      <div id="favorites-content" class="favorites-content">
        <div id="favorites-list" class="favorites-list">
          <div class="loading">
            <div class="spinner"></div>
            <span>加载中...</span>
          </div>
        </div>
        
        <div id="pagination" class="pagination" style="display: none;">
          <button id="prev-btn" class="page-btn" onclick="prevPage()">上一页</button>
          <span id="page-info" class="page-info"></span>
          <button id="next-btn" class="page-btn" onclick="nextPage()">下一页</button>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
.favorites-page {
  min-height: 100vh;
  padding: 40px 0;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32px;
}

.page-title {
  font-size: 2rem;
  font-weight: 700;
  color: var(--color-title);
}

.back-btn {
  padding: 10px 20px;
  background: var(--color-bg-subtle);
  border: none;
  border-radius: 20px;
  font-size: 0.9rem;
  color: var(--color-muted);
  cursor: pointer;
  transition: all 0.25s;
}

.back-btn:hover {
  background: var(--color-bg);
  color: var(--color-title);
}

.login-prompt {
  max-width: 400px;
  margin: 60px auto;
}

.prompt-content {
  text-align: center;
  padding: 48px;
  background: var(--color-bg);
  border-radius: 24px;
  color: var(--color-muted);
}

.prompt-content svg {
  margin-bottom: 24px;
  opacity: 0.5;
}

.prompt-content h2 {
  font-size: 1.5rem;
  color: var(--color-title);
  margin-bottom: 12px;
}

.prompt-content p {
  margin-bottom: 24px;
}

.login-btn {
  padding: 12px 32px;
  background: linear-gradient(135deg, #ff6b35, #ff8f65);
  color: #fff;
  border: none;
  border-radius: 24px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.25s;
}

.login-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 16px rgba(255, 107, 53, 0.35);
}

.favorites-content {
  display: none;
}

.favorites-list {
  max-width: 800px;
  margin: 0 auto;
}

.favorite-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 24px;
  background: var(--color-bg);
  border-radius: 16px;
  margin-bottom: 12px;
  transition: all 0.25s;
}

.favorite-item:hover {
  transform: translateX(8px);
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
}

.favorite-item a {
  display: flex;
  align-items: center;
  flex: 1;
  text-decoration: none;
  color: inherit;
}

.favorite-info {
  flex: 1;
}

.favorite-title {
  font-size: 1.1rem;
  font-weight: 600;
  color: var(--color-title);
  margin-bottom: 4px;
}

.favorite-date {
  font-size: 0.875rem;
  color: var(--color-muted);
}

.favorite-arrow {
  color: var(--color-muted);
  margin-left: 16px;
}

.remove-btn {
  padding: 8px 16px;
  background: var(--color-bg-subtle);
  border: none;
  border-radius: 8px;
  color: var(--color-muted);
  cursor: pointer;
  font-size: 0.875rem;
  transition: all 0.2s;
}

.remove-btn:hover {
  background: #ffebee;
  color: #e53935;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px;
  color: var(--color-muted);
  gap: 16px;
}

.spinner {
  width: 40px;
  height: 40px;
  border: 3px solid var(--color-border-light);
  border-top-color: var(--color-accent);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-state {
  text-align: center;
  padding: 60px;
  color: var(--color-muted);
}

.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16px;
  margin-top: 32px;
}

.page-btn {
  padding: 10px 24px;
  background: var(--color-bg-subtle);
  border: none;
  border-radius: 20px;
  font-size: 0.9rem;
  color: var(--color-text);
  cursor: pointer;
  transition: all 0.25s;
}

.page-btn:hover:not(:disabled) {
  background: var(--color-accent);
  color: #fff;
}

.page-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.page-info {
  font-size: 0.9rem;
  color: var(--color-muted);
}

@media (max-width: 768px) {
  .page-header {
    flex-direction: column;
    gap: 16px;
    text-align: center;
  }
  .page-title { font-size: 1.5rem; }
  .favorite-item { padding: 16px; }
  .favorite-title { font-size: 1rem; }
}
</style>

<script>
import { isLoggedIn, getMyFavorites, toggleFavorite, type FavoritesResponse } from '../../lib/auth';

declare global {
  interface Window {
    loadFavorites: () => Promise<void>;
    renderFavorites: (data: FavoritesResponse) => void;
    prevPage: () => void;
    nextPage: () => void;
  }
}

let currentPage = 1;
let totalPages = 1;
let favoritesData: FavoritesResponse | null = null;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function formatSlug(slug: string): string {
  return slug.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase());
}

window.renderFavorites = function(data: FavoritesResponse) {
  favoritesData = data;
  currentPage = data.page;
  totalPages = data.pages;
  
  const container = document.getElementById('favorites-list');
  const pagination = document.getElementById('pagination');
  const pageInfo = document.getElementById('page-info');
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  
  if (!container) return;
  
  if (data.items.length === 0) {
    container.innerHTML = '<div class="empty-state">暂无收藏，快去收藏喜欢的食谱吧~</div>';
    if (pagination) pagination.style.display = 'none';
    return;
  }
  
  container.innerHTML = data.items.map(item => `
    <div class="favorite-item" data-slug="${item.recipe_slug}">
      <a href="/recipes/${item.recipe_slug}">
        <div class="favorite-info">
          <div class="favorite-title">${formatSlug(item.recipe_slug)}</div>
          <div class="favorite-date">收藏于 ${formatDate(item.created_at)}</div>
        </div>
        <svg class="favorite-arrow" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </a>
      <button class="remove-btn" onclick="event.preventDefault(); removeFavorite('${item.recipe_slug}')">取消收藏</button>
    </div>
  `).join('');
  
  if (pagination) pagination.style.display = 'flex';
  if (pageInfo) pageInfo.textContent = `第 ${currentPage} / ${totalPages} 页`;
  if (prevBtn) prevBtn.disabled = currentPage <= 1;
  if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
};

window.removeFavorite = async function(slug: string) {
  try {
    const result = await toggleFavorite(slug);
    if (result.success) {
      // 从DOM移除该项
      const item = document.querySelector(`.favorite-item[data-slug="${slug}"]`);
      if (item) {
        item.style.opacity = '0';
        item.style.transform = 'translateX(-100%)';
        setTimeout(() => {
          item.remove();
          // 如果列表空了，刷新
          if (document.querySelectorAll('.favorite-item').length === 0) {
            window.loadFavorites();
          }
        }, 300);
      }
    }
  } catch (err) {
    console.error('取消收藏失败:', err);
  }
};

window.loadFavorites = async function() {
  const loginPrompt = document.getElementById('login-prompt');
  const favoritesContent = document.getElementById('favorites-content');
  
  if (!isLoggedIn()) {
    if (loginPrompt) loginPrompt.style.display = 'block';
    if (favoritesContent) favoritesContent.style.display = 'none';
    return;
  }
  
  if (loginPrompt) loginPrompt.style.display = 'none';
  if (favoritesContent) favoritesContent.style.display = 'block';
  
  const container = document.getElementById('favorites-list');
  if (!container) return;
  
  try {
    const result = await getMyFavorites(currentPage, 10);
    if (result.success && result.data) {
      window.renderFavorites(result.data);
    } else if (result.error === '请先登录') {
      if (loginPrompt) loginPrompt.style.display = 'block';
      if (favoritesContent) favoritesContent.style.display = 'none';
    } else {
      container.innerHTML = '<div class="empty-state">加载失败，请刷新重试</div>';
    }
  } catch (err) {
    console.error('加载收藏失败:', err);
    container.innerHTML = '<div class="empty-state">加载失败，请刷新重试</div>';
  }
};

window.prevPage = function() {
  if (currentPage > 1) {
    currentPage--;
    window.loadFavorites();
  }
};

window.nextPage = function() {
  if (currentPage < totalPages) {
    currentPage++;
    window.loadFavorites();
  }
};

// 监听登录状态变化
document.addEventListener('DOMContentLoaded', () => {
  window.loadFavorites();
});

// 监听认证变化事件
window.addEventListener('auth_change', () => {
  window.loadFavorites();
});
</script>
