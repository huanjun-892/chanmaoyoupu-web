---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const pageTitle = '排行榜 - 馋猫有谱';
---

<BaseLayout title={pageTitle}>
  
  <main class="rankings-page">
    <div class="container">
      <h1 class="page-title">🏆 排行榜</h1>
      
      <div class="tabs">
        <button class="tab-btn active" data-tab="likes" onclick="switchRankingTab('likes')">
          <svg viewBox="0 0 24 24" width="18" height="18"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="currentColor"/></svg>
          点赞榜
        </button>
        <button class="tab-btn" data-tab="favorites" onclick="switchRankingTab('favorites')">
          <svg viewBox="0 0 24 24" width="18" height="18"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="currentColor"/></svg>
          收藏榜
        </button>
      </div>

      <div class="filter-bar" id="filter-bar">
        <div class="filter-group">
          <span class="filter-label">菜系</span>
          <div class="filter-options">
            <button class="filter-chip active" data-filter="cuisine" data-value="" onclick="setFilter(this)">全部</button>
            <button class="filter-chip" data-filter="cuisine" data-value="川菜" onclick="setFilter(this)">🌶️ 川菜</button>
            <button class="filter-chip" data-filter="cuisine" data-value="粤菜" onclick="setFilter(this)">🥢 粤菜</button>
            <button class="filter-chip" data-filter="cuisine" data-value="湘菜" onclick="setFilter(this)">🔥 湘菜</button>
            <button class="filter-chip" data-filter="cuisine" data-value="浙菜" onclick="setFilter(this)">🍵 浙菜</button>
            <button class="filter-chip" data-filter="cuisine" data-value="鲁菜" onclick="setFilter(this)">🍖 鲁菜</button>
            <button class="filter-chip" data-filter="cuisine" data-value="苏菜" onclick="setFilter(this)">🦀 苏菜</button>
            <button class="filter-chip" data-filter="cuisine" data-value="东北菜" onclick="setFilter(this)">🥟 东北菜</button>
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">地域</span>
          <div class="filter-options">
            <button class="filter-chip active" data-filter="region" data-value="" onclick="setFilter(this)">全部</button>
            <button class="filter-chip" data-filter="region" data-value="四川" onclick="setFilter(this)">四川</button>
            <button class="filter-chip" data-filter="region" data-value="广东" onclick="setFilter(this)">广东</button>
            <button class="filter-chip" data-filter="region" data-value="湖南" onclick="setFilter(this)">湖南</button>
            <button class="filter-chip" data-filter="region" data-value="浙江" onclick="setFilter(this)">浙江</button>
            <button class="filter-chip" data-filter="region" data-value="山东" onclick="setFilter(this)">山东</button>
            <button class="filter-chip" data-filter="region" data-value="东北" onclick="setFilter(this)">东北</button>
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">场景</span>
          <div class="filter-options">
            <button class="filter-chip active" data-filter="tag" data-value="" onclick="setFilter(this)">全部</button>
            <button class="filter-chip" data-filter="tag" data-value="快手菜" onclick="setFilter(this)">⚡ 快手菜</button>
            <button class="filter-chip" data-filter="tag" data-value="下饭菜" onclick="setFilter(this)">🍚 下饭菜</button>
            <button class="filter-chip" data-filter="tag" data-value="家常菜" onclick="setFilter(this)">🏠 家常菜</button>
            <button class="filter-chip" data-filter="tag" data-value="减脂" onclick="setFilter(this)">🥗 减脂</button>
            <button class="filter-chip" data-filter="tag" data-value="夜宵" onclick="setFilter(this)">🌙 夜宵</button>
          </div>
        </div>
      </div>

      <div id="likes-ranking" class="ranking-list">
        <div class="loading"><div class="spinner"></div><span>加载中...</span></div>
      </div>

      <div id="favorites-ranking" class="ranking-list" style="display: none;">
        <div class="loading"><div class="spinner"></div><span>加载中...</span></div>
      </div>
    </div>
  </main>

</BaseLayout>

<style>
.rankings-page { min-height: 100vh; padding: 40px 0; }
.page-title { font-size: 2rem; font-weight: 700; color: var(--color-title); text-align: center; margin-bottom: 32px; }

.tabs { display: flex; justify-content: center; gap: 16px; margin-bottom: 24px; }
.tab-btn { display: flex; align-items: center; gap: 8px; padding: 12px 24px; border: none; background: var(--color-bg-subtle); border-radius: 30px; font-size: 1rem; font-weight: 500; color: var(--color-muted); cursor: pointer; transition: all 0.25s; }
.tab-btn.active { background: linear-gradient(135deg, #ff6b35, #ff8f65); color: #fff; }
.tab-btn:not(.active):hover { background: var(--color-bg); color: var(--color-title); }

.filter-bar { max-width: 800px; margin: 0 auto 28px; display: flex; flex-direction: column; gap: 12px; }
.filter-group { display: flex; align-items: center; gap: 10px; }
.filter-label { font-size: 0.85rem; font-weight: 600; color: var(--color-muted); min-width: 40px; flex-shrink: 0; }
.filter-options { display: flex; flex-wrap: wrap; gap: 8px; }
.filter-chip { padding: 6px 14px; border: 1px solid var(--color-border-light); border-radius: 20px; background: var(--color-bg); font-size: 0.82rem; color: var(--color-muted); cursor: pointer; transition: all 0.2s; white-space: nowrap; }
.filter-chip:hover { border-color: var(--color-accent); color: var(--color-accent); }
.filter-chip.active { background: var(--color-accent); color: #fff; border-color: var(--color-accent); }

.ranking-list { max-width: 800px; margin: 0 auto; }
.ranking-item { display: flex; align-items: center; padding: 16px 24px; background: var(--color-bg); border-radius: 16px; margin-bottom: 12px; transition: all 0.25s; cursor: pointer; }
.ranking-item:hover { transform: translateX(8px); box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
.ranking-item a { display: flex; align-items: center; width: 100%; text-decoration: none; color: inherit; }

.ranking-rank { width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; font-weight: 700; margin-right: 16px; flex-shrink: 0; }
.ranking-rank.top-1 { background: linear-gradient(135deg, #ffd700, #ffb800); color: #fff; border-radius: 50%; }
.ranking-rank.top-2 { background: linear-gradient(135deg, #c0c0c0, #a8a8a8); color: #fff; border-radius: 50%; }
.ranking-rank.top-3 { background: linear-gradient(135deg, #cd7f32, #b5651d); color: #fff; border-radius: 50%; }
.ranking-rank.normal { background: var(--color-bg-subtle); color: var(--color-muted); border-radius: 50%; }

.ranking-cover { width: 56px; height: 56px; border-radius: 12px; object-fit: cover; margin-right: 16px; flex-shrink: 0; }
.ranking-cover-placeholder { width: 56px; height: 56px; border-radius: 12px; background: var(--color-bg-subtle); display: flex; align-items: center; justify-content: center; font-size: 1.4rem; margin-right: 16px; flex-shrink: 0; }

.ranking-info { flex: 1; min-width: 0; }
.ranking-title { font-size: 1.1rem; font-weight: 600; color: var(--color-title); margin-bottom: 4px; }
.ranking-meta { font-size: 0.82rem; color: var(--color-muted); display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
.ranking-meta-tag { display: inline-flex; align-items: center; gap: 2px; }

.ranking-count { font-size: 1.4rem; font-weight: 700; color: var(--color-accent); margin-left: 20px; flex-shrink: 0; }
.ranking-count-label { font-size: 0.7rem; color: var(--color-muted); margin-top: 2px; text-align: center; }

.loading { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px; color: var(--color-muted); gap: 16px; }
.spinner { width: 40px; height: 40px; border: 3px solid var(--color-border-light); border-top-color: var(--color-accent); border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }

.empty-state { text-align: center; padding: 60px; color: var(--color-muted); }

@media (max-width: 768px) {
  .page-title { font-size: 1.5rem; }
  .tabs { gap: 8px; }
  .tab-btn { padding: 10px 16px; font-size: 0.9rem; }
  .ranking-item { padding: 12px 16px; }
  .ranking-rank { width: 40px; height: 40px; font-size: 1rem; margin-right: 12px; }
  .ranking-count { font-size: 1.1rem; }
  .filter-group { flex-wrap: wrap; }
}
</style>

<script>
import { getLikesRanking, getFavoritesRanking, type RankingItem } from '../lib/auth';

declare global {
  interface Window {
    switchRankingTab: (tab: 'likes' | 'favorites') => void;
    setFilter: (el: HTMLElement) => void;
  }
}

let currentTab: 'likes' | 'favorites' = 'likes';
let currentFilters = { cuisine: '', region: '', tag: '' };

window.switchRankingTab = function(tab: 'likes' | 'favorites') {
  currentTab = tab;
  const tabBtns = document.querySelectorAll('.tab-btn');
  const likesList = document.getElementById('likes-ranking');
  const favoritesList = document.getElementById('favorites-ranking');
  
  tabBtns.forEach(btn => {
    btn.classList.toggle('active', btn.getAttribute('data-tab') === tab);
  });
  
  if (tab === 'likes') {
    if (likesList) likesList.style.display = 'block';
    if (favoritesList) favoritesList.style.display = 'none';
  } else {
    if (likesList) likesList.style.display = 'none';
    if (favoritesList) favoritesList.style.display = 'block';
  }
  loadCurrentRanking();
};

window.setFilter = function(el: HTMLElement) {
  const filterType = el.getAttribute('data-filter') || '';
  const value = el.getAttribute('data-value') || '';
  
  // Update active state within same filter group
  const siblings = el.parentElement?.querySelectorAll('.filter-chip') || [];
  siblings.forEach(s => s.classList.remove('active'));
  el.classList.add('active');
  
  // Update filter
  if (filterType === 'cuisine') currentFilters.cuisine = value;
  else if (filterType === 'region') currentFilters.region = value;
  else if (filterType === 'tag') currentFilters.tag = value;
  
  loadCurrentRanking();
};

function renderRankingList(containerId: string, items: RankingItem[], type: 'likes' | 'favorites') {
  const container = document.getElementById(containerId);
  if (!container) return;
  
  if (items.length === 0) {
    container.innerHTML = '<div class="empty-state">暂无数据，快去给喜欢的食谱点赞吧！</div>';
    return;
  }
  
  const countLabel = type === 'likes' ? '点赞' : '收藏';
  const countKey = type === 'likes' ? 'like_count' : 'favorite_count';
  
  container.innerHTML = items.map((item, index) => {
    const rank = index + 1;
    const rankClass = rank <= 3 ? `top-${rank}` : 'normal';
    const title = item.title || item.recipe_slug.replace(/-/g, ' ');
    const coverHtml = item.cover_url 
      ? `<img src="${item.cover_url}" alt="${title}" class="ranking-cover" loading="lazy" />`
      : `<div class="ranking-cover-placeholder">🍽️</div>`;
    
    const metaParts: string[] = [];
    if (item.cuisine) metaParts.push(`<span class="ranking-meta-tag">🍳 ${item.cuisine}</span>`);
    if (item.regions?.length) metaParts.push(...item.regions.map(r => `<span class="ranking-meta-tag">📍 ${r}</span>`));
    if (item.tags?.length) metaParts.push(...item.tags!.map(t => `<span class="ranking-meta-tag"># ${t}</span>`));
    
    return `
      <div class="ranking-item">
        <a href="/recipes/${item.recipe_slug}">
          <div class="ranking-rank ${rankClass}">${rank}</div>
          ${coverHtml}
          <div class="ranking-info">
            <div class="ranking-title">${title}</div>
            <div class="ranking-meta">${metaParts.join('') || '查看食谱详情'}</div>
          </div>
          <div style="text-align:right;flex-shrink:0;margin-left:12px;">
            <div class="ranking-count">${item[countKey as keyof RankingItem] || 0}</div>
            <div class="ranking-count-label">${countLabel}</div>
          </div>
        </a>
      </div>
    `;
  }).join('');
}

async function loadCurrentRanking() {
  const containerId = currentTab === 'likes' ? 'likes-ranking' : 'favorites-ranking';
  const container = document.getElementById(containerId);
  if (!container) return;
  
  container.innerHTML = '<div class="loading"><div class="spinner"></div><span>加载中...</span></div>';
  
  try {
    const fn = currentTab === 'likes' ? getLikesRanking : getFavoritesRanking;
    const result = await fn(50, currentFilters);
    if (result.success && result.data) {
      renderRankingList(containerId, result.data, currentTab);
    } else {
      container.innerHTML = '<div class="empty-state">加载失败，请刷新重试</div>';
    }
  } catch (err) {
    console.error('加载排行榜失败:', err);
    container.innerHTML = '<div class="empty-state">加载失败，请刷新重试</div>';
  }
}

document.addEventListener('DOMContentLoaded', () => {
  loadCurrentRanking();
});
</script>
