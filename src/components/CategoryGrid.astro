---
import { getAllCuisines, getAllTags } from '../lib/strapi';

const cuisines = await getAllCuisines();
const tags = await getAllTags();

// 菜系emoji映射
const cuisineEmoji: Record<string, string> = {
  '川菜': '🌶️', '粤菜': '🥘', '湘菜': '🔥',
  '浙菜': '🍵', '鲁菜': '🍖', '家常菜': '🏠',
};

// 标签emoji映射
const tagEmoji: Record<string, string> = {
  '快手菜': '⚡', '减脂餐': '🥗', '下饭菜': '🍚',
  '夜宵': '🌙', '家常菜': '🏠', '宴客菜': '🎉',
};

// 菜系入口
const cuisineItems = cuisines.slice(0, 6).map((c: any) => ({
  label: c.name,
  href: `/recipes?cuisine=${c.name}`,
  emoji: cuisineEmoji[c.name] || '🍽️',
}));

// 标签入口
const tagItems = tags.slice(0, 6).map((t: any) => ({
  label: t.name,
  href: `/recipes?tag=${t.name}`,
  emoji: t.icon || tagEmoji[t.name] || '🏷️',
}));

// 合并：菜系优先，标签补充
const categories = [...cuisineItems, ...tagItems].slice(0, 6);
---

<section class="section categories-section">
  <div class="container">
    <h2 class="section-title">想做什么菜？</h2>
    <div class="category-grid">
      {categories.map((cat) => (
        <a href={cat.href} class="category-item">
          <span class="category-emoji">{cat.emoji}</span>
          <span class="category-label">{cat.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .category-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 14px;
  }

  .category-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius);
    overflow: hidden;
    aspect-ratio: 1 / 1;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border: 1px solid var(--color-border-light);
    background: var(--color-bg-warm);
    text-decoration: none;
  }

  .category-emoji {
    font-size: 2rem;
    margin-bottom: 8px;
    transition: transform 0.3s;
  }

  .category-item:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
    background: var(--color-accent-light);
  }

  .category-item:hover .category-emoji {
    transform: scale(1.15);
  }

  .category-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-title);
    letter-spacing: 0.02em;
  }

  @media (max-width: 768px) {
    .category-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 480px) {
    .category-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .category-label {
      font-size: 0.75rem;
    }
    .category-emoji {
      font-size: 1.6rem;
    }
  }
</style>
