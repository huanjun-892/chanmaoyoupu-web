    function saveBanner() {
      const data = {
        title: document.getElementById('bn-title').value.trim(),
        image_url: document.getElementById('bn-image').value.trim(),
        link: document.getElementById('bn-link').value.trim(),
        sort_order: parseInt(document.getElementById('bn-sort').value) || 0,
