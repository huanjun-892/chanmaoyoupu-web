---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getAllRecipes, getAllCuisines, getAllTags, getAllRegions, getAllMethods, difficultyLabel, getCoverUrl } from '../../lib/strapi';

const recipes = await getAllRecipes();
const cuisines = await getAllCuisines();
const tags = await getAllTags();
const regions = await getAllRegions();
const methods = await getAllMethods();

const recipeList = recipes.map((r: any) => ({
  title: r.title,
  slug: r.slug,
  difficulty: difficultyLabel(r.difficulty),
  cookTime: r.cookTime,
  calories: r.calories,
  tags: (r.tags || []).map((t: any) => t.name),
  regions: (r.regions || []).map((rg: any) => rg.name),
  cuisine: r.cuisine?.name || '',
  methods: (r.methods || []).map((m: any) => m.name),
  cover: getCoverUrl(r.cover),
}));

const cuisineList = ['全部', ...cuisines.map((c: any) => c.name)];

// 地域排序：国内在前，国外在后，各自按拼音排序
const domesticRegions = ['全国', '北京', '上海', '四川', '广东', '山东', '浙江', '湖南', '江苏', '安徽', '福建', '东北', '云南', '贵州', '西北', '湖北', '广西'];
const internationalRegions = ['日本', '韩国', '法国', '意大利', '东南亚', '印度'];
const allRegionNames = regions.map((r: any) => r.name);
const sortedRegionNames = [
  ...domesticRegions.filter(n => allRegionNames.includes(n)),
  ...internationalRegions.filter(n => allRegionNames.includes(n)),
  ...allRegionNames.filter(n => !domesticRegions.includes(n) && !internationalRegions.includes(n))
];
const regionList = ['全部', ...sortedRegionNames];

const sceneList = ['全部', ...tags.map((t: any) => t.name)];
const difficultyList = ['全部', '入门', '简单', '中级', '高级'];
const methodList = ['全部', ...methods.map((m: any) => m.name)];
---

<BaseLayout 
  title="食谱大全"
  description="馋猫有谱食谱大全，汇聚八大菜系、家常菜、快手菜、宴客菜等各类精选食谱，每道菜都有详细步骤、食材用量和烹饪技巧，新手也能轻松上手。"
  keywords="食谱大全,菜谱,家常菜,快手菜,川菜,粤菜,家常菜做法,烹饪食谱"
>

  <section class="section">
    <div class="container">
      <h1 class="page-title">全部食谱</h1>
      <p class="page-desc">{recipes.length} 道食谱，从入门到进阶</p>

      <!-- 筛选器 -->
      <div class="filters" id="filters">
        <div class="filter-group">
          <span class="filter-label">菜系</span>
          <div class="filter-options">
            {cuisineList.map((c: string) => (
              <button class="filter-btn" data-filter="cuisine" data-value={c === '全部' ? '' : c}>{c}</button>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <span class="filter-label">地域</span>
          <div class="filter-options">
            {regionList.map((r: string) => (
              <button class="filter-btn" data-filter="region" data-value={r === '全部' ? '' : r}>{r}</button>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <span class="filter-label">场景</span>
          <div class="filter-options">
            {sceneList.map((s: string) => (
              <button class="filter-btn" data-filter="tag" data-value={s === '全部' ? '' : s}>{s}</button>
            ))}
          </div>
        </div>

        <div class="filter-group">
          <span class="filter-label">难度</span>
          <div class="filter-options">
            {difficultyList.map((d: string) => (
              <button class="filter-btn" data-filter="difficulty" data-value={d === '全部' ? '' : d}>{d}</button>
            ))}
          </div>
        </div>
        <div class="filter-group">
          <span class="filter-label">做法</span>
          <div class="filter-options">
            {methodList.map((m: string) => (
              <button class="filter-btn" data-filter="method" data-value={m === '全部' ? '' : m}>{m}</button>
            ))}
          </div>
        </div>
      </div>

      <!-- 食谱列表 -->
      <div class="grid-3" id="recipe-grid">
        {recipeList.map((recipe: any) => (
          <div class="recipe-item"
            data-cuisine={recipe.cuisine}
            data-region={recipe.regions.join(',')}
            data-tag={recipe.tags.join(',')}
            data-difficulty={recipe.difficulty}
            data-method={recipe.methods.join(',')}>
            <RecipeCard {...recipe} />
          </div>
        ))}
      </div>

      <div class="empty-state" id="empty-state" style="display:none;">
        <p>没有找到符合条件的食谱，试试其他筛选条件？</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // 客户端筛选逻辑
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const filterType = btn.getAttribute('data-filter');
      const value = btn.getAttribute('data-value');

      // 切换按钮高亮
      btn.parentElement!.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // 收集当前筛选条件
      const activeFilters: Record<string, string> = {};
      document.querySelectorAll('.filter-btn.active').forEach((b: any) => {
        const ft = b.getAttribute('data-filter');
        const fv = b.getAttribute('data-value');
        if (ft && fv) activeFilters[ft] = fv;
      });

      // 筛选显示
      let visibleCount = 0;
      document.querySelectorAll('.recipe-item').forEach((item: any) => {
        let show = true;
        if (activeFilters.cuisine && item.dataset.cuisine !== activeFilters.cuisine) show = false;
        if (activeFilters.region && !item.dataset.region?.split(',').includes(activeFilters.region)) show = false;
        if (activeFilters.tag && !item.dataset.tag?.split(',').includes(activeFilters.tag)) show = false;
        if (activeFilters.difficulty && item.dataset.difficulty !== activeFilters.difficulty) show = false;
        if (activeFilters.method && item.dataset.method && !item.dataset.method.split(',').includes(activeFilters.method)) show = false;

        item.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });

      const emptyEl = document.getElementById('empty-state');
      if (emptyEl) emptyEl.style.display = visibleCount === 0 ? 'block' : 'none';
    });
  });

  // 初始化：默认选中"全部"
  document.querySelectorAll('.filter-group').forEach(group => {
    const firstBtn = group.querySelector('.filter-btn');
    if (firstBtn) firstBtn.classList.add('active');
  });

  // URL参数筛选
  const params = new URLSearchParams(window.location.search);
  if (params.has('cuisine')) {
    const val = params.get('cuisine');
    document.querySelector(`.filter-btn[data-filter="cuisine"][data-value="${val}"]`)?.dispatchEvent(new Event('click'));
  }
  if (params.has('tag')) {
    const val = params.get('tag');
    document.querySelector(`.filter-btn[data-filter="tag"][data-value="${val}"]`)?.dispatchEvent(new Event('click'));
  }
  if (params.has('method')) {
    const val = params.get('method');
    document.querySelector(`.filter-btn[data-filter="method"][data-value="${val}"]`)?.dispatchEvent(new Event('click'));
  }

  if (params.has('difficulty')) {
    const val = params.get('difficulty');
    const labelMap: Record<string, string> = { easy: '入门', simple: '简单', medium: '中级', hard: '高级' };
    const label = labelMap[val || ''] || val;
    document.querySelector(`.filter-btn[data-filter="difficulty"][data-value="${label}"]`)?.dispatchEvent(new Event('click'));
  }
</script>

<style>
  .page-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-title);
    margin-bottom: 8px;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--color-muted);
    margin-bottom: 32px;
  }

  .filters {
    margin-bottom: 32px;
    padding: 20px 24px;
    background: var(--color-bg-warm);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .filter-group {
    margin-bottom: 10px;
    display: flex;
    align-items: baseline;
    gap: 0;
    flex-wrap: wrap;
  }

  .filter-group:last-child {
    margin-bottom: 0;
  }

  .filter-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-muted);
    margin-right: 10px;
    flex-shrink: 0;
    line-height: 32px;
  }

  .filter-options {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 4px 14px;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    background: var(--color-bg);
    color: var(--color-text);
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .filter-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .filter-btn.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: var(--color-muted);
    font-size: 1rem;
  }
</style>
