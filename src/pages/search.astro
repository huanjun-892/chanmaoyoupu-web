---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { searchAll, difficultyLabel, getCoverUrl } from '../lib/strapi';

const url = new URL(Astro.request.url);
const q = url.searchParams.get('q') || '';
const type = url.searchParams.get('type') || 'all';

let results: any = { recipes: [], knowledge: [], ingredients: [], total: 0 };
if (q.trim()) {
  results = await searchAll(q, type);
}
---

<BaseLayout title={`搜索: ${q}`}>
  <section class="section">
    <div class="container">
      <h1 class="page-title">搜索结果</h1>

      <form class="search-form" action="/search" method="get">
        <div class="search-row">
          <input type="text" name="q" value={q} placeholder="搜索食谱、食材、知识库..." class="search-input" />
          <button type="submit" class="search-btn">搜索</button>
        </div>
        <div class="filter-row">
          <label class="filter-label">搜索范围：</label>
          <select name="type" class="filter-select">
            <option value="all" selected={type === 'all'}>全部</option>
            <option value="recipes" selected={type === 'recipes'}>食谱</option>
            <option value="knowledge" selected={type === 'knowledge'}>知识库</option>
            <option value="ingredients" selected={type === 'ingredients'}>食材调料</option>
          </select>
        </div>
      </form>

      {q.trim() ? (
        <>
          <p class="result-summary">找到 <strong>{results.total}</strong> 条与「{q}」相关的结果</p>

          <!-- 分类Tab -->
          <div class="result-tabs">
            <button class="result-tab active" data-type="all">全部 ({results.total})</button>
            <button class="result-tab" data-type="recipes">食谱 ({results.recipes?.length || 0})</button>
            <button class="result-tab" data-type="knowledge">知识库 ({results.knowledge?.length || 0})</button>
            <button class="result-tab" data-type="ingredients">食材调料 ({results.ingredients?.length || 0})</button>
          </div>

          <!-- 食谱结果 -->
          {results.recipes && results.recipes.length > 0 && (
          <div class="result-section" data-section="recipes">
            <h2 class="section-label">🍽 食谱</h2>
            <div class="grid-3">
              {results.recipes.map((r: any) => (
                <RecipeCard
                  title={r.title}
                  slug={r.slug}
                  difficulty={difficultyLabel(r.difficulty)}
                  cookTime={r.cookTime}
                  tags={[]}
                  cover={getCoverUrl(r.cover)}
                />
              ))}
            </div>
          </div>
          )}

          <!-- 知识库结果 -->
          {results.knowledge && results.knowledge.length > 0 && (
          <div class="result-section" data-section="knowledge">
            <h2 class="section-label">📚 知识库</h2>
            <div class="knowledge-list">
              {results.knowledge.map((k: any) => (
                <a href={`/knowledge/${k.slug}`} class="knowledge-item">
                  <span class="knowledge-category">{k.category}</span>
                  <span class="knowledge-title">{k.title}</span>
                </a>
              ))}
            </div>
          </div>
          )}

          <!-- 食材调料结果 -->
          {results.ingredients && results.ingredients.length > 0 && (
          <div class="result-section" data-section="ingredients">
            <h2 class="section-label">🥬 食材调料</h2>
            <div class="ingredient-results">
              {results.ingredients.map((ing: any) => (
                <a href={`/ingredients/${ing.slug}`} class="ingredient-result-item">
                  <span class="ing-icon">{ing.category === 'seasoning' ? '🧂' : '🥬'}</span>
                  <div class="ing-info">
                    <span class="ing-name">{ing.name}</span>
                    <span class="ing-desc">{ing.description ? ing.description.substring(0, 80) : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
          )}

          {results.total === 0 && (
            <div class="no-results">
              <p>没有找到与「{q}」相关的内容</p>
              <p class="hint">试试换个关键词，或搜索食材名、菜名等</p>
            </div>
          )}
        </>
      ) : (
        <div class="no-results">
          <p>请输入关键词开始搜索</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = document.querySelectorAll('.result-tab');
  const sections = document.querySelectorAll('.result-section');
  
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const type = tab.getAttribute('data-type');
      
      sections.forEach(section => {
        if (type === 'all') {
          section.style.display = '';
        } else {
          section.style.display = section.getAttribute('data-section') === type ? '' : 'none';
        }
      });
    });
  });
</script>

<style>
  .page-title { font-size: 2rem; font-weight: 700; color: var(--color-title); margin-bottom: 24px; }

  .search-form { margin-bottom: 28px; }
  .search-row { display: flex; gap: 10px; margin-bottom: 12px; }
  .search-input {
    flex: 1; padding: 12px 16px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 1rem; outline: none;
  }
  .search-input:focus { border-color: var(--color-accent); }
  .search-btn {
    padding: 12px 28px; background: var(--color-accent); color: #fff;
    border: none; border-radius: var(--radius); font-size: 1rem;
    cursor: pointer; font-weight: 600;
  }
  .search-btn:hover { opacity: 0.9; }
  .filter-row { display: flex; align-items: center; gap: 10px; }
  .filter-label { font-size: 0.85rem; color: var(--color-muted); }
  .filter-select {
    padding: 6px 12px; border: 1px solid var(--color-border);
    border-radius: var(--radius); font-size: 0.85rem; outline: none;
  }

  .result-summary { font-size: 0.9rem; color: var(--color-muted); margin-bottom: 20px; }
  .result-summary strong { color: var(--color-accent); }

  .result-tabs { display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap; }
  .result-tab {
    padding: 6px 16px; border: 1px solid var(--color-border); border-radius: 100px;
    background: var(--color-bg); color: var(--color-text); font-size: 0.85rem;
    cursor: pointer; transition: all 0.2s;
  }
  .result-tab:hover { border-color: var(--color-accent); }
  .result-tab.active { background: var(--color-accent); color: #fff; border-color: var(--color-accent); }

  .section-label { font-size: 1.1rem; font-weight: 700; color: var(--color-title); margin-bottom: 16px; }

  .knowledge-list { display: flex; flex-direction: column; gap: 10px; }
  .knowledge-item {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 18px; background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius); text-decoration: none; color: inherit; transition: all 0.2s;
  }
  .knowledge-item:hover { border-color: var(--color-accent); }
  .knowledge-category {
    padding: 2px 10px; border-radius: 100px; font-size: 0.72rem;
    background: #E8F5E9; color: #2E7D32; flex-shrink: 0;
  }
  .knowledge-title { font-size: 0.95rem; font-weight: 500; }

  .ingredient-results { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 12px; }
  .ingredient-result-item {
    display: flex; align-items: center; gap: 12px;
    padding: 14px 18px; background: var(--color-bg); border: 1px solid var(--color-border);
    border-radius: var(--radius); text-decoration: none; color: inherit; transition: all 0.2s;
  }
  .ingredient-result-item:hover { border-color: var(--color-accent); }
  .ing-icon { font-size: 1.5rem; flex-shrink: 0; }
  .ing-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .ing-name { font-size: 0.95rem; font-weight: 600; }
  .ing-desc { font-size: 0.8rem; color: var(--color-muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .no-results { text-align: center; padding: 60px 20px; color: var(--color-muted); }
  .no-results .hint { font-size: 0.85rem; margin-top: 8px; }
</style>
