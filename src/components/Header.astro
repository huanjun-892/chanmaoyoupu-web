---
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <img src="/images/logo-small.png" alt="馋猫有谱" class="logo-icon" width="36" height="36" />
      <span class="logo-text">馋猫有谱</span>
    </a>
    <nav class="nav">
      <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>首页</a>
      <a href="/recipes" class:list={['nav-link', { active: currentPath.startsWith('/recipes') }]}>食谱</a>
      <a href="/knowledge" class:list={['nav-link', { active: currentPath.startsWith('/knowledge') }]}>知识库</a>
    </nav>
    <div class="header-right">
      <form action="/search" method="get" class="search-box">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" name="q" placeholder="搜食谱、食材..." class="search-input" />
      </form>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 252, 248, 0.88);
    backdrop-filter: blur(16px) saturate(180%);
    border-bottom: 1px solid var(--color-border-light);
  }

  .header-inner {
    display: flex;
    align-items: center;
    height: 68px;
    gap: 36px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    white-space: nowrap;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    flex-shrink: 0;
  }

  .logo-text {
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--color-title);
    letter-spacing: -0.01em;
  }

  .nav {
    display: flex;
    gap: 28px;
  }

  .nav-link {
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--color-muted);
    padding: 4px 0;
    position: relative;
    transition: color 0.25s;
  }

  .nav-link:hover {
    color: var(--color-title);
  }

  .nav-link.active {
    color: var(--color-accent);
  }

  .nav-link.active::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 2.5px;
    background: var(--color-accent);
    border-radius: 2px;
  }

  .header-right {
    margin-left: auto;
  }

  .search-box {
    display: flex;
    align-items: center;
    background: var(--color-bg-subtle);
    border: 1.5px solid transparent;
    border-radius: 100px;
    padding: 8px 16px;
    transition: all 0.25s;
    gap: 8px;
  }

  .search-box:focus-within {
    border-color: var(--color-accent);
    background: var(--color-bg);
    box-shadow: 0 0 0 3px var(--color-accent-light);
  }

  .search-icon {
    color: var(--color-muted);
    flex-shrink: 0;
  }

  .search-input {
    border: none;
    background: transparent;
    outline: none;
    font-size: 0.84rem;
    color: var(--color-text);
    width: 160px;
  }

  .search-input::placeholder {
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .nav { gap: 20px; }
    .search-input { width: 110px; }
    .header-inner { gap: 20px; }
  }

  @media (max-width: 480px) {
    .search-input { width: 80px; }
    .header-inner { gap: 14px; }
  }
</style>
