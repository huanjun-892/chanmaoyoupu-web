---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllKnowledge } from '../../lib/strapi';

const allKnowledge = await getAllKnowledge();
const secretItems = allKnowledge.filter((k: any) => k.category === 'secret');

const subCategories: Record<string, { icon: string; label: string }> = {
  classic_broth: { icon: '🍲', label: '经典卤水' },
  braised: { icon: '🍖', label: '卤菜制作' },
  snack: { icon: '🍜', label: '特色小吃' },
  pickle: { icon: '🫙', label: '腌制酱料' },
  northern: { icon: '🥘', label: '北方酱卤' },
};
---

<BaseLayout title="秘方">

  <section class="section">
    <div class="container">
      <h1 class="page-title">🗝️ 美食秘方</h1>
      <p class="page-desc">老师傅不外传的配方，从卤水到调料，从腌制到酱卤，为你一一解密。</p>

      {secretItems.length > 0 ? (
      <div class="secrets-grid">
        {secretItems.map((item: any, idx: number) => {
          const excerpt = item.content ? item.content.replace(/<[^>]*>/g, '').slice(0, 100) + '...' : '';
          const icons = ['🍲', '🍖', '🥩', '🍗', '🍜', '🫕', '🐌', '🫙', '🥓', '🥘'];
          const icon = icons[idx % icons.length];
          return (
            <a href={`/secrets/${item.slug}`} class="secret-card">
              <div class="secret-card-icon">{icon}</div>
              <div class="secret-card-body">
                <h3 class="secret-card-title">{item.title}</h3>
                <p class="secret-card-excerpt">{excerpt}</p>
                <span class="secret-card-link">查看秘方 →</span>
              </div>
            </a>
          );
        })}
      </div>
      ) : (
      <div class="coming-soon">
        <span class="coming-soon-icon">🗝️</span>
        <p class="coming-soon-text">秘方正在整理中，敬请期待！</p>
        <p class="coming-soon-sub">先去看看<a href="/recipes">食谱</a>或<a href="/knowledge">知识库</a>吧～</p>
      </div>
      )}
    </div>
  </section>

</BaseLayout>

<style>
  .page-title { font-size: 2rem; font-weight: 700; color: var(--color-title); margin-bottom: 8px; }
  .page-desc { font-size: 1rem; color: var(--color-muted); margin-bottom: 48px; }

  .secrets-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .secret-card {
    display: flex;
    gap: 20px;
    padding: 24px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all 0.25s;
    text-decoration: none;
  }

  .secret-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(255, 107, 53, 0.1);
  }

  .secret-card-icon {
    font-size: 2.4rem;
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F8F9FA;
    border-radius: 12px;
  }

  .secret-card-body {
    flex: 1;
    min-width: 0;
  }

  .secret-card-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-title);
    margin-bottom: 8px;
  }

  .secret-card-excerpt {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .secret-card-link {
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  .coming-soon { text-align: center; padding: 80px 20px; }
  .coming-soon-icon { font-size: 3rem; display: block; margin-bottom: 16px; }
  .coming-soon-text { font-size: 1.2rem; color: var(--color-title); font-weight: 600; margin-bottom: 8px; }
  .coming-soon-sub { font-size: 0.95rem; color: var(--color-muted); }
  .coming-soon-sub a { color: var(--color-accent); }

  @media (max-width: 768px) {
    .secrets-grid { grid-template-columns: 1fr; }
  }
</style>