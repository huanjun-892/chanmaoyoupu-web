---
// 登录/注册弹窗组件
---

<div id="login-modal" class="modal-overlay" style="display: none;">
  
  <div class="modal-content">
    
    <button class="modal-close" onclick="closeLoginModal()">&times;</button>
    
    
    <div class="modal-tabs">
      <button class="tab-btn active" data-tab="login" onclick="switchTab('login')">登录</button>
      <button class="tab-btn" data-tab="register" onclick="switchTab('register')">注册</button>
    </div>
    
    
    <!-- 登录表单 -->
    <form id="login-form" class="auth-form" onsubmit="handleLogin(event)">
      <div class="form-group">
        <label for="login-email">邮箱</label>
        <input type="email" id="login-email" name="email" required placeholder="请输入邮箱">
      </div>
      <div class="form-group">
        <label for="login-password">密码</label>
        <input type="password" id="login-password" name="password" required placeholder="请输入密码" minlength="6">
      </div>
      <div id="login-error" class="error-msg" style="display: none;"></div>
      <button type="submit" class="submit-btn">登录</button>
    </form>
    
    
    <!-- 注册表单 -->
    <form id="register-form" class="auth-form" style="display: none;" onsubmit="handleRegister(event)">
      <div class="form-group">
        <label for="register-nickname">昵称</label>
        <div class="nickname-input-wrap">
          <input type="text" id="register-nickname" name="nickname" placeholder="不填则自动生成趣味昵称" maxlength="20">
          <span id="nickname-status" class="nickname-status"></span>
        </div>
      </div>
      <div class="form-group">
        <label for="register-email">邮箱 <span class="required">*</span></label>
        <input type="email" id="register-email" name="email" required placeholder="请输入邮箱">
      </div>
      <div class="form-group">
        <label for="register-password">密码 <span class="required">*</span></label>
        <input type="password" id="register-password" name="password" required placeholder="至少6位" minlength="6">
      </div>
      <div class="form-group">
        <label for="register-confirm">确认密码 <span class="required">*</span></label>
        <input type="password" id="register-confirm" name="confirm" required placeholder="请再次输入密码" minlength="6">
      </div>
      <div class="optional-divider">以下信息选填</div>
      <div class="form-group optional">
        <label for="register-phone">手机号</label>
        <input type="tel" id="register-phone" name="phone" placeholder="选填，如13800138000" maxlength="11">
      </div>
      <div class="form-group optional">
        <label for="register-birthday">出生日期</label>
        <input type="date" id="register-birthday" name="birthday" placeholder="选填">
      </div>
      <div id="register-error" class="error-msg" style="display: none;"></div>
      <button type="submit" class="submit-btn">注册</button>
    </form>
    
    <div class="oauth-divider">
      <span>其他登录方式</span>
    </div>
    
    <div class="oauth-buttons">
      <button class="oauth-btn" onclick="oauthLogin('wechat')" title="微信登录（即将开放）">
        <svg viewBox="0 0 24 24" width="24" height="24"><path fill="#07C160" d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.047c.134 0 .24-.111.24-.247 0-.06-.023-.12-.038-.173l-.327-1.233a.582.582 0 01-.023-.156.49.49 0 01.201-.398C23.024 18.48 24 16.82 24 14.98c0-3.21-2.931-5.837-6.656-6.088V8.89l-.407-.032zm-1.834 2.994c.536 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.433-.982.97-.982zm4.857 0c.536 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.433-.982.969-.982z"/></svg>
        <span>微信</span>
      </button>
      <button class="oauth-btn" onclick="oauthLogin('douyin')" title="抖音登录（即将开放）">
        <svg viewBox="0 0 24 24" width="24" height="24"><path fill="#161823" d="M12.53.02C13.84 0 15.14.01 16.44 0c.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
        <span>抖音</span>
      </button>
      <button class="oauth-btn" onclick="oauthLogin('kuaishou')" title="快手登录（即将开放）">
        <svg viewBox="0 0 24 24" width="24" height="24"><path fill="#FF4906" d="M12.006 4.295c-2.67 0-4.79 2.12-4.79 4.79v6.13c0 2.67 2.12 4.79 4.79 4.79h4.79c2.67 0 4.79-2.12 4.79-4.79v-6.13c0-2.67-2.12-4.79-4.79-4.79h-4.79zm0 1.6a3.19 3.19 0 013.19 3.19v6.13a3.19 3.19 0 01-3.19 3.19h-4.79a3.19 3.19 0 01-3.19-3.19v-6.13a3.19 3.19 0 013.19-3.19h4.79zM9.005 8.895c-.552 0-1 .448-1 1v4.21c0 .552.448 1 1 1s1-.448 1-1v-4.21c0-.552-.448-1-1-1zm6 0c-.552 0-1 .448-1 1v4.21c0 .552.448 1 1 1s1-.448 1-1v-4.21c0-.552-.448-1-1-1zm-3 6c-1.657 0-3 1.343-3 3s1.343 3 3 3 3-1.343 3-3-1.343-3-3-3zm0 1.6a1.4 1.4 0 110 2.8 1.4 1.4 0 010-2.8z"/></svg>
        <span>快手</span>
      </button>
    </div>
  </div>
</div>

<style>
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  backdrop-filter: blur(4px);
}

.modal-content {
  background: #fff;
  border-radius: 16px;
  padding: 32px;
  width: 90%;
  max-width: 420px;
  min-width: 320px;
  position: relative;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  max-height: 90vh;
  overflow-y: auto;
}

.modal-close {
  position: absolute;
  top: 16px;
  right: 16px;
  background: none;
  border: none;
  font-size: 24px;
  cursor: pointer;
  color: #999;
  padding: 4px;
  line-height: 1;
}

.modal-close:hover { color: #333; }

.modal-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
  flex-wrap: nowrap;
}

.tab-btn {
  flex: 1;
  padding: 12px 0;
  border: none;
  background: #f5f5f5;
  border-radius: 8px;
  cursor: pointer;
  font-size: 15px;
  font-weight: 500;
  color: #666;
  transition: all 0.2s;
  white-space: nowrap;
}

.tab-btn.active {
  background: #ff6b35;
  color: #fff;
}

.tab-btn:hover:not(.active) { background: #eee; }

.auth-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-group label {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.form-group label .required {
  color: #e53935;
  font-size: 12px;
}

.form-group input {
  padding: 12px 16px;
  border: 1px solid #ddd;
  border-radius: 8px;
  font-size: 15px;
  transition: border-color 0.2s;
}

.form-group input:focus {
  outline: none;
  border-color: #ff6b35;
}

.form-group.optional label {
  color: #888;
  font-weight: 400;
}

.nickname-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.nickname-input-wrap input {
  flex: 1;
  padding-right: 30px;
}

.nickname-status {
  position: absolute;
  right: 10px;
  font-size: 16px;
  font-weight: bold;
}

.nickname-status.available { color: #4caf50; }
.nickname-status.taken { color: #e53935; }
.nickname-status.checking { color: #ff9800; }

.optional-divider {
  text-align: center;
  color: #bbb;
  font-size: 13px;
  border-top: 1px dashed #e0e0e0;
  padding-top: 12px;
  margin: 4px 0;
}

.error-msg {
  color: #e53935;
  font-size: 13px;
  padding: 8px 12px;
  background: #ffebee;
  border-radius: 6px;
}

.submit-btn {
  padding: 14px;
  background: linear-gradient(135deg, #ff6b35, #ff8f65);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 16px;
  font-weight: 600;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}

.submit-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(255, 107, 53, 0.4);
}

.submit-btn:active { transform: translateY(0); }

.submit-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
  transform: none;
}

.oauth-divider {
  display: flex;
  align-items: center;
  margin: 24px 0 16px;
  color: #999;
  font-size: 13px;
}

.oauth-divider::before,
.oauth-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #eee;
}

.oauth-divider span { padding: 0 12px; }

.oauth-buttons {
  display: flex;
  justify-content: center;
  gap: 24px;
}

.oauth-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  background: none;
  border: none;
  cursor: pointer;
  color: #666;
  font-size: 12px;
  padding: 8px;
  border-radius: 8px;
  transition: background 0.2s;
}

.oauth-btn:hover { background: #f5f5f5; }
.oauth-btn:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

<script>
import { login, register, checkNickname, oauthLogin, logout, getStoredUser, isLoggedIn, onAuthChange, updateProfile, type User } from '../lib/auth';

declare global {
  interface Window {
    openLoginModal: () => void;
    closeLoginModal: () => void;
    switchTab: (tab: 'login' | 'register') => void;
    handleLogin: (e: Event) => Promise<void>;
    handleRegister: (e: Event) => Promise<void>;
    oauthLogin: (provider: string) => Promise<void>;
    updateAuthUI: () => void;
    handleLogout: () => void;
  }
}

// 打开登录弹窗
window.openLoginModal = function() {
  const modal = document.getElementById('login-modal');
  if (modal) {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  }
};

// 关闭登录弹窗
window.closeLoginModal = function() {
  const modal = document.getElementById('login-modal');
  if (modal) {
    modal.style.display = 'none';
    document.body.style.overflow = '';
    const loginForm = document.getElementById('login-form') as HTMLFormElement;
    const registerForm = document.getElementById('register-form') as HTMLFormElement;
    const loginError = document.getElementById('login-error');
    const registerError = document.getElementById('register-error');
    if (loginForm) loginForm.reset();
    if (registerForm) registerForm.reset();
    if (loginError) loginError.style.display = 'none';
    if (registerError) registerError.style.display = 'none';
    const nicknameStatus = document.getElementById('nickname-status');
    if (nicknameStatus) { nicknameStatus.textContent = ''; nicknameStatus.className = 'nickname-status'; }
  }
};

// 切换标签
window.switchTab = function(tab: 'login' | 'register') {
  const loginForm = document.getElementById('login-form');
  const registerForm = document.getElementById('register-form');
  const tabBtns = document.querySelectorAll('.modal-tabs .tab-btn');
  
  tabBtns.forEach(btn => {
    if (btn.getAttribute('data-tab') === tab) {
      btn.classList.add('active');
    } else {
      btn.classList.remove('active');
    }
  });
  
  if (tab === 'login') {
    if (loginForm) loginForm.style.display = 'flex';
    if (registerForm) registerForm.style.display = 'none';
  } else {
    if (loginForm) loginForm.style.display = 'none';
    if (registerForm) registerForm.style.display = 'flex';
  }
};

// 显示错误
function showError(elementId: string, message: string) {
  const errorEl = document.getElementById(elementId);
  if (errorEl) {
    errorEl.textContent = message;
    errorEl.style.display = 'block';
  }
}

// 手机号校验（宽松模式：11位数字，1开头即可）
function isValidPhone(phone: string): boolean {
  if (!phone) return true; // 选填，空值合法
  return /^1\d{10}$/.test(phone);
}

// 昵称实时查重
let nicknameCheckTimer: any = null;
const nicknameInput = document.getElementById('register-nickname') as HTMLInputElement;
if (nicknameInput) {
  nicknameInput.addEventListener('input', () => {
    const nickname = nicknameInput.value.trim();
    const statusEl = document.getElementById('nickname-status');
    if (!statusEl) return;
    
    if (!nickname || nickname.length < 2) {
      statusEl.textContent = '';
      statusEl.className = 'nickname-status';
      return;
    }
    
    // 防抖：输入后500ms再查询
    clearTimeout(nicknameCheckTimer);
    statusEl.textContent = '⏳';
    statusEl.className = 'nickname-status checking';
    
    nicknameCheckTimer = setTimeout(async () => {
      try {
        const result = await checkNickname(nickname);
        if (result.success && result.data) {
          if (result.data.available) {
            statusEl.textContent = '✓';
            statusEl.className = 'nickname-status available';
          } else {
            statusEl.textContent = '✗';
            statusEl.className = 'nickname-status taken';
          }
        }
      } catch {
        statusEl.textContent = '';
        statusEl.className = 'nickname-status';
      }
    }, 500);
  });
}

// 处理登录
window.handleLogin = async function(e: Event) {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
  const email = (form.querySelector('#login-email') as HTMLInputElement).value;
  const password = (form.querySelector('#login-password') as HTMLInputElement).value;
  
  submitBtn.disabled = true;
  submitBtn.textContent = '登录中...';
  showError('login-error', '');
  
  try {
    const result = await login(email, password);
    if (result.success && result.data) {
      window.closeLoginModal();
      window.updateAuthUI();
      window.dispatchEvent(new CustomEvent('login_success', { detail: result.data.user }));
    } else {
      showError('login-error', result.error || '登录失败');
    }
  } catch (err: any) {
    showError('login-error', err.message || '网络错误，请重试');
  } finally {
    submitBtn.disabled = false;
    submitBtn.textContent = '登录';
  }
};

// 处理注册
window.handleRegister = async function(e: Event) {
  e.preventDefault();
  const form = e.target as HTMLFormElement;
  const submitBtn = form.querySelector('.submit-btn') as HTMLButtonElement;
  const nickname = (form.querySelector('#register-nickname') as HTMLInputElement).value.trim();
  const email = (form.querySelector('#register-email') as HTMLInputElement).value;
  const password = (form.querySelector('#register-password') as HTMLInputElement).value;
  const confirm = (form.querySelector('#register-confirm') as HTMLInputElement).value;
  const phone = (form.querySelector('#register-phone') as HTMLInputElement).value.trim();
  const birthday = (form.querySelector('#register-birthday') as HTMLInputElement).value;
  
  submitBtn.disabled = true;
  submitBtn.textContent = '注册中...';
  showError('register-error', '');
  
  // 手机号格式校验
  if (phone && !isValidPhone(phone)) {
    showError('register-error', '手机号格式不正确，请输入11位手机号');
    submitBtn.disabled = false;
    submitBtn.textContent = '注册';
    return;
  }
  
  // 检查昵称是否已被占用
  if (nickname) {
    const nickResult = await checkNickname(nickname);
    if (nickResult.success && nickResult.data && !nickResult.data.available) {
      showError('register-error', '该昵称已被使用，请换一个');
      submitBtn.disabled = false;
      submitBtn.textContent = '注册';
      return;
    }
  }
  
  if (password !== confirm) {
    showError('register-error', '两次输入的密码不一致');
    submitBtn.disabled = false;
    submitBtn.textContent = '注册';
    return;
  }
  
  try {
    const result = await register(email, password, nickname || undefined, phone || undefined, birthday || undefined);
    if (result.success && result.data) {
      window.closeLoginModal();
      window.updateAuthUI();
      window.dispatchEvent(new CustomEvent('login_success', { detail: result.data.user }));
    } else {
      showError('register-error', result.error || '注册失败');
    }
  } catch (err: any) {
    showError('register-error', err.message || '网络错误，请重试');
  } finally {
    submitBtn.disabled = false;
    submitBtn.textContent = '注册';
  }
};

// OAuth登录（预留）
window.oauthLogin = async function(provider: string) {
  const result = await oauthLogin(provider as 'wechat' | 'douyin' | 'kuaishou');
  if (!result.success) {
    alert(result.error || '该登录方式暂未开放');
  }
};

// 退出登录
  // handleLogout is defined in Header.astro
  // Just call it from the logout button onclick

// 更新认证UI
  // updateAuthUI is defined in Header.astro

// 点击遮罩关闭
document.getElementById('login-modal')?.addEventListener('click', (e) => {
  if (e.target === e.currentTarget) {
    window.closeLoginModal();
  }
});

// ESC键关闭
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    window.closeLoginModal();
    // 同时关闭用户下拉菜单
    const dropdown = document.getElementById('user-dropdown');
    if (dropdown) dropdown.classList.remove('show');
  }
});

// 初始化UI
document.addEventListener('DOMContentLoaded', () => {
  window.updateAuthUI();
});

// 监听认证状态变化
onAuthChange(() => {
  window.updateAuthUI();
});
</script>
