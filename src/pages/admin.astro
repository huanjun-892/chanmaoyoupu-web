---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="管理后台 - 馋猫有谱" description="馋猫有谱网站管理后台">
  <!-- Quill 富文本编辑器 -->
  <link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
  
  <style>
    .admin-container {
      display: flex;
      min-height: calc(100vh - 80px);
      background: var(--color-bg-secondary);
    }
    
    .admin-sidebar {
      width: 220px;
      background: var(--color-bg);
      border-right: 1px solid var(--color-border);
      padding: 20px 0;
      flex-shrink: 0;
    }
    
    .admin-logo {
      padding: 0 20px 20px;
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 10px;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--color-accent);
    }
    
    .admin-nav {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    
    .admin-nav li {
      margin-bottom: 2px;
    }
    
    .admin-nav a {
      display: block;
      padding: 12px 20px;
      color: var(--color-text-secondary);
      text-decoration: none;
      font-size: 0.9rem;
      transition: all 0.2s;
      cursor: pointer;
      border-left: 3px solid transparent;
    }
    
    .admin-nav a:hover {
      background: var(--color-bg-secondary);
      color: var(--color-text);
    }
    
    .admin-nav a.active {
      background: var(--color-accent-light);
      color: var(--color-accent);
      border-left-color: var(--color-accent);
      font-weight: 500;
    }
    
    .admin-main {
      flex: 1;
      padding: 24px;
      overflow-y: auto;
    }
    
    .admin-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 24px;
    }
    
    .admin-header h1 {
      font-size: 1.4rem;
      margin: 0;
      color: var(--color-title);
    }
    
    .admin-user {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 0.9rem;
      color: var(--color-text-secondary);
    }
    
    .btn {
      padding: 8px 16px;
      border-radius: var(--radius-sm);
      border: none;
      cursor: pointer;
      font-size: 0.85rem;
      font-weight: 500;
      transition: all 0.2s;
    }
    
    .btn-primary {
      background: var(--color-accent);
      color: white;
    }
    
    .btn-primary:hover {
      background: var(--color-accent-dark);
    }
    
    .btn-secondary {
      background: var(--color-bg);
      color: var(--color-text);
      border: 1px solid var(--color-border);
    }
    
    .btn-secondary:hover {
      background: var(--color-bg-secondary);
    }
    
    .btn-danger {
      background: #fee2e2;
      color: #dc2626;
    }
    
    .btn-sm {
      padding: 5px 10px;
      font-size: 0.75rem;
    }
    
    /* 统计卡片 */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 30px;
    }
    
    .stat-card {
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 20px;
    }
    
    .stat-number {
      font-size: 2rem;
      font-weight: 700;
      color: var(--color-accent);
      margin-bottom: 5px;
    }
    
    .stat-label {
      font-size: 0.9rem;
      color: var(--color-text-secondary);
    }
    
    /* 表格 */
    .data-table {
      width: 100%;
      border-collapse: collapse;
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      overflow: hidden;
    }
    
    .data-table th {
      background: var(--color-bg-secondary);
      padding: 12px 16px;
      text-align: left;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--color-text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      border-bottom: 1px solid var(--color-border);
    }
    
    .data-table td {
      padding: 12px 16px;
      border-bottom: 1px solid var(--color-border);
      font-size: 0.9rem;
    }
    
    .data-table tr:last-child td {
      border-bottom: none;
    }
    
    .data-table tr:hover {
      background: var(--color-bg-secondary);
    }
    
    /* 搜索栏 */
    .toolbar {
      display: flex;
      gap: 12px;
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    
    .search-input {
      flex: 1;
      min-width: 200px;
      padding: 8px 12px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      font-size: 0.9rem;
      background: var(--color-bg);
      color: var(--color-text);
    }
    
    .search-input:focus {
      outline: none;
      border-color: var(--color-accent);
    }
    
    /* 分页 */
    .pagination {
      display: flex;
      gap: 8px;
      margin-top: 16px;
      align-items: center;
      justify-content: flex-end;
    }
    
    .pagination button {
      padding: 6px 12px;
      border: 1px solid var(--color-border);
      background: var(--color-bg);
      border-radius: var(--radius-sm);
      cursor: pointer;
      font-size: 0.8rem;
      color: var(--color-text);
    }
    
    .pagination button:hover:not(:disabled) {
      border-color: var(--color-accent);
      color: var(--color-accent);
    }
    
    .pagination button:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    
    .pagination .page-info {
      font-size: 0.85rem;
      color: var(--color-text-secondary);
    }
    
    /* Tab切换 */
    .tabs {
      display: flex;
      gap: 4px;
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 20px;
    }
    
    .tab-btn {
      padding: 10px 16px;
      background: none;
      border: none;
      cursor: pointer;
      font-size: 0.9rem;
      color: var(--color-text-secondary);
      border-bottom: 2px solid transparent;
      margin-bottom: -1px;
    }
    
    .tab-btn.active {
      color: var(--color-accent);
      border-bottom-color: var(--color-accent);
      font-weight: 500;
    }
    
    /* 状态标签 */
    .status-badge {
      display: inline-block;
      padding: 3px 8px;
      border-radius: 20px;
      font-size: 0.75rem;
      font-weight: 500;
    }
    
    .status-published {
      background: #dcfce7;
      color: #166534;
    }
    
    .status-draft {
      background: #fef3c7;
      color: #92400e;
    }
    
    /* 弹窗 */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 1000;
    }
    
    .modal-overlay.show {
      display: flex;
    }
    
    .modal-content {
      background: var(--color-bg);
      border-radius: var(--radius);
      width: 90%;
      max-width: 600px;
      max-height: 80vh;
      overflow-y: auto;
    }
    
    .modal-header {
      padding: 16px 20px;
      border-bottom: 1px solid var(--color-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .modal-header h3 {
      margin: 0;
      font-size: 1.1rem;
      color: var(--color-title);
    }
    
    .modal-close {
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--color-text-secondary);
      line-height: 1;
    }
    
    .modal-body {
      padding: 20px;
    }
    
    .modal-footer {
      padding: 16px 20px;
      border-top: 1px solid var(--color-border);
      display: flex;
      justify-content: flex-end;
      gap: 10px;
    }
    
    .form-group {
      margin-bottom: 16px;
    }
    
    .form-group label {
      display: block;
      margin-bottom: 6px;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--color-text);
    }
    
    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 8px 12px;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      font-size: 0.9rem;
      background: var(--color-bg);
      color: var(--color-text);
    }
    
    .form-group textarea {
      min-height: 80px;
      resize: vertical;
    }
    
    /* Quill 编辑器样式 */
    .ql-container {
      font-size: 0.9rem;
      background: var(--color-bg);
      border-bottom-left-radius: var(--radius-sm);
      border-bottom-right-radius: var(--radius-sm);
    }
    
    .ql-toolbar {
      background: var(--color-bg-secondary);
      border-top-left-radius: var(--radius-sm);
      border-top-right-radius: var(--radius-sm);
    }
    
    .ql-editor {
      min-height: 80px;
      color: var(--color-text);
    }
    
    .ql-editor.ql-blank::before {
      color: var(--color-text-secondary);
      font-style: normal;
    }
    
    .ql-snow .ql-stroke {
      stroke: var(--color-text-secondary);
    }
    
    .ql-snow .ql-fill,
    .ql-snow .ql-stroke.ql-fill {
      fill: var(--color-text-secondary);
    }
    
    .ql-snow.ql-toolbar button:hover,
    .ql-snow .ql-toolbar button:hover,
    .ql-snow.ql-toolbar button.ql-active,
    .ql-snow .ql-toolbar button.ql-active {
      color: var(--color-accent);
    }
    
    .ql-snow.ql-toolbar button:hover .ql-stroke,
    .ql-snow .ql-toolbar button:hover .ql-stroke,
    .ql-snow.ql-toolbar button.ql-active .ql-stroke,
    .ql-snow .ql-toolbar button.ql-active .ql-stroke {
      stroke: var(--color-accent);
    }
    
    .ql-snow.ql-toolbar button:hover .ql-fill,
    .ql-snow .ql-toolbar button:hover .ql-fill,
    .ql-snow.ql-toolbar button.ql-active .ql-fill,
    .ql-snow .ql-toolbar button.ql-active .ql-fill {
      fill: var(--color-accent);
    }
    
    .ql-editor h3 {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 8px;
      color: var(--color-title);
    }
    
    .ql-editor ul,
    .ql-editor ol {
      padding-left: 20px;
      margin-bottom: 8px;
    }
    
    .ql-editor li {
      margin-bottom: 4px;
    }
    
    .ql-editor strong {
      font-weight: 600;
    }
    
    /* 小尺寸编辑器 */
    .quill-small .ql-editor {
      min-height: 60px;
      padding: 8px 12px;
    }
    
    .quill-small .ql-toolbar {
      padding: 4px 8px;
    }
    
    .quill-small .ql-toolbar button {
      height: 24px;
      width: 24px;
      padding: 2px;
    }
    
    .form-group input:focus,
    .form-group textarea:focus,
    .form-group select:focus {
      outline: none;
      border-color: var(--color-accent);
    }
    
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    
    /* 加载状态 */
    .loading {
      text-align: center;
      padding: 40px;
      color: var(--color-text-secondary);
    }
    
    .spinner {
      display: inline-block;
      width: 30px;
      height: 30px;
      border: 3px solid var(--color-border);
      border-top-color: var(--color-accent);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      margin-bottom: 10px;
    }
    
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    
    /* Toast提示 */
    .toast {
      position: fixed;
      top: 20px;
      right: 20px;
      padding: 12px 20px;
      border-radius: var(--radius-sm);
      color: white;
      font-size: 0.9rem;
      z-index: 2000;
      animation: slideIn 0.3s ease;
    }
    
    .toast-success {
      background: #22c55e;
    }
    
    .toast-error {
      background: #ef4444;
    }
    
    @keyframes slideIn {
      from {
        transform: translateX(100%);
        opacity: 0;
      }
      to {
        transform: translateX(0);
        opacity: 1;
      }
    }
    
    .page-section {
      display: none;
    }
    
    .page-section.active {
      display: block;
    }
    
    @media (max-width: 768px) {
      .admin-sidebar {
        width: 60px;
      }
      
      .admin-logo span,
      .admin-nav a span {
        display: none;
      }
      
      .admin-nav a {
        text-align: center;
        padding: 12px 0;
      }
    }
  </style>
  
  <div class="admin-container">
    <!-- 侧边栏 -->
    <aside class="admin-sidebar">
      <div class="admin-logo">🐱 <span>管理后台</span></div>
      <ul class="admin-nav">
        <li><a data-page="dashboard" class="active">📊 <span>数据概览</span></a></li>
        <li><a data-page="recipes">🍜 <span>食谱管理</span></a></li>
        <li><a data-page="ingredients">🥬 <span>食材管理</span></a></li>
        <li><a data-page="knowledge">📚 <span>知识库管理</span></a></li>
        <li><a data-page="categories">🏷️ <span>分类管理</span></a></li>
        <li><a data-page="push">📱 <span>内容推送助手</span></a></li>
      </ul>
    </aside>
    
    <!-- 主内容区 -->
    <main class="admin-main">
      <div class="admin-header">
        <h1 id="page-title">数据概览</h1>
        <div class="admin-user">
          <span id="user-email">加载中...</span>
          <button class="btn btn-secondary btn-sm" onclick="logout()">退出</button>
        </div>
      </div>
      
      <!-- 数据概览 -->
      <section id="page-dashboard" class="page-section active">
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-number" id="stat-recipes">-</div>
            <div class="stat-label">食谱总数</div>
          </div>
          <div class="stat-card">
            <div class="stat-number" id="stat-ingredients">-</div>
            <div class="stat-label">食材数量</div>
          </div>
          <div class="stat-card">
            <div class="stat-number" id="stat-knowledge">-</div>
            <div class="stat-label">知识库文章</div>
          </div>
          <div class="stat-card">
            <div class="stat-number" id="stat-cuisines">-</div>
            <div class="stat-label">菜系分类</div>
          </div>
          <div class="stat-card">
            <div class="stat-number" id="stat-tags">-</div>
            <div class="stat-label">标签数量</div>
          </div>
          <div class="stat-card">
            <div class="stat-number" id="stat-users">-</div>
            <div class="stat-label">注册用户</div>
          </div>
        </div>
      </section>
      
      <!-- 食谱管理 -->
      <section id="page-recipes" class="page-section">
        <div class="toolbar">
          <input type="text" class="search-input" id="recipe-search" placeholder="搜索食谱标题或slug..." oninput="searchRecipes()">
          <select class="search-input" id="recipe-status" onchange="searchRecipes()">
            <option value="">全部状态</option>
            <option value="1">已发布</option>
            <option value="0">草稿</option>
          </select>
          <button class="btn btn-primary" onclick="openRecipeModal()">+ 新增食谱</button>
        </div>
        <div id="recipes-table-container">
          <div class="loading"><div class="spinner"></div><p>加载中...</p></div>
        </div>
        <div class="pagination" id="recipes-pagination"></div>
      </section>
      
      <!-- 食材管理 -->
      <section id="page-ingredients" class="page-section">
        <div class="toolbar">
          <input type="text" class="search-input" id="ingredient-search" placeholder="搜索食材名称..." oninput="searchIngredients()">
          <button class="btn btn-primary" onclick="openIngredientModal()">+ 新增食材</button>
        </div>
        <div id="ingredients-table-container">
          <div class="loading"><div class="spinner"></div><p>加载中...</p></div>
        </div>
        <div class="pagination" id="ingredients-pagination"></div>
      </section>
      
      <!-- 知识库管理 -->
      <section id="page-knowledge" class="page-section">
        <div class="toolbar">
          <input type="text" class="search-input" id="knowledge-search" placeholder="搜索文章标题..." oninput="searchKnowledge()">
          <select class="search-input" id="knowledge-category" onchange="searchKnowledge()">
            <option value="">全部分类</option>
            <option value="secret">独家秘方</option>
            <option value="普通">普通文章</option>
          </select>
          <button class="btn btn-primary" onclick="openKnowledgeModal()">+ 新增文章</button>
        </div>
        <div id="knowledge-table-container">
          <div class="loading"><div class="spinner"></div><p>加载中...</p></div>
        </div>
        <div class="pagination" id="knowledge-pagination"></div>
      </section>
      
      <!-- 分类管理 -->
      <section id="page-categories" class="page-section">
        <div class="tabs">
          <button class="tab-btn active" data-tab="cuisines" onclick="switchCategoryTab('cuisines')">菜系</button>
          <button class="tab-btn" data-tab="tags" onclick="switchCategoryTab('tags')">标签</button>
          <button class="tab-btn" data-tab="regions" onclick="switchCategoryTab('regions')">地区</button>
          <button class="tab-btn" data-tab="methods" onclick="switchCategoryTab('methods')">做法</button>
        </div>
        
        <div id="tab-cuisines" class="tab-content">
          <div class="toolbar">
            <input type="text" class="search-input" id="cuisine-search" placeholder="搜索菜系..." oninput="searchCuisines()">
            <button class="btn btn-primary" onclick="openCuisineModal()">+ 新增菜系</button>
          </div>
          <div id="cuisines-table-container"></div>
        </div>
        
        <div id="tab-tags" class="tab-content" style="display:none;">
          <div class="toolbar">
            <input type="text" class="search-input" id="tag-search" placeholder="搜索标签..." oninput="searchTags()">
            <button class="btn btn-primary" onclick="openTagModal()">+ 新增标签</button>
          </div>
          <div id="tags-table-container"></div>
        </div>
        
        <div id="tab-regions" class="tab-content" style="display:none;">
          <div class="toolbar">
            <input type="text" class="search-input" id="region-search" placeholder="搜索地区..." oninput="searchRegions()">
            <button class="btn btn-primary" onclick="openRegionModal()">+ 新增地区</button>
          </div>
          <div id="regions-table-container"></div>
        </div>
        
        <div id="tab-methods" class="tab-content" style="display:none;">
          <div class="toolbar">
            <input type="text" class="search-input" id="method-search" placeholder="搜索做法..." oninput="searchMethods()">
            <button class="btn btn-primary" onclick="openMethodModal()">+ 新增做法</button>
          </div>
          <div id="methods-table-container"></div>
        </div>
      </section>
      
      <!-- 内容推送助手 -->
      <section id="page-push" class="page-section">
        <div class="stats-grid">
          <div class="stat-card" style="cursor: pointer; border: 2px solid var(--color-accent);" onclick="selectPlatform('wechat')">
            <div class="stat-number">💬</div>
            <div class="stat-label">公众号</div>
          </div>
          <div class="stat-card" style="cursor: pointer;" onclick="selectPlatform('xiaohongshu')">
            <div class="stat-number">📕</div>
            <div class="stat-label">小红书</div>
          </div>
          <div class="stat-card" style="cursor: pointer;" onclick="selectPlatform('douyin')">
            <div class="stat-number">🎵</div>
            <div class="stat-label">抖音</div>
          </div>
          <div class="stat-card" style="cursor: pointer;" onclick="selectPlatform('toutiao')">
            <div class="stat-number">📰</div>
            <div class="stat-label">头条</div>
          </div>
          <div class="stat-card" style="cursor: pointer;" onclick="selectPlatform('bilibili')">
            <div class="stat-number">📺</div>
            <div class="stat-label">B站</div>
          </div>
        </div>
        
        <div style="background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius); padding: 20px;">
          <h3 style="margin-top: 0; color: var(--color-title);">生成推送内容</h3>
          <div class="form-group">
            <label>选择内容类型</label>
            <select id="push-content-type" onchange="loadPushContent()">
              <option value="recipe">食谱</option>
              <option value="knowledge">知识库文章</option>
            </select>
          </div>
          <div class="form-group">
            <label>选择内容</label>
            <select id="push-content-select" onchange="generatePushContent()">
              <option value="">请先选择内容类型</option>
            </select>
          </div>
          <div class="form-group">
            <label>生成的内容</label>
            <textarea id="push-content-result" rows="10" readonly style="background: var(--color-bg-secondary);"></textarea>
          </div>
          <button class="btn btn-primary" onclick="copyPushContent()" style="width: 100%;">📋 一键复制内容</button>
        </div>
        
        <p style="color: var(--color-text-secondary); font-size: 0.85rem; margin-top: 16px; text-align: center;">
          💡 提示：选择平台和内容后，自动生成适配该平台风格的文案，一键复制发布
        </p>
      </section>
    </main>
  </div>
  
  <!-- 编辑弹窗 -->
  <div class="modal-overlay" id="edit-modal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 id="modal-title">编辑</h3>
        <button class="modal-close" onclick="closeModal()">&times;</button>
      </div>
      <div class="modal-body" id="modal-body"></div>
      <div class="modal-footer" id="modal-footer">
        <button class="btn btn-secondary" onclick="closeModal()">取消</button>
        <button class="btn btn-primary" onclick="saveItem()">保存</button>
      </div>
    </div>
  </div>

  <script is:inline>
    const API_BASE = 'https://api.chanmaoyoupu.com/api/admin';
    let currentPage = { recipes: 1, ingredients: 1, knowledge: 1 };
    let currentItem = null;
    let currentItemType = null;
    let currentCategoryTab = 'cuisines';
    let currentPlatform = 'wechat';
    let quillEditors = {}; // 存储所有 Quill 编辑器实例
    
    // ============ Quill 富文本编辑器工具函数 ============
    function initQuillEditor(containerId, options = {}) {
      // 如果已存在，先销毁
      if (quillEditors[containerId]) {
        quillEditors[containerId].destroy();
        delete quillEditors[containerId];
      }
      
      const container = document.getElementById(containerId);
      if (!container) return null;
      
      // 创建 Quill 容器结构
      const editorId = containerId + '-editor';
      container.innerHTML = `<div id="${editorId}"></div>`;
      
      const defaultOptions = {
        theme: 'snow',
        placeholder: options.placeholder || '请输入内容...',
        modules: {
          toolbar: options.toolbar || [
            [{ 'header': [3, 4, false] }],
            ['bold', 'italic', 'underline'],
            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
            ['clean']
          ]
        }
      };
      
      const quill = new Quill('#' + editorId, defaultOptions);
      
      // 设置初始内容
      if (options.content) {
        quill.root.innerHTML = options.content;
      }
      
      quillEditors[containerId] = quill;
      return quill;
    }
    
    function getQuillContent(containerId) {
      if (quillEditors[containerId]) {
        return quillEditors[containerId].root.innerHTML;
      }
      const container = document.getElementById(containerId);
      if (container) {
        const editor = container.querySelector('.ql-editor');
        if (editor) return editor.innerHTML;
      }
      return '';
    }
    
    function destroyQuillEditors() {
      Object.keys(quillEditors).forEach(key => {
        try {
          quillEditors[key].destroy();
        } catch (e) {}
        delete quillEditors[key];
      });
      quillEditors = {};
    }
    
    // 带富文本的字段配置
    const richTextFields = {
      recipe: ['description', 'nutrition', 'common_mistakes', 'success_tips', 'ingredient_substitutes', 'suitable_for', 'required_tools'],
      ingredient: ['description'],
      knowledge: ['summary', 'content'],
      cuisine: ['description'],
      tag: []
    };
    
    // 初始化（脚本在DOM之后，直接执行即可）
    function initAdmin() {
      try {
        checkAuth();
        initNavigation();
        loadStats();
      } catch (e) {
        console.error('Admin init error:', e);
      }
    }
    
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAdmin);
    } else {
      initAdmin();
    }
    
    // 检查登录状态
    function checkAuth() {
      const token = localStorage.getItem('admin_token');
      if (!token) {
        showLoginModal();
      } else {
        fetch(API_BASE + '/stats', {
          headers: { 'Authorization': 'Bearer ' + token }
        }).then(res => {
          if (res.status === 401 || res.status === 403) {
            localStorage.removeItem('admin_token');
            showLoginModal();
          }
        });
      }
    }
    
    // 显示登录弹窗
    function showLoginModal() {
      const modal = document.getElementById('edit-modal');
      const body = document.getElementById('modal-body');
      const title = document.getElementById('modal-title');
      const footer = document.getElementById('modal-footer');
      
      // 销毁可能存在的富文本编辑器
      destroyQuillEditors();
      
      title.textContent = '管理员登录';
      body.innerHTML = `
        <div class="form-group">
          <label>邮箱</label>
          <input type="email" id="login-email" placeholder="请输入邮箱">
        </div>
        <div class="form-group">
          <label>密码</label>
          <input type="password" id="login-password" placeholder="请输入密码" onkeypress="if(event.key==='Enter')doLogin()">
        </div>
        <p style="color: var(--color-text-secondary); font-size: 0.8rem;">
          请使用管理员账号登录
        </p>
      `;
      footer.innerHTML = `
        <button class="btn btn-primary" onclick="doLogin()">登录</button>
      `;
      modal.classList.add('show');
    }
    
    // 登录
    function doLogin() {
      const email = document.getElementById('login-email').value;
      const password = document.getElementById('login-password').value;
      
      if (!email || !password) {
        showToast('请输入邮箱和密码', 'error');
        return;
      }
      
      fetch('https://api.chanmaoyoupu.com/api/auth/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password })
      }).then(res => res.json()).then(data => {
        if (data.success) {
          if (data.data.user.role !== 'admin') {
            showToast('该账号没有管理员权限', 'error');
            return;
          }
          localStorage.setItem('admin_token', data.data.token);
          localStorage.setItem('admin_user', JSON.stringify(data.data.user));
          closeModal();
          updateUserInfo();
          loadStats();
          showToast('登录成功', 'success');
        } else {
          showToast(data.error || '登录失败', 'error');
        }
      }).catch(() => {
        showToast('网络错误，请稍后重试', 'error');
      });
    }
    
    // 退出登录
    function logout() {
      localStorage.removeItem('admin_token');
      localStorage.removeItem('admin_user');
      showLoginModal();
    }
    
    // 更新用户信息显示
    function updateUserInfo() {
      const user = JSON.parse(localStorage.getItem('admin_user') || '{}');
      document.getElementById('user-email').textContent = user.email || '未登录';
    }
    
    // 导航切换
    function initNavigation() {
      const links = document.querySelectorAll('.admin-nav a');
      if (!links || links.length === 0) {
        console.warn('Admin nav links not found');
        return;
      }
      
      links.forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          try {
            const page = this.dataset.page;
            if (!page) return;
            
            // 切换激活状态
            links.forEach(a => a.classList.remove('active'));
            this.classList.add('active');
            
            // 切换内容区域
            document.querySelectorAll('.page-section').forEach(s => s.classList.remove('active'));
            const targetSection = document.getElementById('page-' + page);
            if (targetSection) {
              targetSection.classList.add('active');
            }
            
            // 更新标题
            const titleEl = document.getElementById('page-title');
            const spanEl = this.querySelector('span');
            if (titleEl && spanEl) {
              titleEl.textContent = spanEl.textContent;
            }
            
            // 加载对应数据
            if (page === 'recipes') loadRecipes();
            else if (page === 'ingredients') loadIngredients();
            else if (page === 'knowledge') loadKnowledge();
            else if (page === 'categories') loadCuisines();
            else if (page === 'push') loadPushContentOptions();
          } catch (err) {
            console.error('Navigation error:', err);
          }
        });
      });
    }
    
    // 获取认证头
    function getAuthHeaders() {
      const token = localStorage.getItem('admin_token');
      return {
        'Content-Type': 'application/json',
        'Authorization': 'Bearer ' + (token || '')
      };
    }
    
    // ============ 统计数据 ============
    function loadStats() {
      fetch(API_BASE + '/stats', { headers: getAuthHeaders() })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            document.getElementById('stat-recipes').textContent = data.data.recipes || 0;
            document.getElementById('stat-ingredients').textContent = data.data.ingredients || 0;
            document.getElementById('stat-knowledge').textContent = data.data.knowledge || 0;
            document.getElementById('stat-cuisines').textContent = data.data.cuisines || 0;
            document.getElementById('stat-tags').textContent = data.data.tags || 0;
            document.getElementById('stat-users').textContent = data.data.users || 0;
          }
        });
    }
    
    // ============ 食谱管理 ============
    function loadRecipes() {
      const page = currentPage.recipes;
      const keyword = document.getElementById('recipe-search').value;
      const status = document.getElementById('recipe-status').value;
      
      let url = API_BASE + '/recipes?page=' + page + '&limit=10';
      if (keyword) url += '&keyword=' + encodeURIComponent(keyword);
      if (status !== '') url += '&published=' + status;
      
      fetch(url, { headers: getAuthHeaders() })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            renderRecipesTable(data.data.items);
            renderPagination('recipes', data.data);
          }
        });
    }
    
    function searchRecipes() {
      currentPage.recipes = 1;
      loadRecipes();
    }
    
    function renderRecipesTable(items) {
      const container = document.getElementById('recipes-table-container');
      if (!items || items.length === 0) {
        container.innerHTML = '<div class="loading"><p>暂无数据</p></div>';
        return;
      }
      
      let html = '<table class="data-table"><thead><tr>';
      html += '<th>ID</th><th>标题</th><th>Slug</th><th>难度</th><th>菜系</th><th>状态</th><th>操作</th>';
      html += '</tr></thead><tbody>';
      
      items.forEach(item => {
        const statusText = item.published ? '已发布' : '草稿';
        const statusClass = item.published ? 'status-published' : 'status-draft';
        html += `<tr>
          <td>${item.id}</td>
          <td>${item.title}</td>
          <td><code style="font-size: 0.8rem;">${item.slug}</code></td>
          <td>${item.difficulty || '-'}</td>
          <td>${item.cuisine_name || '-'}</td>
          <td><span class="status-badge ${statusClass}">${statusText}</span></td>
          <td>
            <button class="btn btn-secondary btn-sm" onclick="editRecipe(${item.id})">编辑</button>
            <button class="btn btn-secondary btn-sm" onclick="toggleRecipePublish(${item.id}, ${item.published ? 0 : 1})">
              ${item.published ? '下架' : '上架'}
            </button>
            <button class="btn btn-danger btn-sm" onclick="deleteRecipe(${item.id})">删除</button>
          </td>
        </tr>`;
      });
      
      html += '</tbody></table>';
      container.innerHTML = html;
    }
    
    function openRecipeModal(id) {
      currentItemType = 'recipe';
      currentItem = null;
      
      const title = document.getElementById('modal-title');
      
      if (id) {
        title.textContent = '编辑食谱';
        fetch(API_BASE + '/recipes/' + id, { headers: getAuthHeaders() })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              currentItem = data.data;
              renderRecipeForm(data.data);
            }
          });
      } else {
        title.textContent = '新增食谱';
        renderRecipeForm({});
      }
      
      document.getElementById('edit-modal').classList.add('show');
    }
    
    function editRecipe(id) {
      openRecipeModal(id);
    }
    
    function renderRecipeForm(data) {
      const body = document.getElementById('modal-body');

      // 构建食材HTML
      let ingredientsHtml = '';
      const ingredients = data.ingredients || [];
      if (ingredients.length === 0) {
        ingredientsHtml = '<p style="color: var(--color-text-secondary); font-size: 0.85rem; margin: 0;">暂无食材，点击下方按钮添加</p>';
      } else {
        ingredients.forEach((ing, idx) => {
          ingredientsHtml += `
            <div class="ingredient-row" style="display: flex; gap: 8px; margin-bottom: 8px;">
              <input type="text" placeholder="食材名称" value="${ing.name || ''}" style="flex: 1; padding: 6px 10px; border: 1px solid var(--color-border); border-radius: 4px; font-size: 0.85rem; background: var(--color-bg); color: var(--color-text);">
              <input type="text" placeholder="用量" value="${ing.amount || ''}" style="width: 120px; padding: 6px 10px; border: 1px solid var(--color-border); border-radius: 4px; font-size: 0.85rem; background: var(--color-bg); color: var(--color-text);">
              <button type="button" onclick="removeIngredientRow(this)" style="padding: 6px 12px; background: #fee2e2; color: #dc2626; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">删除</button>
            </div>
          `;
        });
      }

      // 构建步骤HTML
      let stepsHtml = '';
      const steps = data.steps || [];
      if (steps.length === 0) {
        stepsHtml = '<p style="color: var(--color-text-secondary); font-size: 0.85rem; margin: 0;">暂无步骤，点击下方按钮添加</p>';
      } else {
        steps.forEach((step, idx) => {
          stepsHtml += `
            <div class="step-row" style="margin-bottom: 8px;">
              <div style="display: flex; gap: 8px; align-items: flex-start;">
                <span style="font-weight: 600; color: var(--color-accent); min-width: 24px; padding-top: 6px;">${idx + 1}.</span>
                <textarea placeholder="步骤描述" rows="2" style="flex: 1; padding: 6px 10px; border: 1px solid var(--color-border); border-radius: 4px; font-size: 0.85rem; resize: vertical; background: var(--color-bg); color: var(--color-text);">${step.text || ''}</textarea>
                <button type="button" onclick="removeStepRow(this)" style="padding: 6px 12px; background: #fee2e2; color: #dc2626; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem; white-space: nowrap;">删除</button>
              </div>
            </div>
          `;
        });
      }

      body.innerHTML = `
        <div style="border-bottom: 1px solid var(--color-border); padding-bottom: 12px; margin-bottom: 12px;">
          <h4 style="margin: 0 0 12px 0; color: var(--color-title); font-size: 0.95rem;">基本信息</h4>
          <div class="form-group">
            <label>标题 *</label>
            <input type="text" id="recipe-title" value="${data.title || ''}" placeholder="食谱标题">
          </div>
          <div class="form-group">
            <label>Slug *</label>
            <input type="text" id="recipe-slug" value="${data.slug || ''}" placeholder="url-friendly slug">
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>难度</label>
              <select id="recipe-difficulty">
                <option value="简单" ${data.difficulty === '简单' ? 'selected' : ''}>简单</option>
                <option value="中等" ${data.difficulty === '中等' ? 'selected' : ''}>中等</option>
                <option value="较难" ${data.difficulty === '较难' ? 'selected' : ''}>较难</option>
              </select>
            </div>
            <div class="form-group">
              <label>烹饪时间(分钟)</label>
              <input type="number" id="recipe-cooktime" value="${data.cook_time || ''}">
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>份量(人份)</label>
              <input type="number" id="recipe-servings" value="${data.servings || ''}">
            </div>
            <div class="form-group">
              <label>卡路里</label>
              <input type="number" id="recipe-calories" value="${data.calories || ''}">
            </div>
          </div>
          <div class="form-group">
            <label>菜系</label>
            <select id="recipe-cuisine">
              <option value="">无</option>
            </select>
          </div>
          <div class="form-group">
            <label>封面图URL</label>
            <input type="text" id="recipe-cover" value="${data.cover_url || ''}" placeholder="https://...">
          </div>
          <div class="form-group">
            <label>简介</label>
            <div id="recipe-description" class="quill-small"></div>
          </div>
          <div class="form-group">
            <label>发布状态</label>
            <select id="recipe-published">
              <option value="1" ${data.published === 1 ? 'selected' : ''}>发布</option>
              <option value="0" ${data.published === 0 ? 'selected' : ''}>草稿</option>
            </select>
          </div>
        </div>

        <div style="border-bottom: 1px solid var(--color-border); padding-bottom: 12px; margin-bottom: 12px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <h4 style="margin: 0; color: var(--color-title); font-size: 0.95rem;">食材清单</h4>
            <button type="button" onclick="addIngredientRow()" style="padding: 4px 12px; background: var(--color-accent); color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">+ 添加食材</button>
          </div>
          <div id="ingredients-list">${ingredientsHtml}</div>
        </div>

        <div style="border-bottom: 1px solid var(--color-border); padding-bottom: 12px; margin-bottom: 12px;">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
            <h4 style="margin: 0; color: var(--color-title); font-size: 0.95rem;">烹饪步骤</h4>
            <button type="button" onclick="addStepRow()" style="padding: 4px 12px; background: var(--color-accent); color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">+ 添加步骤</button>
          </div>
          <div id="steps-list">${stepsHtml}</div>
        </div>

        <div>
          <h4 style="margin: 0 0 12px 0; color: var(--color-title); font-size: 0.95rem;">详细信息</h4>
          <div class="form-group">
            <label>营养价值</label>
            <div id="recipe-nutrition"></div>
          </div>
          <div class="form-group">
            <label>常见误区</label>
            <div id="recipe-common-mistakes"></div>
          </div>
          <div class="form-group">
            <label>成功技巧</label>
            <div id="recipe-success-tips"></div>
          </div>
          <div class="form-group">
            <label>食材替代</label>
            <div id="recipe-substitutes"></div>
          </div>
          <div class="form-group">
            <label>适宜人群</label>
            <div id="recipe-suitable-for"></div>
          </div>
          <div class="form-group">
            <label>所需厨具</label>
            <div id="recipe-required-tools"></div>
          </div>
        </div>
      `;

      // 加载菜系选项
      loadCuisineOptions(data.cuisine_id);
      
      // 初始化富文本编辑器
      setTimeout(() => {
        initQuillEditor('recipe-description', {
          content: data.description || '',
          placeholder: '简要介绍这道菜的特点...',
          toolbar: ['bold', 'italic', { 'list': 'bullet' }, 'clean']
        });
        
        const fieldConfig = {
          'recipe-nutrition': { placeholder: '如：富含蛋白质、维生素...', content: data.nutrition || '' },
          'recipe-common-mistakes': { placeholder: '如：不要过度翻炒以免变老...', content: data.common_mistakes || '' },
          'recipe-success-tips': { placeholder: '如：冷水下锅焯水去腥味...', content: data.success_tips || '' },
          'recipe-substitutes': { placeholder: '如：没有料酒可用黄酒代替...', content: data.ingredient_substitutes || '' },
          'recipe-suitable-for': { placeholder: '如：一般人群均可食用...', content: data.suitable_for || '' },
          'recipe-required-tools': { placeholder: '如：炒锅、铲子、盘子...', content: data.required_tools || '' }
        };
        
        Object.keys(fieldConfig).forEach(fieldId => {
          initQuillEditor(fieldId, {
            content: fieldConfig[fieldId].content,
            placeholder: fieldConfig[fieldId].placeholder,
            toolbar: [
              [{ 'header': [3, 4, false] }],
              ['bold', 'italic', 'underline'],
              [{ 'list': 'ordered'}, { 'list': 'bullet' }],
              ['clean']
            ]
          });
        });
      }, 10);
    }

    // 加载菜系下拉选项
    function loadCuisineOptions(selectedId) {
      fetch(API_BASE + '/cuisines?all=1', { headers: getAuthHeaders() })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            const select = document.getElementById('recipe-cuisine');
            if (!select) return;
            data.data.forEach(c => {
              if (c.id === 0) return;
              const option = document.createElement('option');
              option.value = c.id;
              option.textContent = c.name;
              if (selectedId && c.id === selectedId) option.selected = true;
              select.appendChild(option);
            });
          }
        });
    }

    // 添加食材行
    function addIngredientRow() {
      const list = document.getElementById('ingredients-list');
      if (!list) return;
      const row = document.createElement('div');
      row.className = 'ingredient-row';
      row.style.cssText = 'display: flex; gap: 8px; margin-bottom: 8px;';
      row.innerHTML = `
        <input type="text" placeholder="食材名称" style="flex: 1; padding: 6px 10px; border: 1px solid var(--color-border); border-radius: 4px; font-size: 0.85rem; background: var(--color-bg); color: var(--color-text);">
        <input type="text" placeholder="用量" style="width: 120px; padding: 6px 10px; border: 1px solid var(--color-border); border-radius: 4px; font-size: 0.85rem; background: var(--color-bg); color: var(--color-text);">
        <button type="button" onclick="removeIngredientRow(this)" style="padding: 6px 12px; background: #fee2e2; color: #dc2626; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">删除</button>
      `;
      list.appendChild(row);
    }

    // 删除食材行
    function removeIngredientRow(btn) {
      const row = btn.closest('.ingredient-row');
      if (row) row.remove();
    }

    // 添加步骤行
    function addStepRow() {
      const list = document.getElementById('steps-list');
      if (!list) return;
      const rows = list.querySelectorAll('.step-row');
      const stepNum = rows.length + 1;

      const row = document.createElement('div');
      row.className = 'step-row';
      row.style.marginBottom = '8px';
      row.innerHTML = `
        <div style="display: flex; gap: 8px; align-items: flex-start;">
          <span style="font-weight: 600; color: var(--color-accent); min-width: 24px; padding-top: 6px;">${stepNum}.</span>
          <textarea placeholder="步骤描述" rows="2" style="flex: 1; padding: 6px 10px; border: 1px solid var(--color-border); border-radius: 4px; font-size: 0.85rem; resize: vertical; background: var(--color-bg); color: var(--color-text);"></textarea>
          <button type="button" onclick="removeStepRow(this)" style="padding: 6px 12px; background: #fee2e2; color: #dc2626; border: none; border-radius: 4px; cursor: pointer; font-size: 0.8rem; white-space: nowrap;">删除</button>
        </div>
      `;
      list.appendChild(row);
    }

    // 删除步骤行
    function removeStepRow(btn) {
      const row = btn.closest('.step-row');
      if (row) row.remove();
      // 重新编号
      const rows = document.querySelectorAll('#steps-list .step-row');
      rows.forEach((rowEl, idx) => {
        const numSpan = rowEl.querySelector('span');
        if (numSpan) numSpan.textContent = (idx + 1) + '.';
      });
    }
    
    function toggleRecipePublish(id, published) {
      fetch(API_BASE + '/recipes/' + id + '/publish', {
        method: 'PUT',
        headers: getAuthHeaders(),
        body: JSON.stringify({ published })
      }).then(res => res.json()).then(data => {
        if (data.success) {
