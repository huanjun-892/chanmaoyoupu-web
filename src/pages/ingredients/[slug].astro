---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import { getAllIngredients, difficultyLabel, getCoverUrl } from '../../lib/strapi';

export async function getStaticPaths() {
  const ingredients = await getAllIngredients();
  return ingredients.map((i: any) => ({
    params: { slug: i.slug },
    props: { ingredient: i },
  }));
}

const { ingredient } = Astro.props;

if (!ingredient) {
  return Astro.redirect('/ingredients');
}

const categoryLabel = ingredient.category === 'seasoning' ? '调料' : '食材';
const categoryIcon = ingredient.category === 'seasoning' ? '🧂' : '🥬';  // fallback when no image

// SEO
const pageDescription = ingredient.description || `${ingredient.name}的营养价值、选购技巧和搭配建议，了解${ingredient.name}的正确使用方法。`;
const pageKeywords = `${ingredient.name},${categoryLabel},营养价值,食用方法${ingredient.aliases ? ',' + ingredient.aliases : ''}`;

// Schema.org - Food schema
const foodSchema = {
  "@context": "https://schema.org",
  "@type": "Food",
  "name": ingredient.name,
  "description": ingredient.description || '',
  "image": ingredient.imageUrl || undefined,
  "category": categoryLabel
};
---

<BaseLayout title={ingredient.name} description={pageDescription} keywords={pageKeywords}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(foodSchema)} />
  </Fragment>
  <article class="ingredient-detail">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">首页</a>
        <span class="sep">/</span>
        <a href="/ingredients">食材调料</a>
        <span class="sep">/</span>
        <span>{ingredient.name}</span>
      </nav>

      <div class="ingredient-header">
        <div class="header-icon">{ingredient.imageUrl ? <img src={ingredient.imageUrl} alt={ingredient.name} /> : categoryIcon}</div>
        <div class="header-info">
          <div class="header-tags">
            <span class="tag-category">{categoryLabel}</span>
            {ingredient.aliases && <span class="tag-alias">又名：{ingredient.aliases}</span>}
          </div>
          <h1 class="ingredient-name">{ingredient.name}</h1>
          <p class="ingredient-desc">{ingredient.description}</p>
        </div>
      </div>

      <div class="ingredient-body">
        <div class="info-grid">
          {ingredient.nutrition && (
          <section class="info-card">
            <h2 class="info-title">🥗 营养价值</h2>
            <div class="info-content" set:html={ingredient.nutrition} />
          </section>
          )}

          {ingredient.tips && (
          <section class="info-card">
            <h2 class="info-title">💡 选购与使用技巧</h2>
            <div class="info-content" set:html={ingredient.tips} />
          </section>
          )}

          {ingredient.season && (
          <section class="info-card">
            <h2 class="info-title">🗓 时令季节</h2>
            <div class="info-content" set:html={ingredient.season} />
          </section>
          )}

          {ingredient.origin && (
          <section class="info-card">
            <h2 class="info-title">📍 产地来源</h2>
            <div class="info-content" set:html={ingredient.origin} />
          </section>
          )}

          {ingredient.storageMethod && (
          <section class="info-card">
            <h2 class="info-title">🗄 储存方法</h2>
            <div class="info-content" set:html={ingredient.storageMethod} />
          </section>
          )}

          {ingredient.pairingSuggestions && (
          <section class="info-card">
            <h2 class="info-title">🤝 搭配建议</h2>
            <div class="info-content" set:html={ingredient.pairingSuggestions} />
          </section>
          )}

          {ingredient.avoidWith && (
          <section class="info-card info-card-warning">
            <h2 class="info-title">🚫 不宜搭配</h2>
            <div class="info-content" set:html={ingredient.avoidWith} />
          </section>
          )}
        </div>
      </div>

      {ingredient.relatedRecipes && ingredient.relatedRecipes.length > 0 && (
      <section class="related-recipes">
        <h2 class="section-heading">相关食谱</h2>
        <div class="grid-3">
          {ingredient.relatedRecipes.map((r: any) => (
            <RecipeCard
              title={r.title}
              slug={r.slug}
              difficulty={difficultyLabel(r.difficulty)}
              cookTime={r.cookTime}
              tags={[]}
              cover={getCoverUrl(r.cover)}
            />
          ))}
        </div>
      </section>
      )}
    </div>
  </article>
</BaseLayout>

<style>
  .breadcrumb { font-size: 0.82rem; color: var(--color-muted); margin-bottom: 24px; }
  .breadcrumb a { color: var(--color-muted); transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--color-accent); }
  .breadcrumb .sep { margin: 0 6px; }

  .ingredient-header {
    display: flex; align-items: flex-start; gap: 20px;
    margin-bottom: 40px; padding: 28px;
    background: var(--color-bg-warm); border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }
  .header-icon { font-size: 3.5rem; flex-shrink: 0; width: 100px; height: 100px; display: flex; align-items: center; justify-content: center; border-radius: 16px; overflow: hidden; background: var(--color-bg-warm); }
  .header-icon img { width: 100%; height: 100%; object-fit: cover; border-radius: 16px; }
  .header-info { flex: 1; }
  .header-tags { display: flex; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
  .tag-category { padding: 3px 12px; border-radius: 100px; font-size: 0.78rem; font-weight: 500; background: #FFF3E0; color: #E65100; }
  .tag-alias { padding: 3px 12px; border-radius: 100px; font-size: 0.78rem; background: #F3E5F5; color: #6A1B9A; }
  .ingredient-name { font-size: 2rem; font-weight: 800; color: var(--color-title); margin-bottom: 10px; }
  .ingredient-desc { font-size: 1rem; color: var(--color-text); line-height: 1.7; }

  .info-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px; margin-bottom: 40px;
  }
  .info-card {
    padding: 20px; background: var(--color-bg);
    border: 1px solid var(--color-border); border-radius: var(--radius);
  }
  .info-title { font-size: 1.05rem; font-weight: 700; color: var(--color-title); margin-bottom: 12px; }
  .info-content { font-size: 0.9rem; color: var(--color-text); line-height: 1.7; }

  .info-card-warning {
    background: #FFF5F5;
    border-color: #FFCCC7;
  }
  .info-card-warning .info-title {
    color: #D4380D;
  }

  .section-heading {
    font-size: 1.15rem; font-weight: 700; color: var(--color-title);
    margin-bottom: 20px; padding-bottom: 8px;
    border-bottom: 2px solid var(--color-accent); display: inline-block;
  }
  .related-recipes { margin-top: 40px; padding-top: 32px; border-top: 1px solid var(--color-border); }

  @media (max-width: 768px) {
    .ingredient-header { flex-direction: column; align-items: center; text-align: center; }
    .header-tags { justify-content: center; }
    .ingredient-name { font-size: 1.5rem; }
  }
</style>
