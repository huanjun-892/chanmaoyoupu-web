          sample: [
            {
              '名称': '土豆',
              'Slug': 'tu-dou',
              '分类': '蔬菜',
              '图片': '',
              '别名': '马铃薯、洋芋',
              '产地': '全国各地',
              '季节': '秋季',
              '状态': 1,
              '简介': '土豆是全球第四大重要的粮食作物',
              '营养价值': '富含淀粉、蛋白质、维生素C和B族维生素',
              '选购技巧': '选择表皮光滑、无发芽、无绿色部分的土豆',
