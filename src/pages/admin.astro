    function generatePlatformContent(item, type, platform) {
      const title = item.title;
      const desc = item.description || item.summary || '';
      
      const platformStyles = {
        wechat: {
          prefix: '🍜 ',
          suffix: '\n\n— END —\n喜欢的话记得点赞+在看哦～\n关注「馋猫有谱」，每天学一道家常菜',
          style: '公众号风格，段落分明，语气亲切'
        },
        xiaohongshu: {
          prefix: '🔥 ',
          suffix: '\n\n#美食教程 #家常菜 #食谱分享 #做饭教程 #美食日常 #吃货薯',
          style: '小红书风格，emoji丰富，口语化，有吸引力'
        },
        douyin: {
          prefix: '',
          suffix: '\n\n喜欢的话记得点赞关注哦 👆',
          style: '短视频口播文案，口语化，有节奏感'
        },
        toutiao: {
          prefix: '',
          suffix: '\n\n—— 馋猫有谱 · 专注家常美食 ——',
          style: '头条风格，信息密度高，结构清晰'
        },
        bilibili: {
          prefix: '',
          suffix: '\n\n觉得有用的话记得一键三连哦～ 支持一下up主！',
          style: 'B站风格，轻松活泼，有网感'
        }
      };
      
      const style = platformStyles[platform] || platformStyles.wechat;
      
      if (type === 'recipe') {
        const ingredients = item.ingredients || [];
        const steps = item.steps || [];
        
        let content = style.prefix + title + '\n\n';
        content += '📝 食材清单：\n';
        ingredients.forEach(ing => {
          content += '• ' + ing.name + '：' + (ing.amount || '适量') + '\n';
        });
        
        content += '\n👨‍🍳 做法步骤：\n';
        steps.forEach((step, idx) => {
          content += (idx + 1) + '. ' + (step.text || step.description || '') + '\n';
        });
        
        content += '\n💡 小贴士：\n';
        content += (item.success_tips || item.tips || '根据个人口味调整盐和调料的用量～') + '\n';
        content += style.suffix;
        
        return content;
      } else if (type === 'ingredient') {
        let content = style.prefix + title + '\n\n';
        content += '🥗 食材介绍：\n';
        content += (item.description || desc || '').replace(/<[^>]+>/g, '') + '\n\n';
        
        if (item.nutrition) {
          content += '📊 营养价值：\n';
          content += item.nutrition.replace(/<[^>]+>/g, '') + '\n\n';
        }
        
        if (item.tips) {
          content += '💡 选购与保存：\n';
          content += item.tips.replace(/<[^>]+>/g, '') + '\n\n';
        }
        
        content += style.suffix;
        return content;
      } else {
        let content = style.prefix + title + '\n\n';
        content += (item.content || desc || '').replace(/<[^>]+>/g, '') + '\n\n';
        content += style.suffix;
        return content;
      }
    }
    
